@page
@model Proyecto_Laboratorios_Univalle.Pages.Admin.TestConnectionModel
@{
    ViewData["Title"] = "Prueba de Conexión a Base de Datos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-database-check"></i> Diagnóstico de Conexión
                    </h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Esta página te permite verificar la conectividad con la base de datos antes de publicar.
                    </p>

                    <form method="post">
                        <button type="submit" class="btn btn-lg btn-primary">
                            <i class="bi bi-play-circle"></i> Probar Conexión
                        </button>
                    </form>

                    @if (Model.TestResult != null)
                    {
                        <div class="mt-4 alert @(Model.TestResult.Value.Success ? "alert-success" : "alert-danger")" role="alert">
                            <h4 class="alert-heading">
                                @if (Model.TestResult.Value.Success)
                                {
                                    <i class="bi bi-check-circle-fill"></i> <text>Conexión Exitosa</text>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle-fill"></i> <text>Error de Conexión</text>
                                }
                            </h4>
                            <p class="mb-0">@Model.TestResult.Value.Message</p>
                        </div>

                        @if (Model.TestResult.Value.Success)
                        {
                            <div class="mt-3">
                                <h5>Información de la Conexión:</h5>
                                <ul class="list-group">
                                    <li class="list-group-item">
                                        <strong>Servidor:</strong> @Model.ServerInfo
                                    </li>
                                    <li class="list-group-item">
                                        <strong>Base de Datos:</strong> @Model.DatabaseInfo
                                    </li>
                                    <li class="list-group-item">
                                        <strong>Hora del Servidor:</strong> @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="mt-3">
                                <h5>Sugerencias para resolver el problema:</h5>
                                <ul>
                                    <li>Verifica que el servidor de base de datos esté en línea</li>
                                    <li>Confirma que las credenciales en <code>appsettings.json</code> sean correctas</li>
                                    <li>Asegúrate de que el firewall permita conexiones al puerto 1433</li>
                                    <li>Revisa el archivo de log en <code>logs/connection_errors.txt</code></li>
                                </ul>
                            </div>
                        }
                    }

                    <div class="mt-4">
                        <h5>Cadena de Conexión Actual:</h5>
                        <pre class="bg-light p-3 rounded"><code>@Model.ConnectionString</code></pre>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        pre code {
            font-size: 0.85rem;
            word-break: break-all;
        }
    </style>
}

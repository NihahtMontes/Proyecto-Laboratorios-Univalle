@page
@model Proyecto_Laboratorios_Univalle.Pages.Users.IndexModel

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-md-flex align-items-center">
                    <div>
                        <h4 class="card-title">Listado de Usuarios Registrados</h4>
                        <h5 class="card-subtitle">Administre los accesos y roles del personal de laboratorios</h5>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="thead-light">
                            <tr>
                                <th>Nombre</th>
                                <th>@Html.DisplayNameFor(model => model.User[0].IdentityCard)</th>
                                <th>@Html.DisplayNameFor(model => model.User[0].Role)</th>
                                <th>@Html.DisplayNameFor(model => model.User[0].Status)</th>
                                <th>@Html.DisplayNameFor(model => model.User[0].Position)</th>
                                <th>Email</th>
                                <th>Auditoría</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                    @foreach (var item in Model.User) {
                            <tr>
                                <td>
                                    <strong>@Html.DisplayFor(modelItem => item.FirstName) @Html.DisplayFor(modelItem => item.LastName)</strong>
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.IdentityCard)</td>
                                <td><span class="badge badge-info">@Html.DisplayFor(modelItem => item.Role)</span></td>
                                <td>
                                    <span class="badge badge-@(item.Status == Proyecto_Laboratorios_Univalle.Models.Enums.GeneralStatus.Activo ? "success" : "danger")">
                                        @Html.DisplayFor(modelItem => item.Status)
                                    </span>
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.Position)</td>
                                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                                <td>
                                    <small class="text-muted">
                                        Alt: @item.CreatedDate.ToString("dd/MM/yy")<br/>
                                        por @item.CreatedBy?.Initials
                                    </small>
                                </td>
                                <td>
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-info"><i class="fas fa-info-circle"></i></a>
                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                    }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <a asp-page="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Crear Nuevo Usuario</a>
                </div>
            </div>
        </div>
    </div>
</div>

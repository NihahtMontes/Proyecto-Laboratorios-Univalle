@page
@model Proyecto_Laboratorios_Univalle.Pages.Users.IndexModel


<h1>Lista de Usuarios</h1>


<div class="row">
    <div class="col-12">
        <div class="card">
            <!-- Navegación de Pestañas Estilo NiceAdmin -->
            <ul class="nav nav-tabs customtab" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-toggle="tab" href="#usuarios" role="tab">
                        <span class="hidden-sm-up"><i class="ti-user"></i></span>
                        <span class="hidden-xs-down"> Listado de Usuarios</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#personas" role="tab">
                        <span class="hidden-sm-up"><i class="ti-id-badge"></i></span>
                        <span class="hidden-xs-down"> Gestión de Personas</span>
                    </a>
                </li>
            </ul>

            <!-- Contenido de las Pestañas -->
            <div class="tab-content">

                <!-- PESTAÑA 1: USUARIOS -->
                <div class="tab-pane active" id="usuarios" role="tabpanel">
                    <div class="card-body">
                        <div class="d-md-flex align-items-center mb-3">
                            <div>
                                <h4 class="card-title">Cuentas de Usuario</h4>
                                <h6 class="card-subtitle">Administre los accesos y roles del sistema</h6>
                            </div>
                            <div class="ml-auto">
                                <a asp-page="Create" class="btn btn-sm btn-info btn-rounded">
                                    <i class="fas fa-plus mr-1"></i> Crear Usuario
                                </a>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover v-middle">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Rol</th>
                                        <th>Estado</th>
                                        <th>Cargo</th>
                                        <th>Email</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.User)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="m-r-10"><span class="btn btn-circle btn-sm btn-light-info text-info">@item.FirstName.Substring(0, 1)</span></div>
                                                    <div class="">
                                                        <h5 class="m-b-0 font-16">@item.FirstName @item.LastName</h5>
                                                        <small class="text-muted">C.I: @item.IdentityCard</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><span class="badge badge-light-info text-info font-medium">@item.Role</span></td>
                                            <td>
                                                @if (item.Status == Proyecto_Laboratorios_Univalle.Models.Enums.GeneralStatus.Activo)
                                                {
                                                    <span class="label label-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="label label-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td>@item.Position</td>
                                            <td>@item.Email</td>
                                            <td>
                                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar"><i class="fas fa-edit"></i></a>
                                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Detalles"><i class="fas fa-info-circle"></i></a>
                                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="fas fa-trash"></i></a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- PESTAÑA 2: PERSONAS (Integración Real) -->
                <div class="tab-pane p-20" id="personas" role="tabpanel">
                    <div class="row mb-3">
                        <div class="col-md-8">
                            <h4 class="card-title">Catálogo de Personas Base</h4>
                            <p class="card-subtitle">Personal registrado antes de asignar cuenta de acceso</p>
                        </div>
                        <div class="col-md-4 text-right">
                            <a href="/Persons/Create" class="btn btn-info btn-sm">
                                <i class="fas fa-plus mr-1"></i> Registrar Persona
                            </a>
                            <a href="/Persons/Index" class="btn btn-outline-primary btn-sm ml-2">
                                <i class="fas fa-external-link-alt"></i> Pantalla Completa
                            </a>
                        </div>
                    </div>
                    
                    <!-- AQUÍ SE CARGA LA TABLA REAL -->
                    @if (Model.PersonsList != null && Model.PersonsList.Any())
                    {
                        <partial name="_PersonsTable" model="Model.PersonsList" />
                    }
                    else
                    {
                        <div class="text-center p-40">
                            <h3 class="text-muted"><i class="mdi mdi-account-off display-4"></i></h3>
                            <p>No hay personas registradas aún.</p>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Ajuste para que las pestañas se vean más modernas */
        .customtab .nav-link.active {
            border-bottom: 2px solid #2962ff;
            color: #2962ff;
        }

        .v-middle td {
            vertical-align: middle !important;
        }
        /* Estilo de etiquetas NiceAdmin */
        .label {
            padding: 3px 10px;
            line-height: normal;
            display: inline-block;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 400;
            color: #fff;
        }

        .label-success {
            background-color: #28a745;
        }

        .label-danger {
            background-color: #dc3545;
        }
    </style>
}
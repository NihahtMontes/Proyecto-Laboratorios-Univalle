@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Users.DeleteModel
@using Proyecto_Laboratorios_Univalle.Models.Enums



<div class="row justify-content-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-6 col-lg-5">
        <div class="card text-center shadow-sm border-0">
            <div class="card-body p-5">
                <!-- Warning icon -->
                <div class="mb-4 text-danger">
                    <i class="fas fa-user-times display-3"></i> 
                </div>

                <!-- Title -->
                <h3 class="card-title text-dark font-weight-bold">¿Revocar Acceso al Sistema?</h3>
                <p class="text-muted mb-4">
                    Está a punto de dar de baja la cuenta de usuario de <strong class="text-dark">@Model.AppUser.FullName</strong> (@@@Model.AppUser.UserName).
                    El usuario ya no podrá iniciar sesión, pero su historial de acciones se preservará por integridad institucional.
                </p>

                <!-- Key Data -->
                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100 border-left border-danger border-3 shadow-none italic">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase font-weight-bold">Rol Actual:</span>
                        <strong class="text-dark">@Model.AppUser.Role</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase font-weight-bold">Área/Dpto:</span>
                        <span class="text-dark font-weight-bold small">@(Model.AppUser.Department ?? "No especificado")</span>
                    </div>
                    <div class="d-flex justify-content-between pt-2 border-top">
                        <span class="text-muted small uppercase font-weight-bold">Documento (CI):</span>
                        <span class="text-dark small font-weight-bold">@Model.AppUser.IdentityCard</span>
                    </div>
                </div>

                <!-- Buttons -->
                <form method="post">
                    <input type="hidden" asp-for="AppUser.Id" />
                    
                    <a asp-page="./Details" asp-route-id="@Model.AppUser.Id" class="btn btn-outline-secondary btn-rounded px-4 mr-2 py-2 font-weight-bold">
                         Ver Expediente
                    </a>
                    <button type="submit" class="btn btn-danger btn-rounded px-4 shadow-sm py-2 font-weight-bold">
                        <i class="fas fa-trash-alt mr-1"></i> Sí, Confirmar Baja
                    </button>
                </form>
                
                <div class="mt-4">
                    <a asp-page="./Index" class="btn btn-link text-muted small font-weight-bold">Volver al Control de Usuarios</a>
                </div>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small italic">
            <i class="fas fa-info-circle mr-1"></i> <strong>Sugerencia Técnica:</strong> Se recomienda <strong>Inactivar</strong> la cuenta desde el editor si el usuario ha realizado registros críticos recientes.
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-3 { border-left-width: 4px !important; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
    </style>
}

@page
@model Proyecto_Laboratorios_Univalle.Pages.Users.DeleteModel

@{
    ViewData["Title"] = "Revocar Acceso";
}

<div class="row justify-content-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-6 col-lg-5">
        <div class="card text-center shadow-sm">
            <div class="card-body p-5">
                <!-- Ícono de advertencia -->
                <div class="mb-4 text-danger">
                    <i class="ti-user display-3 opacity-2" style="position: absolute; left: 50%; transform: translateX(-50%); top: 10px;"></i>
                    <i class="fas fa-user-times display-4" style="position: relative; z-index: 1;"></i>
                </div>

                <!-- Título -->
                <h3 class="card-title text-dark font-weight-bold">¿Revocar Acceso al Sistema?</h3>
                <p class="text-muted mb-4">
                    Estás a punto de eliminar la cuenta de usuario de <strong class="text-dark">@Model.User.FullName</strong> (@@@Model.User.UserName).
                    <br>El usuario ya no podrá iniciar sesión, pero su historial de acciones se mantendrá por integridad.
                </p>

                <!-- Datos clave -->
                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100 border-left border-danger border-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase">Rol Actual:</span>
                        <strong class="text-dark">@Model.User.Role</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase">Dpto:</span>
                        <span class="text-dark font-weight-bold small">@(Model.User.Department ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small uppercase">C.I.:</span>
                        <span class="text-dark small">@Model.User.IdentityCard</span>
                    </div>
                </div>

                <!-- Botones -->
                <form method="post">
                    <input type="hidden" asp-for="User.Id" />
                    
                    <a asp-page="./Details" asp-route-id="@Model.User.Id" class="btn btn-outline-secondary btn-rounded px-4 mr-2">
                         Ver Perfil
                    </a>
                    <button type="submit" class="btn btn-danger btn-rounded px-4 shadow-sm">
                        <i class="fas fa-trash-alt mr-1"></i> Confirmar Eliminación
                    </button>
                </form>
                
                <div class="mt-4">
                    <a asp-page="./Index" class="btn btn-link text-muted small">Volver a Usuarios</a>
                </div>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            <i class="fas fa-info-circle mr-1"></i> Se recomienda <strong>Inactivar</strong> la cuenta en lugar de eliminarla si el usuario ha realizado registros importantes.
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-3 { border-left-width: 3px !important; }
    </style>
}

@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Users.EditModel
@using Proyecto_Laboratorios_Univalle.Models.Enums



<div class="row">
    <!-- Main Column: Profile Management -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Gestión de Perfil de Usuario</h4>
                        <h6 class="card-subtitle text-muted">Actualización de privilegios, credenciales y datos de contacto de la cuenta institucional.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-user-edit fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="row">
                        <!-- Identity Data -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-id-badge mr-2"></i> Identidad y Contacto
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="Input.FirstName" class="control-label font-weight-bold small uppercase text-muted">Nombres <span class="text-danger">*</span></label>
                                        <input asp-for="Input.FirstName" class="form-control" placeholder="Juan" required />
                                        <span asp-validation-for="Input.FirstName" class="text-danger small font-weight-bold"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="Input.LastName" class="control-label font-weight-bold small uppercase text-muted">A. Paterno <span class="text-danger">*</span></label>
                                        <input asp-for="Input.LastName" class="form-control" placeholder="Pérez" required />
                                        <span asp-validation-for="Input.LastName" class="text-danger small font-weight-bold"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Input.SecondLastName" class="control-label font-weight-bold small uppercase text-muted">A. Materno</label>
                                <input asp-for="Input.SecondLastName" class="form-control" />
                                <span asp-validation-for="Input.SecondLastName" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-3 border-left border-info pl-3 bg-light p-3 rounded shadow-none">
                                <label asp-for="Input.IdentityCard" class="control-label font-weight-bold small text-info uppercase">Cédula de Identidad (C.I.) <span class="text-danger">*</span></label>
                                <input asp-for="Input.IdentityCard" class="form-control border-info shadow-none font-weight-bold" required />
                                <span asp-validation-for="Input.IdentityCard" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.Email" class="control-label font-weight-bold small uppercase text-muted">Correo Institucional <span class="text-danger">*</span></label>
                                <input asp-for="Input.Email" class="form-control" required />
                                <span asp-validation-for="Input.Email" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.PhoneNumber" class="control-label font-weight-bold small uppercase text-muted">Teléfono de Contacto</label>
                                <input asp-for="Input.PhoneNumber" class="form-control" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small font-weight-bold"></span>
                            </div>
                        </div>

                        <!-- Security and Profile -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-lock mr-2"></i> Privilegios de Acceso
                            </h5>

                            <div class="form-group mb-3 border-left border-warning pl-3 bg-light p-3 rounded shadow-none">
                                <label asp-for="Input.Role" class="control-label font-weight-bold small text-warning uppercase">Rol de Aplicación <span class="text-danger">*</span></label>
                                <select asp-for="Input.Role" class="form-control custom-select border-warning font-weight-bold" asp-items="ViewBag.UserRole" required></select>
                                <span asp-validation-for="Input.Role" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="bg-light p-3 rounded mb-4 border shadow-none">
                                <h6 class="font-weight-bold text-dark small text-uppercase mb-3 italic"><i class="fas fa-key mr-2 text-muted"></i> Gestión de Credenciales</h6>
                                <div class="form-group mb-3">
                                    <label asp-for="Input.UserName" class="control-label font-weight-bold small uppercase text-muted">Nombre de Usuario (Login)</label>
                                    <input asp-for="Input.UserName" class="form-control bg-white shadow-none" readonly />
                                    <small class="text-muted italic" style="font-size: 0.7rem;">El identificador de acceso es único y permanente.</small>
                                </div>
                                <div class="form-group mb-0">
                                    <label asp-for="Input.NewPassword" class="control-label font-weight-bold small uppercase text-muted">Nueva Contraseña</label>
                                    <input asp-for="Input.NewPassword" type="password" class="form-control shadow-none" placeholder="********" />
                                    <small class="text-warning font-weight-bold d-block mt-2 small">
                                        <i class="fas fa-info-circle mr-1"></i> Deje en blanco para conservar la actual.
                                    </small>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group mb-0">
                                        <label asp-for="Input.Position" class="control-label font-weight-bold small uppercase text-muted">Cargo</label>
                                        <input asp-for="Input.Position" class="form-control shadow-none" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group mb-0">
                                        <label asp-for="Input.Department" class="control-label font-weight-bold small uppercase text-muted">Área/Dpto.</label>
                                        <input asp-for="Input.Department" class="form-control shadow-none" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Sidebar: Control and Audit -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-shield-alt mr-2 text-info"></i> Estatus de Cuenta</h5>
                <hr class="border-secondary" />
                
                <div class="form-group">
                    <label class="small text-muted uppercase font-weight-bold d-block mb-3">Estado Operativo</label>
                    <div class="d-flex align-items-center mb-3">
                         <div class="m-r-10">
                            <div class="btn btn-circle btn-lg btn-@(Model.Input.Status == GeneralStatus.Activo ? "success" : "danger") shadow-sm">
                                <i class="fas fa-power-off"></i>
                            </div>
                        </div>
                        <div>
                            <h5 class="font-weight-bold text-white mb-0">Cuenta @(Model.Input.Status)</h5>
                            <span class="text-muted small">ID: #@Model.Id</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 py-2 border-top border-secondary small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ingreso al Sistema:</span>
                        <span class="font-weight-bold text-info">Habilitado</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Registro Auditado:</span>
                        <span class="text-white">@Model.Input.HireDate?.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-light border-0 p-3 shadow-none italic small text-info border-left border-info border-3">
            <i class="fas fa-info-circle mr-1"></i> <strong>Aviso:</strong> Al modificar el <strong>Rol de Aplicación</strong>, los cambios de permisos se aplicarán en el siguiente inicio de sesión del usuario.
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Advanced text pattern for Spanish names
            var textPattern = /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]*$/;
            
            function setupBlocking(selector, pattern) {
                $(selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g, ''));
                    }
                });
            }

            setupBlocking('#Input_FirstName', textPattern);
            setupBlocking('#Input_LastName', textPattern);
            setupBlocking('#Input_SecondLastName', textPattern);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 4px !important; }
    </style>
}

@page
@using Proyecto_Laboratorios_Univalle.Models.Enums
@model Proyecto_Laboratorios_Univalle.Pages.Maintenances.EditModel

@{
    var categoryList = Html.GetEnumSelectList<CostCategory>();
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Actualizar Servicio #@Model.Input.Id</h4>
                        <h6 class="card-subtitle text-muted">Edite los parámetros técnicos y costos del mantenimiento.</h6>
                    </div>
                    <div class="ml-auto text-right">
                        <span class="badge badge-light shadow-sm py-2 px-3 border">
                            <i class="far fa-clock mr-1"></i> Programado: @(Model.Input.ScheduledDate?.ToShortDateString() ?? "-")
                        </span>
                    </div>
                </div>

                <form method="post" id="maintenanceForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4"></div>
                    <input type="hidden" asp-for="Input.Id" />

                    <div class="bg-light p-4 rounded mb-4 border-left border-warning border-3">
                        <h5 class="text-dark font-weight-bold mb-3"><i class="fas fa-microchip mr-2 text-warning"></i>Contexto del Servicio</h5>
                        <div class="row">
                            <div class="col-md-5">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.EquipmentUnitId" class="control-label font-weight-bold small uppercase text-muted">Equipo Objetivo</label>
                                    <select asp-for="Input.EquipmentUnitId" class="form-control custom-select" asp-items="ViewBag.EquipmentUnitId" required>
                                        <option value="">-- Seleccione Equipo --</option>
                                    </select>
                                    <span asp-validation-for="Input.EquipmentUnitId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.MaintenanceTypeId" class="control-label font-weight-bold small uppercase text-muted">Tipo de Servicio</label>
                                    <select asp-for="Input.MaintenanceTypeId" class="form-control custom-select" asp-items="ViewBag.MaintenanceTypeId" required>
                                        <option value="">-- Categoría --</option>
                                    </select>
                                    <span asp-validation-for="Input.MaintenanceTypeId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.TechnicianId" class="control-label font-weight-bold small uppercase text-muted">Técnico Responsable</label>
                                    <select asp-for="Input.TechnicianId" class="form-control custom-select" asp-items="ViewBag.TechnicianId">
                                        <option value="">-- Asignar Técnico --</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-7">
                            <h5 class="text-dark font-weight-bold mb-3"><i class="far fa-calendar-alt mr-2 text-info"></i>Planificación Temporal</h5>
                            <div class="card border mb-4">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 border-right">
                                            <div class="form-group">
                                                <label asp-for="Input.ScheduledDate" class="control-label font-weight-bold small uppercase text-muted">Fecha Programada</label>
                                                <input asp-for="Input.ScheduledDate" class="form-control" type="date" />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label asp-for="Input.StartDate" class="control-label font-weight-bold small uppercase text-muted">Inicio Real</label>
                                                <input asp-for="Input.StartDate" class="form-control" type="datetime-local" />
                                            </div>
                                            <div class="form-group mb-0">
                                                <label asp-for="Input.EndDate" class="control-label font-weight-bold small uppercase text-muted">Finalización</label>
                                                <input asp-for="Input.EndDate" class="form-control" type="datetime-local" />
                                                <span asp-validation-for="Input.EndDate" class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <h5 class="text-dark font-weight-bold mb-3"><i class="fas fa-thermometer-half mr-2 text-danger"></i>Situación Actual</h5>
                            <div class="card bg-light border-0 mb-4">
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label asp-for="Input.Status" class="control-label font-weight-bold small uppercase text-muted">Estado del Proceso</label>
                                        <select asp-for="Input.Status" class="form-control custom-select border-warning font-weight-bold text-dark"
                                                asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<MaintenanceStatus>()"
                                                id="statusSelector">
                                        </select>
                                    </div>

                                    <div id="costWarning" class="alert alert-warning border-0 rounded shadow-sm d-flex align-items-center" style="display:none">
                                        <i class="fas fa-exclamation-triangle fa-2x mr-3"></i>
                                        <div class="line-height-normal small">
                                            <strong>Requerido:</strong><br />
                                            Para estado <u>Completado</u> debe registrar costos.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border border-light shadow-none mb-4">
                        <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                            <h5 class="text-dark font-weight-bold mb-0"><i class="fas fa-tasks mr-2 text-primary"></i>Lista de Verificación Técnica (L-48)</h5>
                        </div>
                        <div class="card-body px-4 pt-2">
                            <div class="row align-items-center">
                                <div class="col-md-7 border-right">
                                    <div class="custom-control custom-checkbox mb-3">
                                        <input type="checkbox" class="custom-control-input maintenance-check" id="chkStep1Edit" asp-for="Input.Step1_Cleaning" onchange="calculatePercentage()">
                                        <label class="custom-control-label font-weight-bold" for="chkStep1Edit">Limpieza y Desinfección de Componentes</label>
                                    </div>
                                    <div class="custom-control custom-checkbox mb-3">
                                        <input type="checkbox" class="custom-control-input maintenance-check" id="chkStep2Edit" asp-for="Input.Step2_Calibration" onchange="calculatePercentage()">
                                        <label class="custom-control-label font-weight-bold" for="chkStep2Edit">Calibración y Ajuste de Sistema</label>
                                    </div>
                                    <div class="custom-control custom-checkbox mb-3">
                                        <input type="checkbox" class="custom-control-input maintenance-check" id="chkStep3Edit" asp-for="Input.Step3_Testing" onchange="calculatePercentage()">
                                        <label class="custom-control-label font-weight-bold" for="chkStep3Edit">Pruebas de Esfuerzo y Carga Operativa</label>
                                    </div>
                                    <div class="custom-control custom-checkbox mb-2">
                                        <input type="checkbox" class="custom-control-input maintenance-check" id="chkStep4Edit" asp-for="Input.Step4_FinalReview" onchange="calculatePercentage()">
                                        <label class="custom-control-label font-weight-bold" for="chkStep4Edit">Revisión Final de Seguridad y Cierre</label>
                                    </div>
                                </div>
                                <div class="col-md-5 text-center">
                                    <h6 class="text-muted text-uppercase font-weight-bold mb-3">Avance del Mantenimiento</h6>
                                    <h2 id="displayProgressText" class="display-4 font-weight-bold text-primary mb-2">0%</h2>
                                    <div class="progress rounded-pill shadow-sm" style="height: 12px;">
                                        <div id="visualProgressBar" class="progress-bar bg-primary progress-bar-striped" role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <input type="hidden" asp-for="Input.CompletionPercentage" id="hiddenPercentageInput" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Description" class="control-label font-weight-bold text-dark">Descripción del Trabajo / Requerimiento</label>
                        <textarea asp-for="Input.Description" class="form-control rounded" rows="3" required data-validation-required-message="La descripción es obligatoria"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    </div>

                    <div class="card border border-light shadow-none mb-4">
                        <div class="card-header bg-white d-flex align-items-center border-bottom-0 pt-4 px-4">
                            <h5 class="text-dark font-weight-bold mb-0"><i class="fas fa-file-invoice-dollar mr-2 text-success"></i>Control de Costos y Repuestos</h5>
                            <button type="button" class="btn btn-sm btn-success btn-rounded shadow-sm ml-auto font-weight-bold px-3" onclick="addRow()">
                                <i class="fas fa-plus mr-1"></i> Agregar Ítem
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover v-middle mb-0" id="costsTable">
                                    <thead class="bg-light text-uppercase small font-weight-bold text-muted">
                                        <tr>
                                            <th class="pl-4" style="width: 30%">Concepto</th>
                                            <th style="width: 20%">Categoría</th>
                                            <th style="width: 10%" class="text-center">Cant.</th>
                                            <th style="width: 15%" class="text-center">Unitario (Bs)</th>
                                            <th style="width: 15%" class="text-center">Subtotal</th>
                                            <th style="width: 10%"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="costsContainer">
                                        @if (Model.Input.CostDetails != null)
                                        {
                                            for (int i = 0; i < Model.Input.CostDetails.Count; i++)
                                            {
                                                <tr class="cost-row">
                                                    <input type="hidden" name="Input.CostDetails[@i].Id" value="@Model.Input.CostDetails[i].Id" />
                                                    <td class="pl-4">
                                                        <input name="Input.CostDetails[@i].Concept" class="form-control" value="@Model.Input.CostDetails[i].Concept" required />
                                                    </td>
                                                    <td>
                                                        <select name="Input.CostDetails[@i].Category" class="form-control custom-select" asp-items="@categoryList" asp-for="@Model.Input.CostDetails[i].Category">
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <input name="Input.CostDetails[@i].Quantity" class="form-control text-center txt-qty" type="number" step="0.01" value="@Model.Input.CostDetails[i].Quantity.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" min="0" onchange="calculateTotals()" required />
                                                    </td>
                                                    <td>
                                                        <input name="Input.CostDetails[@i].UnitPrice" class="form-control text-center txt-price" type="number" step="0.01" value="@Model.Input.CostDetails[i].UnitPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" min="0" onchange="calculateTotals()" required />
                                                    </td>
                                                    <td class="text-center font-weight-bold txt-subtotal py-3 text-dark">Bs @Model.Input.CostDetails[i].Subtotal.ToString("N2")</td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-circle btn-sm btn-outline-danger" onclick="removeRow(this)" data-toggle="tooltip" title="Quitar">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="bg-light">
                                            <td colspan="4" class="text-right font-weight-bold text-dark py-3">COSTO TOTAL ACTUALIZADO:</td>
                                            <td class="text-center font-weight-bold text-success h5 py-3 mb-0" id="totalDisplay">Bs 0.00</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            <input type="hidden" asp-for="Input.ActualCost" id="hiddenActualCost" />
                        </div>
                    </div>

                    <div class="row mb-5">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Input.SatisfactionLevel" class="control-label font-weight-bold small uppercase text-muted">Nivel de Satisfacción</label>
                                <select asp-for="Input.SatisfactionLevel" class="form-control custom-select"
                                        asp-items="Html.GetEnumSelectList<MaintenanceSatisfaction>()">
                                    <option value="">-- No evaluado --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Input.Recommendations" class="control-label font-weight-bold small uppercase text-muted">Recomendaciones Post-Servicio</label>
                                <textarea asp-for="Input.Recommendations" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Input.Observations" class="control-label font-weight-bold small uppercase text-muted">Observaciones Internas</label>
                                <textarea asp-for="Input.Observations" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right pb-4">
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded px-4 mr-2">Cancelar</a>
                        <button type="submit" class="btn btn-info btn-rounded px-5 shadow font-weight-bold text-white">
                            <i class="fas fa-sync-alt mr-1"></i> Actualizar Servicio
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<table style="display:none">
    <tbody id="costTemplate">
        <tr class="cost-row">
            <input type="hidden" name="Input.CostDetails[INDEX].Id" value="0" />
            <td class="pl-4">
                <input name="Input.CostDetails[INDEX].Concept" class="form-control" required placeholder="Nuevo ítem" />
            </td>
            <td>
                <select name="Input.CostDetails[INDEX].Category" class="form-control custom-select" asp-items="categoryList"></select>
            </td>
            <td>
                <input name="Input.CostDetails[INDEX].Quantity" class="form-control text-center txt-qty" type="number" step="0.01" value="1" min="0" onchange="calculateTotals()" required />
            </td>
            <td>
                <input name="Input.CostDetails[INDEX].UnitPrice" class="form-control text-center txt-price" type="number" step="0.01" value="0.00" min="0" onchange="calculateTotals()" required />
            </td>
            <td class="text-center font-weight-bold txt-subtotal py-3 text-dark">Bs 0.00</td>
            <td class="text-center">
                <button type="button" class="btn btn-circle btn-sm btn-outline-danger" onclick="removeRow(this)" data-toggle="tooltip" title="Quitar">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        </tr>
    </tbody>
</table>

@section Styles {
    <style>
        .border-3 {
            border-left-width: 4px !important;
        }

        .line-height-normal {
            line-height: 1.4;
        }

        .v-middle td {
            vertical-align: middle !important;
        }

        .cost-row input:focus, .cost-row select:focus {
            background-color: #fff;
            box-shadow: 0 0 0 0.2rem rgba(41,98,255,.1);
        }
    </style>
}

@section Scripts {
    <script src="~/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();

            // Calcular porcentajes al cargar la página (para mostrar valores guardados)
            calculatePercentage();

            calculateTotals();

            $('#statusSelector').on('change', function() { toggleCostWarning($(this).val()); });
            toggleCostWarning($('#statusSelector').val());

            setupBlocking('#Input_Concept', /^[a-zA-Z0-9\s\-\.\(\)]*$/, "Caracteres no permitidos");

            $('#Input_StartDate').on('change', function() {
                $('#Input_EndDate').attr('min', $(this).val());
            });
            if($('#Input_StartDate').val()) {
                 $('#Input_EndDate').attr('min', $('#Input_StartDate').val());
            }
        });

        // --- LÓGICA DE CHECKBOXES (PORCENTAJE L-48) ---
        function calculatePercentage() {
            const checkboxes = $('.maintenance-check');
            if (checkboxes.length === 0) return;

            const completedTasks = checkboxes.filter(':checked').length;
            const percentage = Math.round((completedTasks / checkboxes.length) * 100);

            $('#displayProgressText').text(percentage + '%');
            $('#visualProgressBar').css('width', percentage + '%').attr('aria-valuenow', percentage);
            $('#hiddenPercentageInput').val(percentage);
        }

        // --- LÓGICA DE COSTOS ---
        function addRow() {
            const container = $('#costsContainer');
            const template = $('#costTemplate').html();
            const index = container.children().length;

            const newRow = template.replace(/\[INDEX\]/g, `[${index}]`);
            container.append(newRow);

            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
        }

        function removeRow(btn) {
            $(btn).closest('tr').fadeOut(200, function() {
                $(this).remove();
                reindexRows();
                calculateTotals();
            });
        }

        function reindexRows() {
            $('#costsContainer tr').each(function(i) {
                $(this).find('input, select').each(function() {
                    const name = $(this).attr('name');
                    if (name) {
                        $(this).attr('name', name.replace(/\[\d+\]/, `[${i}]`));
                    }
                });
            });
        }

        function calculateTotals() {
            let totalGeneral = 0;
            $('#costsContainer tr').each(function() {
                const qty = parseFloat($(this).find('.txt-qty').val()) || 0;
                const price = parseFloat($(this).find('.txt-price').val()) || 0;
                const subtotal = qty * price;

                $(this).find('.txt-subtotal').text('Bs ' + subtotal.toLocaleString('es-BO', { minimumFractionDigits: 2 }));
                totalGeneral += subtotal;
            });

            $('#totalDisplay').text('Bs ' + totalGeneral.toLocaleString('es-BO', { minimumFractionDigits: 2 }));
            $('#hiddenActualCost').val(totalGeneral.toFixed(2));
            toggleCostWarning($('#statusSelector').val());
        }

        function toggleCostWarning(statusVal) {
            const isCompleted = statusVal == "2";
            const total = parseFloat($('#hiddenActualCost').val()) || 0;
            if (isCompleted && total <= 0) $('#costWarning').fadeIn();
            else $('#costWarning').fadeOut();
        }

        function setupBlocking($selector, pattern, errorMessage) {
            $('body').on('input', $selector, function() {
                var $field = $(this);
                if (!pattern.test($field.val())) $field.val($field.val().slice(0, -1));
            });
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
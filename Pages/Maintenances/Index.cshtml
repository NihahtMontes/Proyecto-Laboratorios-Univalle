@page
@model Proyecto_Laboratorios_Univalle.Pages.Maintenances.IndexModel
@using Proyecto_Laboratorios_Univalle.Models.Enums



<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <!-- ✅ Premium Tab Navigation -->
            <ul class="nav nav-tabs customtab px-4 pt-3" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active font-weight-bold uppercase small" data-toggle="tab" href="#mantenimientos" role="tab">
                        <i class="fas fa-tools mr-2"></i> Historial de Mantenimientos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link font-weight-bold uppercase small" data-toggle="tab" href="#tipos" role="tab">
                        <i class="fas fa-list-ul mr-2 text-muted"></i> Tipos de Mantenimiento
                    </a>
                </li>
            </ul>

            <div class="tab-content">
                <!-- ============================================================== -->
                <!-- TAB 1: MAINTENANCES (WITH SMART INDEX) -->
                <!-- ============================================================== -->
                <div class="tab-pane active" id="mantenimientos" role="tabpanel">
                    <div class="card-body">
                        <!-- Informative Header -->
                        <div class="d-md-flex align-items-center mb-4">
                            <div>
                                <h3 class="card-title text-dark font-weight-bold mt-2 ml-2">Registro Técnico de Mantenimiento</h3>
                                <h6 class="card-subtitle text-muted ml-2">Control centralizado de servicios preventivos y correctivos.</h6>
                            </div>
                            <div class="ml-auto mt-3">
                                <a asp-page="Create" class="btn bg-white border btn-rounded shadow-sm text-dark px-4 font-weight-bold">
                                    <i class="fas fa-plus-circle mr-1 text-info"></i> Nuevo Mantenimiento
                                </a>
                            </div>
                        </div>

                        <!-- 🔍 Smart Index Zone -->
                        <div class="bg-light p-3 mb-4 rounded border-left border-info shadow-sm">
                            <form method="get">
                                <div class="row align-items-end">
                                    <div class="col-md-5">
                                        <label class="small font-weight-bold text-muted uppercase">Búsqueda Técnica</label>
                                        <div class="input-group drop-shadow">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text bg-white border-right-0"><i class="fas fa-search text-muted"></i></span>
                                            </div>
                                            <input type="text" asp-for="SearchTerm" class="form-control border-left-0" placeholder="Equipo, Inventario o Técnico..." />
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small font-weight-bold text-muted uppercase">Filtrar por Estado</label>
                                        <select asp-for="StatusFilter" class="form-control custom-select" 
                                                asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<MaintenanceStatus>()">
                                            <option value="">-- Todos los Estados --</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 text-right">
                                        <button type="submit" class="btn btn-dark btn-rounded px-4 shadow-sm">
                                            <i class="fas fa-filter mr-1"></i> Filtrar
                                        </button>
                                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-1">
                                            <i class="fas fa-sync-alt"></i>
                                        </a>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover v-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-top-0">Equipamiento</th>
                                        <th class="border-top-0">Servicio / Tipo</th>
                                        <th class="border-top-0">Responsable</th>
                                        <th class="border-top-0 text-center">Fecha Ejecución</th>
                                        <th class="border-top-0 text-center">Situación</th>
                                        <th class="border-top-0 text-center">Opciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Maintenances == null || !Model.Maintenances.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center py-5 text-muted italic font-weight-bold">
                                                <i class="fas fa-calendar-times fa-3x mb-3 d-block opacity-2"></i>
                                                Sin registros encontrados para la búsqueda actual.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var item in Model.Maintenances)
                                        {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="m-r-10">
                                                        <span class="btn btn-circle btn-sm btn-light-info text-info"><i class="fas fa-tools"></i></span>
                                                    </div>
                                                    <div>
                                                        <h6 class="m-b-0 font-weight-bold text-dark">@item.EquipmentUnit?.Equipment?.Name</h6>
                                                        <span class="text-muted small">Inv: @item.EquipmentUnit?.InventoryNumber</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="text-dark">@item.MaintenanceType?.Name</div>
                                                <small class="text-muted d-block text-truncate" style="max-width: 150px;">
                                                    @(item.Description ?? "Sin descripción")
                                                </small>
                                            </td>
                                            <td>
                                                <div class="small font-weight-bold">@(item.Technician?.FullName ?? "-")</div>
                                                <small class="text-muted">Técnico Asignado</small>
                                            </td>
                                            <td class="text-center">
                                                <div class="small font-weight-bold">@(item.ScheduledDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                                                <small class="text-muted">Programado</small>
                                            </td>
                                            <td class="text-center">
                                                @{
                                                    var (statusClass, statusText) = item.Status switch {
                                                        MaintenanceStatus.Completed => ("badge-success", "COMPLETADO"),
                                                        MaintenanceStatus.InProgress => ("badge-warning", "EN EJECUCIÓN"),
                                                        MaintenanceStatus.Scheduled => ("badge-info", "PROGRAMADO"),
                                                        MaintenanceStatus.Cancelled => ("badge-danger", "CANCELADO"),
                                                        _ => ("badge-secondary", "DESCONOCIDO")
                                                    };
                                                }
                                                <span class="badge @statusClass px-3 py-1">@statusText</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group">
                                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning btn-rounded" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info btn-rounded mx-1" title="Detalles">
                                                        <i class="fas fa-search-plus"></i>
                                                    </a>
                                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger btn-rounded" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ============================================================== -->
                <!-- TAB 2: MAINTENANCE TYPES -->
                <!-- ============================================================== -->
                <div class="tab-pane" id="tipos" role="tabpanel">
                    <div class="card-body">
                        <div class="d-md-flex align-items-center mb-4">
                            <div>
                                <h3 class="card-title text-dark font-weight-bold mt-2 ml-2">Catálogo de Tipos de Servicio</h3>
                                <h6 class="card-subtitle text-muted ml-2">Parametrización de categorías de mantenimiento.</h6>
                            </div>
                            <div class="ml-auto mt-3">
                                <a href="/MaintenanceTypes/Create" class="btn bg-white border btn-rounded shadow-sm text-dark">
                                    <i class="fas fa-plus-circle mr-1 text-info"></i> Nueva Categoría
                                </a>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover v-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-top-0">Categoría</th>
                                        <th class="border-top-0">Descripción</th>
                                        <th class="border-top-0 text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.MaintenanceTypes != null)
                                    {
                                        foreach (var type in Model.MaintenanceTypes)
                                        {
                                        <tr>
                                            <td>
                                                <h6 class="mb-0 font-weight-bold text-dark"><i class="fas fa-caret-right mr-2 text-info"></i> @type.Name</h6>
                                            </td>
                                            <td>
                                                <span class="text-muted small">@(type.Description ?? "-")</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group">
                                                    <a href="/MaintenanceTypes/Edit?id=@type.Id" class="btn btn-sm btn-outline-warning btn-rounded" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a href="/MaintenanceTypes/Details?id=@type.Id" class="btn btn-sm btn-outline-info btn-rounded mx-1" title="Detalles">
                                                        <i class="fas fa-search-plus"></i>
                                                    </a>
                                                    <a href="/MaintenanceTypes/Delete?id=@type.Id" class="btn btn-sm btn-outline-danger btn-rounded" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .customtab .nav-link { border: none; color: #747d8c; padding: 15px 25px; transition: all 0.3s ease; }
        .customtab .nav-link.active { color: #2962ff; background: transparent; border-bottom: 3px solid #2962ff; }
        .v-middle td { vertical-align: middle !important; }
        .uppercase { text-transform: uppercase; letter-spacing: 0.5px; }
        .border-left-3 { border-left-width: 3px !important; }
        .btn-white { background: #fff; color: #67757c; border: 1px solid #e9ecef; }
        .btn-white:hover { background: #f8f9fa; }
    </style>
}

@section Scripts {
    <!-- SweetAlert2 Plugin -->
    <script src="~/assets/libs/sweetalert2/dist/sweetalert2.all.min.js"></script>
    
    <script>
        $(function () {
             $('[data-toggle="tooltip"]').tooltip();
        });
    </script>
}

@page
@using Proyecto_Laboratorios_Univalle.Models.Enums
@model Proyecto_Laboratorios_Univalle.Pages.Maintenances.CreateModel

@{
    var categoryList = Html.GetEnumSelectList<CostCategory>();
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header Premium -->
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Programar Nuevo Servicio</h4>
                        <h6 class="card-subtitle text-muted">Complete la información técnica, cronograma y proyección de costos para la unidad física.</h6>
                    </div>
                    <div class="ml-auto">
                        <span class="round round-lg bg-light-info text-info"><i class="fas fa-tools fa-lg"></i></span>
                    </div>
                </div>

                <form method="post" id="maintenanceForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4" role="alert"></div>

                    <!-- SECCIÓN 1: UBICACIÓN Y EQUIPO (Jerárquico) -->
                    <div class="bg-light p-4 rounded mb-4 border-left border-info border-3">
                        <h5 class="text-info font-weight-bold mb-3"><i class="fas fa-university mr-2"></i>Ubicación y Activo</h5>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.FacultyId" class="control-label font-weight-bold small uppercase text-muted">Facultad <span class="text-danger">*</span></label>
                                    <select asp-for="Input.FacultyId" class="form-control select2" id="facultySelect" asp-items="ViewBag.FacultyId" required>
                                        <option value="">-- Seleccionar Facultad --</option>
                                    </select>
                                    <span asp-validation-for="Input.FacultyId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.LaboratoryId" class="control-label font-weight-bold small uppercase text-muted">Laboratorio <span class="text-danger">*</span></label>
                                    <select asp-for="Input.LaboratoryId" class="form-control select2" id="laboratorySelect" disabled required>
                                        <option value="">-- Primero seleccione facultad --</option>
                                    </select>
                                    <span asp-validation-for="Input.LaboratoryId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.EquipmentUnitId" class="control-label font-weight-bold small uppercase text-muted">Unidad Física <span class="text-danger">*</span></label>
                                    <select asp-for="Input.EquipmentUnitId" class="form-control select2" id="equipmentUnitSelect" disabled required>
                                        <option value="">-- Seleccione laboratorio --</option>
                                    </select>
                                    <span asp-validation-for="Input.EquipmentUnitId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- SECCIÓN 2: DATOS DEL SERVICIO -->
                    <div class="p-3 mb-4">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.MaintenanceTypeId" class="control-label font-weight-bold small uppercase text-muted">Tipo de Servicio <span class="text-danger">*</span></label>
                                    <select asp-for="Input.MaintenanceTypeId" class="form-control custom-select" asp-items="ViewBag.MaintenanceTypeId" required>
                                        <option value="">-- Seleccionar Categoría --</option>
                                    </select>
                                    <span asp-validation-for="Input.MaintenanceTypeId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.TechnicianId" class="control-label font-weight-bold small uppercase text-muted">Técnico Responsable <span class="text-danger">*</span></label>
                                    <select asp-for="Input.TechnicianId" class="form-control select2" asp-items="ViewBag.TechnicianId" required>
                                        <option value="">-- Asignar Técnico --</option>
                                    </select>
                                    <span asp-validation-for="Input.TechnicianId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Input.RequestId" class="control-label font-weight-bold small uppercase text-muted">Solicitud Relacionada</label>
                                    <select asp-for="Input.RequestId" class="form-control custom-select" asp-items="ViewBag.RequestId">
                                        <option value="">-- Ninguna --</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- CRONOGRAMA -->
                        <div class="col-lg-7">
                            <h5 class="text-dark font-weight-bold mb-3"><i class="far fa-calendar-alt mr-2 text-warning"></i>Planificación Temporal</h5>
                            <div class="card border mb-4 shadow-none">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 border-right">
                                            <div class="form-group">
                                                <label asp-for="Input.ScheduledDate" class="control-label font-weight-bold small uppercase text-muted">Fecha Programada</label>
                                                <input asp-for="Input.ScheduledDate" class="form-control" type="date" />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label asp-for="Input.StartDate" class="control-label font-weight-bold small uppercase text-muted">Inicio Real</label>
                                                <input asp-for="Input.StartDate" class="form-control" type="datetime-local" />
                                            </div>
                                            <div class="form-group mb-0">
                                                <label asp-for="Input.EndDate" class="control-label font-weight-bold small uppercase text-muted">Finalización</label>
                                                <input asp-for="Input.EndDate" class="form-control" type="datetime-local" />
                                                <span asp-validation-for="Input.EndDate" class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ESTADO -->
                        <div class="col-lg-5">
                            <h5 class="text-dark font-weight-bold mb-3"><i class="fas fa-thermometer-half mr-2 text-danger"></i>Estado del Proceso</h5>
                            <div class="card bg-light border-0 mb-4 shadow-none">
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label asp-for="Input.Status" class="control-label font-weight-bold small uppercase text-muted">Situación Actual <span class="text-danger">*</span></label>
                                        <select asp-for="Input.Status" class="form-control custom-select border-warning font-weight-bold text-dark" 
                                                asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<MaintenanceStatus>()"
                                                id="statusSelector">
                                        </select>
                                    </div>
                                    
                                    <div id="costWarning" class="alert alert-warning border-0 rounded shadow-sm d-flex align-items-center" style="display:none">
                                        <i class="fas fa-exclamation-triangle fa-2x mr-3"></i>
                                        <div class="line-height-normal small">
                                            <strong>¡Atención!</strong><br />
                                            Para marcar como <u>Completado</u> debe registrar al menos un costo.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- DETALLES -->
                    <div class="form-group mb-4">
                        <label asp-for="Input.Description" class="control-label font-weight-bold text-dark">Descripción del Trabajo / Requerimiento</label>
                        <textarea asp-for="Input.Description" class="form-control rounded" rows="3" placeholder="Detalle técnico de la intervención..." required></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    </div>

                    <!-- COSTOS DINÁMICOS -->
                    <div class="card border border-light shadow-none mb-4">
                        <div class="card-header bg-white d-flex align-items-center border-bottom-0 pt-4 px-4">
                            <h5 class="text-dark font-weight-bold mb-0"><i class="fas fa-file-invoice-dollar mr-2 text-success"></i>Control de Costos y Repuestos</h5>
                            <button type="button" class="btn btn-sm btn-success btn-rounded shadow-sm ml-auto font-weight-bold px-3" onclick="addRow()">
                                <i class="fas fa-plus mr-1"></i> Agregar Ítem
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover v-middle mb-0" id="costsTable">
                                    <thead class="bg-light text-uppercase small font-weight-bold text-muted">
                                        <tr>
                                            <th class="pl-4" style="width: 30%">Concepto</th>
                                            <th style="width: 20%">Categoría</th>
                                            <th style="width: 10%" class="text-center">Cant.</th>
                                            <th style="width: 15%" class="text-center">Unitario (Bs)</th>
                                            <th style="width: 15%" class="text-center">Subtotal</th>
                                            <th style="width: 10%"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="costsContainer">
                                        @if (Model.Input.CostDetails != null)
                                        {
                                            for (int i = 0; i < Model.Input.CostDetails.Count; i++)
                                            {
                                                <tr class="cost-row">
                                                    <td class="pl-4">
                                                        <input asp-for="Input.CostDetails[i].Concept" class="form-control" required placeholder="Descripción" />
                                                    </td>
                                                    <td>
                                                        <select asp-for="Input.CostDetails[i].Category" class="form-control custom-select" asp-items="categoryList"></select>
                                                    </td>
                                                    <td>
                                                        <input asp-for="Input.CostDetails[i].Quantity" class="form-control text-center txt-qty" type="number" step="0.01" onchange="calculateTotals()" required />
                                                    </td>
                                                    <td>
                                                        <input asp-for="Input.CostDetails[i].UnitPrice" class="form-control text-center txt-price" type="number" step="0.01" onchange="calculateTotals()" required />
                                                    </td>
                                                    <td class="text-center font-weight-bold txt-subtotal py-3 text-dark">Bs @((Model.Input.CostDetails[i].Quantity * Model.Input.CostDetails[i].UnitPrice).ToString("N2"))</td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-circle btn-sm btn-outline-danger" onclick="removeRow(this)">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="bg-light">
                                            <td colspan="4" class="text-right font-weight-bold text-dark py-3">COSTO TOTAL ESTIMADO:</td>
                                            <td class="text-center font-weight-bold text-success h5 py-3 mb-0" id="totalDisplay">Bs 0.00</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            <input type="hidden" asp-for="Input.ActualCost" id="hiddenActualCost" />
                        </div>
                    </div>

                    <!-- NOTAS ADICIONALES -->
                    <div class="row mb-5">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Input.Recommendations" class="control-label font-weight-bold small uppercase text-muted">Recomendaciones Post-Servicio</label>
                                <textarea asp-for="Input.Recommendations" class="form-control" rows="2" placeholder="Sugerencias para el usuario del equipo..."></textarea>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Input.Observations" class="control-label font-weight-bold small uppercase text-muted">Observaciones Internas</label>
                                <textarea asp-for="Input.Observations" class="form-control" rows="2" placeholder="Notas para el equipo técnico..."></textarea>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right pb-4">
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded px-4 mr-2">Cancelar</a>
                        <button type="submit" class="btn btn-info btn-rounded px-5 shadow-sm font-weight-bold">
                            <i class="fas fa-save mr-2"></i> Guardar Programación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- TEMPLATE OCULTO PARA FILAS -->
<table style="display:none">
    <tbody id="costTemplate">
        <tr class="cost-row">
            <td class="pl-4">
                <input name="Input.CostDetails[INDEX].Concept" class="form-control" required placeholder="Descripción del ítem" />
            </td>
            <td>
                <select name="Input.CostDetails[INDEX].Category" class="form-control custom-select" asp-items="categoryList"></select>
            </td>
            <td>
                <input name="Input.CostDetails[INDEX].Quantity" class="form-control text-center txt-qty" type="number" step="0.01" value="1" min="0" onchange="calculateTotals()" required />
            </td>
            <td>
                <input name="Input.CostDetails[INDEX].UnitPrice" class="form-control text-center txt-price" type="number" step="0.01" value="0.00" min="0" onchange="calculateTotals()" required />
            </td>
            <td class="text-center font-weight-bold txt-subtotal py-3 text-dark">Bs 0.00</td>
            <td class="text-center">
                <button type="button" class="btn btn-circle btn-sm btn-outline-danger" onclick="removeRow(this)">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        </tr>
    </tbody>
</table>

@section Styles {
    <link href="~/assets/libs/select2/dist/css/select2.min.css" rel="stylesheet">
    <style>
        .border-3 { border-left-width: 4px !important; }
        .line-height-normal { line-height: 1.4; }
        .v-middle td { vertical-align: middle !important; }
    </style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/assets/libs/select2/dist/js/select2.full.min.js"></script>
    <script>
        $(function () {
            "use strict";

            $(".select2").select2({ width: '100%', allowClear: true });
            
            const container = $('#costsContainer');
            if (container.children().length === 0) addRow(); 

            $('#statusSelector').on('change', function() {
                toggleCostWarning($(this).val());
            });
            toggleCostWarning($('#statusSelector').val());

            // Cascading
            $('#facultySelect').on('change', function() {
                let id = $(this).val();
                let $lab = $('#laboratorySelect');
                let $unit = $('#equipmentUnitSelect');
                
                $lab.empty().append('<option value="">-- Cargando... --</option>').prop('disabled', true);
                $unit.empty().append('<option value="">-- Seleccione laboratorio --</option>').prop('disabled', true);
                
                if (!id) {
                    $lab.html('<option value="">-- Primero seleccione facultad --</option>');
                    return;
                }

                $.get('/Maintenances/Create?handler=LaboratoriesByFaculty', { facultyId: id }, function(data) {
                    let opts = '<option value="">-- Seleccionar Laboratorio --</option>';
                    $.each(data, function(i, item) { opts += `<option value="${item.id}">${item.name}</option>`; });
                    $lab.html(opts).prop('disabled', false).trigger('change');
                });
            });

            $('#laboratorySelect').on('change', function() {
                let id = $(this).val();
                let $unit = $('#equipmentUnitSelect');
                
                $unit.empty().append('<option value="">-- Cargando... --</option>').prop('disabled', true);
                
                if (!id) {
                    $unit.html('<option value="">-- Seleccione laboratorio --</option>');
                    return;
                }

                $.get('/Maintenances/Create?handler=UnitsByLab', { laboratoryId: id }, function(data) {
                    let opts = '<option value="">-- Seleccionar Unidad Física --</option>';
                    $.each(data, function(i, item) { opts += `<option value="${item.id}">${item.name}</option>`; });
                    $unit.html(opts).prop('disabled', false).trigger('change');
                });
            });

            calculateTotals();
        });

        function addRow() {
            const container = $('#costsContainer');
            const template = $('#costTemplate').html();
            const index = container.children().length;
            const newRow = template.replace(/\[INDEX\]/g, `[${index}]`); 
            container.append(newRow);
            calculateTotals();
        }

        function removeRow(btn) {
            $(btn).closest('tr').remove();
            reindexRows();
            calculateTotals();
        }

        function reindexRows() {
            $('#costsContainer tr').each(function(i) {
                $(this).find('input, select').each(function() {
                    const name = $(this).attr('name');
                    if (name) {
                        $(this).attr('name', name.replace(/\[\d+\]/, `[${i}]`));
                        $(this).attr('id', $(this).attr('id')?.replace(/_\d+__/, `_${i}__`));
                    }
                });
            });
        }

        function calculateTotals() {
            let totalGeneral = 0;
            $('#costsContainer tr').each(function() {
                const qty = parseFloat($(this).find('.txt-qty').val()) || 0;
                const price = parseFloat($(this).find('.txt-price').val()) || 0;
                const subtotal = qty * price;
                $(this).find('.txt-subtotal').text('Bs ' + subtotal.toLocaleString('es-BO', { minimumFractionDigits: 2 }));
                totalGeneral += subtotal;
            });
            $('#totalDisplay').text('Bs ' + totalGeneral.toLocaleString('es-BO', { minimumFractionDigits: 2 }));
            $('#hiddenActualCost').val(totalGeneral.toFixed(2));
            toggleCostWarning($('#statusSelector').val());
        }

        function toggleCostWarning(statusVal) {
            const isCompleted = statusVal == "2";
            const total = parseFloat($('#hiddenActualCost').val()) || 0;
            if (isCompleted && total <= 0) $('#costWarning').fadeIn();
            else $('#costWarning').fadeOut();
        }
    </script>
}

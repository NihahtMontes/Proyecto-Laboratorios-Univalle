@page
@using Proyecto_Laboratorios_Univalle.Models.Enums
@model Proyecto_Laboratorios_Univalle.Pages.Maintenances.CreateModel

@{
    ViewData["Title"] = "Programar Mantenimiento";
    var categoryList = Html.GetEnumSelectList<CostCategory>();
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header Premium -->
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Programar Nuevo Servicio</h4>
                        <h6 class="card-subtitle text-muted">Complete la información técnica, cronograma y proyección de costos.</h6>
                    </div>
                    <div class="ml-auto">
                        <span class="round round-lg bg-light-info text-info"><i class="fas fa-tools fa-lg"></i></span>
                    </div>
                </div>

                <form method="post" id="maintenanceForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4" role="alert"></div>

                    <!-- 🛠️ SECCIÓN 1: DATOS GENERALES (Panel Gris) -->
                    <div class="bg-light p-4 rounded mb-4 border-left border-info border-3">
                        <h5 class="text-info font-weight-bold mb-3"><i class="fas fa-microchip mr-2"></i>Contexto del Servicio</h5>
                        <div class="row">
                            <div class="col-md-5">
                                <div class="form-group mb-3">
                                    <label asp-for="Maintenance.EquipmentId" class="control-label font-weight-bold small uppercase text-muted">Equipo Objetivo <span class="text-danger">*</span></label>
                                    <select asp-for="Maintenance.EquipmentId" class="form-control custom-select" asp-items="ViewBag.EquipmentId" required 
                                            data-validation-required-message="Seleccione el equipo a intervenir">
                                        <option value="">-- Seleccione Equipo --</option>
                                    </select>
                                    <span asp-validation-for="Maintenance.EquipmentId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group mb-3">
                                    <label asp-for="Maintenance.MaintenanceTypeId" class="control-label font-weight-bold small uppercase text-muted">Tipo de Servicio <span class="text-danger">*</span></label>
                                    <select asp-for="Maintenance.MaintenanceTypeId" class="form-control custom-select" asp-items="ViewBag.MaintenanceTypeId" required
                                            data-validation-required-message="Requerido">
                                        <option value="">-- Categoría --</option>
                                    </select>
                                    <span asp-validation-for="Maintenance.MaintenanceTypeId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Maintenance.TechnicianId" class="control-label font-weight-bold small uppercase text-muted">Técnico Responsable</label>
                                    <select asp-for="Maintenance.TechnicianId" class="form-control custom-select" asp-items="ViewBag.TechnicianId">
                                        <option value="">-- Asignar Técnico --</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- 📅 SECCIÓN 2: CRONOGRAMA -->
                        <div class="col-lg-7">
                            <h5 class="text-dark font-weight-bold mb-3"><i class="far fa-calendar-alt mr-2 text-warning"></i>Planificación Temporal</h5>
                            <div class="card border mb-4">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 border-right">
                                            <div class="form-group">
                                                <label asp-for="Maintenance.ScheduledDate" class="control-label font-weight-bold small uppercase text-muted">Fecha Programada</label>
                                                <input asp-for="Maintenance.ScheduledDate" class="form-control" type="date" />
                                                <small class="text-muted italic">Referencia para alertas</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group mb-3">
                                                <label asp-for="Maintenance.StartDate" class="control-label font-weight-bold small uppercase text-muted">Inicio Real</label>
                                                <input asp-for="Maintenance.StartDate" class="form-control" type="datetime-local" />
                                            </div>
                                            <div class="form-group mb-0">
                                                <label asp-for="Maintenance.EndDate" class="control-label font-weight-bold small uppercase text-muted">Finalización</label>
                                                <input asp-for="Maintenance.EndDate" class="form-control" type="datetime-local" />
                                                <span asp-validation-for="Maintenance.EndDate" class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 🚦 SECCIÓN 3: ESTADO -->
                        <div class="col-lg-5">
                            <h5 class="text-dark font-weight-bold mb-3"><i class="fas fa-thermometer-half mr-2 text-danger"></i>Estado del Proceso</h5>
                            <div class="card bg-light border-0 mb-4">
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label asp-for="Maintenance.Status" class="control-label font-weight-bold small uppercase text-muted">Situación Actual <span class="text-danger">*</span></label>
                                        <select asp-for="Maintenance.Status" class="form-control custom-select border-warning font-weight-bold text-dark" 
                                                asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<MaintenanceStatus>()"
                                                id="statusSelector">
                                        </select>
                                    </div>
                                    
                                    <div id="costWarning" class="alert alert-warning border-0 rounded shadow-sm d-flex align-items-center" style="display:none">
                                        <i class="fas fa-exclamation-triangle fa-2x mr-3"></i>
                                        <div class="line-height-normal small">
                                            <strong>¡Atención!</strong><br />
                                            Para marcar como <u>Completado</u> debe registrar al menos un costo (mano de obra o repuesto).
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 📝 SECCIÓN 4: DETALLES -->
                    <div class="form-group mb-4">
                        <label asp-for="Maintenance.Description" class="control-label font-weight-bold text-dark">Descripción del Trabajo / Requerimiento</label>
                        <textarea asp-for="Maintenance.Description" class="form-control rounded" rows="3" placeholder="Detalle técnico de la intervención..." required data-validation-required-message="La descripción es obligatoria"></textarea>
                        <span asp-validation-for="Maintenance.Description" class="text-danger small"></span>
                    </div>

                    <!-- 💰 SECCIÓN 5: COSTOS DINÁMICOS -->
                    <div class="card border border-light shadow-none mb-4">
                        <div class="card-header bg-white d-flex align-items-center border-bottom-0 pt-4 px-4">
                            <h5 class="text-dark font-weight-bold mb-0"><i class="fas fa-file-invoice-dollar mr-2 text-success"></i>Control de Costos y Repuestos</h5>
                            <button type="button" class="btn btn-sm btn-success btn-rounded shadow-sm ml-auto font-weight-bold px-3" onclick="addRow()">
                                <i class="fas fa-plus mr-1"></i> Agregar Ítem
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover v-middle mb-0" id="costsTable">
                                    <thead class="bg-light text-uppercase small font-weight-bold text-muted">
                                        <tr>
                                            <th class="pl-4" style="width: 30%">Concepto</th>
                                            <th style="width: 20%">Categoría</th>
                                            <th style="width: 10%" class="text-center">Cant.</th>
                                            <th style="width: 15%" class="text-center">Unitario (Bs)</th>
                                            <th style="width: 15%" class="text-center">Subtotal</th>
                                            <th style="width: 10%"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="costsContainer">
                                        <!-- Filas inyectadas vía JS -->
                                    </tbody>
                                    <tfoot>
                                        <tr class="bg-light">
                                            <td colspan="4" class="text-right font-weight-bold text-dark py-3">COSTO TOTAL ESTIMADO:</td>
                                            <td class="text-center font-weight-bold text-success h5 py-3 mb-0" id="totalDisplay">Bs 0.00</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            <input type="hidden" asp-for="Maintenance.ActualCost" id="hiddenActualCost" />
                        </div>
                    </div>

                    <!-- 📋 SECCIÓN 6: NOTAS ADICIONALES -->
                    <div class="row mb-5">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Maintenance.Recommendations" class="control-label font-weight-bold small uppercase text-muted">Recomendaciones Post-Servicio</label>
                                <textarea asp-for="Maintenance.Recommendations" class="form-control" rows="2" placeholder="Sugerencias para el usuario del equipo..."></textarea>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Maintenance.Observations" class="control-label font-weight-bold small uppercase text-muted">Observaciones Internas</label>
                                <textarea asp-for="Maintenance.Observations" class="form-control" rows="2" placeholder="Notas para el equipo técnico..."></textarea>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right pb-4">
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded px-4 mr-2">Cancelar</a>
                        <button type="submit" class="btn btn-info btn-rounded px-5 shadow-sm font-weight-bold">
                            <i class="fas fa-save mr-2"></i> Guardar Programación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- 📦 TEMPLATE OCULTO PARA FILAS -->
<table style="display:none">
    <tbody id="costTemplate">
        <tr class="cost-row">
            <td class="pl-4">
                <input name="Maintenance.CostDetails[INDEX].Concept" class="form-control" required placeholder="Descripción del ítem" />
            </td>
            <td>
                <select name="Maintenance.CostDetails[INDEX].Category" class="form-control custom-select" asp-items="categoryList"></select>
            </td>
            <td>
                <input name="Maintenance.CostDetails[INDEX].Quantity" class="form-control text-center txt-qty" type="number" step="0.01" value="1" min="0" onchange="calculateTotals()" required />
            </td>
            <td>
                <input name="Maintenance.CostDetails[INDEX].UnitPrice" class="form-control text-center txt-price" type="number" step="0.01" value="0.00" min="0" onchange="calculateTotals()" required />
            </td>
            <td class="text-center font-weight-bold txt-subtotal py-3 text-dark">Bs 0.00</td>
            <td class="text-center">
                <button type="button" class="btn btn-circle btn-sm btn-outline-danger" onclick="removeRow(this)" data-toggle="tooltip" title="Quitar">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        </tr>
    </tbody>
</table>

@section Styles {
    <style>
        .border-3 { border-left-width: 4px !important; }
        .line-height-normal { line-height: 1.4; }
        .v-middle td { vertical-align: middle !important; }
        .cost-row input:focus, .cost-row select:focus { background-color: #fff; box-shadow: 0 0 0 0.2rem rgba(41,98,255,.1); }
    </style>
}

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            
            // 1. Inicialización de validación nativa de plantilla
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();

            // 2. Control de filas dinámicas
            const container = $('#costsContainer');
            if (container.children().length === 0) addRow(); // Fila inicial

            // 3. Monitor de Estado
            $('#statusSelector').on('change', function() {
                toggleCostWarning($(this).val());
            });
            toggleCostWarning($('#statusSelector').val()); // Al cargar

            // 5. Sincronización de Fechas (UX)
            $('#Maintenance_StartDate').on('change', function() {
                $('#Maintenance_EndDate').attr('min', $(this).val());
            });
            // Inicializar
            if($('#Maintenance_StartDate').val()) {
                 $('#Maintenance_EndDate').attr('min', $('#Maintenance_StartDate').val());
            }
        });

        // --- LÓGICA DE COSTOS ---
        function addRow() {
            const container = $('#costsContainer');
            const template = $('#costTemplate').html();
            const index = container.children().length;
            
            // Reemplazo seguro del índice
            const newRow = template.replace(/\[INDEX\]/g, `[${index}]`); 
            container.append(newRow);
            
            // Reactivar validación en nuevos elementos
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            calculateTotals();
        }

        function removeRow(btn) {
            $(btn).closest('tr').fadeOut(200, function() {
                $(this).remove();
                reindexRows();
                calculateTotals();
            });
        }

        function reindexRows() {
            $('#costsContainer tr').each(function(i) {
                $(this).find('input, select').each(function() {
                    const name = $(this).attr('name');
                    if (name) {
                        // Regex robusto para reemplazar [0], [1], etc. por [i]
                        $(this).attr('name', name.replace(/\[\d+\]/, `[${i}]`));
                    }
                });
            });
        }

        function calculateTotals() {
            let totalGeneral = 0;
            $('#costsContainer tr').each(function() {
                const qty = parseFloat($(this).find('.txt-qty').val()) || 0;
                const price = parseFloat($(this).find('.txt-price').val()) || 0;
                const subtotal = qty * price;
                
                $(this).find('.txt-subtotal').text('Bs ' + subtotal.toLocaleString('es-BO', { minimumFractionDigits: 2 }));
                totalGeneral += subtotal;
            });
            
            $('#totalDisplay').text('Bs ' + totalGeneral.toLocaleString('es-BO', { minimumFractionDigits: 2 }));
            $('#hiddenActualCost').val(totalGeneral.toFixed(2));
            
            // Actualizar validación de estado si cambian los costos
            toggleCostWarning($('#statusSelector').val());
        }

        function toggleCostWarning(statusVal) {
             // "2" es Completed en el enum
            const isCompleted = statusVal == "2";
            const total = parseFloat($('#hiddenActualCost').val()) || 0;
            
            if (isCompleted && total <= 0) {
                $('#costWarning').fadeIn();
            } else {
                $('#costWarning').fadeOut();
            }
        }

        // Helper para Bloqueo de Input (Validación Agresiva)
        function setupBlocking($selector, pattern, errorMessage) {
            $('body').on('input', $selector, function() {
                var $field = $(this);
                var val = $field.val();
                if (!pattern.test(val)) {
                    // Revertir último caracter
                    $field.val(val.slice(0, -1)); 
                    // Podríamos mostrar un tooltip temporal aquí
                }
            });
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

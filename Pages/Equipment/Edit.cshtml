@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Equipment.EditModel
@using Proyecto_Laboratorios_Univalle.Models.Enums
@{
    ViewData["Title"] = "Editar Definición de Equipo";
}

<div class="row">
    <!-- Main Column: Technical Record -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Editar Definición: @(Model.ExistingEquipmentDisplay?.Name ?? "Equipo")</h4>
                        <h6 class="card-subtitle text-muted">Actualice la ficha técnica general del catálogo.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-edit fa-2x text-warning"></i>
                    </div>
                </div>

                <form method="post" enctype="multipart/form-data" novalidate id="editForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" asp-for="Input.Id" />

                    <div class="row">
                        <!-- Identification & Origin -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-barcode mr-2"></i> Identificación y Clasificación</h5>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Input.Category" class="control-label font-weight-bold small uppercase text-muted">Tipo de Recurso <span class="text-danger">*</span></label>
                                <select asp-for="Input.Category" class="form-control custom-select" asp-items="Html.GetEnumSelectList<EquipmentCategory>()" id="categorySelect" required>
                                </select>
                                <span asp-validation-for="Input.Category" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3" id="typeContainer">
                                <label asp-for="Input.EquipmentTypeId" class="control-label font-weight-bold small uppercase text-muted">Categoría del Equipo <span class="text-danger">*</span></label>
                                <select asp-for="Input.EquipmentTypeId" class="form-control custom-select" asp-items="ViewBag.EquipmentTypeId">
                                    <option value="">-- Seleccione Categoría --</option>
                                </select>
                                <span asp-validation-for="Input.EquipmentTypeId" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.Name" class="control-label font-weight-bold small uppercase text-muted">Nombre del Activo <span class="text-danger">*</span></label>
                                <input asp-for="Input.Name" class="form-control" required placeholder="Ej: Espectrofotómetro" />
                                <span asp-validation-for="Input.Name" class="text-danger small"></span>
                            </div>

                            <div class="row mt-4 pt-2 border-top">
                                <div class="col-md-12">
                                    <h6 class="font-weight-bold text-muted small uppercase mb-3 text-info">Procedencia</h6>
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Input.CountryId" class="control-label font-weight-bold small uppercase text-muted">País de Origen</label>
                                    <select asp-for="Input.CountryId" class="form-control custom-select" asp-items="ViewBag.CountryId">
                                        <option value="">-- Seleccione País --</option>
                                    </select>
                                    <span asp-validation-for="Input.CountryId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Specifications -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-cogs mr-2"></i> Ficha Técnica</h5>
                            


                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="Input.Brand" class="control-label font-weight-bold small uppercase text-muted">Marca</label>
                                        <input asp-for="Input.Brand" class="form-control shadow-none" placeholder="Ej: Agilent" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="Input.Model" class="control-label font-weight-bold small uppercase text-muted">Modelo</label>
                                        <input asp-for="Input.Model" class="form-control shadow-none" placeholder="Ej: Model-X" />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.ImageUpload" class="control-label font-weight-bold small uppercase text-muted">Imagen de Referencia</label>
                                
                                @if (!string.IsNullOrEmpty(Model.Input.ExistingImageUrl))
                                {
                                    <div class="mb-2">
                                        <img src="~/uploads/equipment/@Model.Input.ExistingImageUrl" alt="Current Image" class="img-thumbnail" style="max-height: 100px;">
                                    </div>
                                }

                                <div class="custom-file">
                                    <input asp-for="Input.ImageUpload" type="file" class="custom-file-input" id="customFile" accept="image/*">
                                    <label class="custom-file-label" for="customFile">Cambiar imagen...</label>
                                </div>
                                <span asp-validation-for="Input.ImageUpload" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.UsefulLifeYears" class="control-label font-weight-bold small uppercase text-muted">Vida Útil Estimada (Años)</label>
                                <input asp-for="Input.UsefulLifeYears" class="form-control shadow-none" type="number" min="0" />
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.Description" class="control-label font-weight-bold small uppercase text-muted">Descripción / Especificaciones</label>
                                <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Especificaciones técnicas..."></textarea>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Side Panel -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-body p-4">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-info-circle mr-2 text-info"></i> Estado del Activo</h5>
                <hr class="border-secondary" />
                
                <div class="text-center py-3">
                    <div class="btn btn-circle btn-lg btn-info mb-3">
                        <i class="fas fa-microscope fa-lg"></i>
                    </div>
                    <h5 class="font-weight-bold text-white mb-1">@Model.Input.Name</h5>
                    <span class="badge badge-pill badge-info px-3 small font-weight-bold">Catálogo</span>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small uppercase font-weight-bold">Unidades Registradas:</span>
                    <span class="font-weight-bold text-info">@((Model.ExistingEquipmentDisplay?.Units?.Count ?? 0) + " Unidades")</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase"><i class="fas fa-history mr-2 text-warning"></i> Control de Auditoría</h5>
                <hr />
                <div class="small mt-3">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0">Fecha de Alta</label>
                        <span class="text-dark font-weight-bold d-block">@(Model.ExistingEquipmentDisplay?.CreatedDate.ToString("dd/MM/yyyy HH:mm"))</span>
                        <span class="text-muted">Por: @(Model.ExistingEquipmentDisplay?.CreatedBy?.Initials ?? "Sist.")</span>
                    </div>
                    @if (Model.ExistingEquipmentDisplay?.LastModifiedDate.HasValue == true)
                    {
                        <div class="mb-0 border-top pt-2">
                            <label class="text-muted d-block small uppercase mb-0">Última Gestión</label>
                            <span class="text-dark font-weight-bold d-block">@Model.ExistingEquipmentDisplay.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="text-muted">Por: @(Model.ExistingEquipmentDisplay.ModifiedBy?.Initials ?? "-")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
             // Custom file input label update
            $(".custom-file-input").on("change", function () {
                var fileName = $(this).val().split("\\").pop();
                $(this).siblings(".custom-file-label").addClass("selected").html(fileName);
            });

            // Toggle Equipment Type based on Category
            function toggleType() {
                var category = $('#categorySelect').val();
                // 0 is Equipment, 1 is Utensil
                if (category == '0') { 
                    $('#typeContainer').show();
                } else {
                    $('#typeContainer').hide();
                    $('#Input_EquipmentTypeId').val(''); 
                }
            }

            $('#categorySelect').change(toggleType);
            toggleType(); // Init
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

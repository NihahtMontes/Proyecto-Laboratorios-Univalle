@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Equipment.DetailsModel
@using Proyecto_Laboratorios_Univalle.Models.Enums
@{
    ViewData["Title"] = "Detalles del Equipo";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Expediente Técnico: @Model.Equipment.Name</h4>
                        <h6 class="card-subtitle text-muted">Información detallada de la definición del activo y su origen geográfico.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <span class="badge badge-pill badge-info px-4 py-2" style="font-size: 0.9rem;">
                            <i class="fas fa-cubes mr-2"></i> Definición de Catálogo
                        </span>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-6 border-right">
                        <h5 class="font-weight-bold text-info mb-3">
                            <i class="fas fa-microscope mr-2"></i> Especificaciones del Activo
                        </h5>
                        <table class="table table-sm table-borderless bg-light rounded p-3">
                            <tbody>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 pt-3" style="width: 40%;">Marca</th>
                                    <td class="font-weight-bold pt-3 text-dark">@(Model.Equipment.Brand ?? "N/A")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3">Modelo</th>
                                    <td class="font-weight-bold text-dark">@(Model.Equipment.Model ?? "N/A")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 pb-3">Categoría</th>
                                    <td class="font-weight-bold pb-3 text-dark">
                                        @Model.Equipment.Category
                                        @if (Model.Equipment.Category == EquipmentCategory.Utensil && Model.Equipment.UtensilType != UtensilType.NoAplica)
                                        {
                                            <span>(@Model.Equipment.UtensilType)</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="col-md-6">
                        <h5 class="font-weight-bold text-info mb-3">
                            <i class="fas fa-globe-americas mr-2"></i> Origen y Procedencia
                        </h5>
                        <table class="table table-sm table-borderless bg-light rounded p-3">
                            <tbody>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 pb-3">País</th>
                                    <td class="font-weight-bold pb-3 text-dark">@(Model.Equipment.Country?.Name ?? "No Definido")</td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="alert alert-soft-info py-2 px-3 small border-0 mt-3">
                            <i class="fas fa-info-circle mr-2"></i> La ubicación física (Laboratorio) se rastrea por cada unidad individual.
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                        <h5 class="font-weight-bold text-dark mb-0">
                            <i class="fas fa-boxes mr-2 text-warning"></i> Control de Unidades Físicas
                        </h5>
                        <div class="ml-auto">
                            <a asp-page="/EquipmentUnits/Create" asp-route-equipmentId="@Model.Equipment.Id" class="btn btn-sm btn-success btn-rounded px-3">
                                <i class="fas fa-plus mr-1"></i> Registrar Nueva Unidad
                            </a>
                        </div>
                    </div>

                    <div class="bg-light p-3 mb-4 rounded border-left border-info shadow-sm">
                        <form method="get">
                            <div class="row align-items-end">
                                <div class="col-md-7">
                                    <label class="small font-weight-bold text-muted uppercase">Búsqueda Rápida</label>
                                    <div class="input-group drop-shadow">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-white border-right-0"><i class="fas fa-search text-muted"></i></span>
                                        </div>
                                        <input type="text" asp-for="SearchTerm" class="form-control border-left-0" placeholder="Buscar por N° Inventario o Serie..." />
                                    </div>
                                </div>
                                <div class="col-md-5 text-right">
                                    <button type="submit" class="btn btn-dark btn-rounded px-4 shadow-sm font-weight-bold">
                                        <i class="fas fa-filter mr-1"></i> Filtrar Unidades
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                    @if (Model.Equipment.Units != null && Model.Equipment.Units.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover bg-white border shadow-sm rounded">
                                <thead class="bg-light text-muted uppercase small font-weight-bold">
                                    <tr>
                                        <th>Identificación</th>
                                        <th>Laboratorio / Facultad</th>
                                        <th>Estado Operativo</th>
                                        <th>Condición Física</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var unit in Model.Equipment.Units)
                                    {
                                        <tr>
                                            <td class="font-weight-bold text-dark v-middle">
                                                <i class="fas fa-barcode text-muted mr-2"></i>@unit.InventoryNumber
                                                <div class="small text-muted mt-1">S/N: @(unit.SerialNumber ?? "N/A")</div>
                                                @if (unit.Career != null)
                                                {
                                                    <div class="small text-info mt-1"><i class="fas fa-graduation-cap mr-1"></i>@unit.Career.Name</div>
                                                }
                                            </td>
                                            <td class="v-middle">
                                                <div class="font-weight-bold">@(unit.Laboratory?.Name ?? "No asignado")</div>
                                                <small class="text-muted">@(unit.Laboratory?.Faculty?.Name ?? "Sin facultad")</small>
                                            </td>
                                            <td class="v-middle">
                                                @{
                                                    var badgeClass = unit.CurrentStatus switch
                                                    {
                                                        EquipmentStatus.Operational => "badge-success",
                                                        EquipmentStatus.UnderMaintenance => "badge-warning",
                                                        EquipmentStatus.OutOfService => "badge-danger",
                                                        EquipmentStatus.Deleted => "badge-dark",
                                                        _ => "badge-secondary"
                                                    };
                                                }
                                                <span class="badge badge-pill @badgeClass px-3 py-1">@Html.DisplayFor(m => unit.CurrentStatus)</span>
                                            </td>
                                            <td class="v-middle">
                                                <span class="badge badge-pill badge-warning px-2 py-1 font-weight-bold shadow-none small text-white">@Html.DisplayFor(m => unit.PhysicalCondition)</span>
                                            </td>
                                            <td class="text-center v-middle">
                                                <div class="btn-group shadow-sm rounded">
                                                    <a asp-page="/EquipmentUnits/Edit" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-page="/EquipmentUnits/Details" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-info" title="Ver Historial">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <form method="post" asp-page-handler="DeleteUnit" asp-route-id="@unit.Id" class="d-inline" onsubmit="return confirm('¿Dar de baja esta unidad?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger ml-1" title="Eliminar">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 bg-light rounded border border-dashed">
                            <i class="fas fa-info-circle fa-2x text-muted mb-3 d-block opacity-5"></i>
                            <p class="text-muted mb-0 font-weight-bold text-dark">No se encontraron unidades registradas.</p>
                            <small class="text-muted">Haga clic en 'Registrar Nueva Unidad' para dar de alta un activo físico.</small>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Equipment.Description))
                {
                    <div class="alert alert-light border-0 mt-4 p-3 shadow-none small text-dark border-left border-info">
                        <label class="font-weight-bold uppercase mb-1 d-block text-info"><i class="fas fa-info-circle mr-2"></i> Descripción / Ficha Técnica:</label>
                        <div class="text-muted">@Model.Equipment.Description</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">

        @if (!string.IsNullOrEmpty(Model.Equipment.ImageUrl))
        {
            <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                <div class="card-body p-3 text-center">
                    <img src="~/uploads/equipment/@Model.Equipment.ImageUrl" alt="@Model.Equipment.Name" class="img-fluid rounded shadow-sm" style="max-height: 250px; object-fit: contain;" />
                </div>
            </div>
        }


        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase border-bottom pb-2">
                    <i class="fas fa-history mr-2 text-warning"></i> Control de Auditoría
                </h5>
                <div class="small">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0 font-weight-bold">Alta del Registro</label>
                        <span class="font-weight-bold text-dark d-block">@Model.Equipment.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                        <div class="text-muted pt-1"><i class="fas fa-user-circle mr-1"></i> @(Model.Equipment.CreatedBy?.FullName ?? "Sistema")</div>
                    </div>
                    @if (Model.Equipment.LastModifiedDate.HasValue)
                    {
                        <div class="mb-0 border-top pt-3 mt-3">
                            <label class="text-muted d-block small uppercase mb-0 font-weight-bold">Última Gestión</label>
                            <span class="font-weight-bold text-dark d-block">@Model.Equipment.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            <div class="text-muted pt-1"><i class="fas fa-user-edit mr-1"></i> @(Model.Equipment.ModifiedBy?.FullName ?? "-")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="form-actions mt-4">
            <a asp-page="./Edit" asp-route-id="@Model.Equipment.Id" class="btn btn-warning btn-block btn-rounded text-white shadow-sm font-weight-bold py-2 mb-2">
                <i class="fas fa-edit mr-1"></i> Modificar Ficha Técnica
            </a>
            <a asp-page="./Index" class="btn btn-outline-secondary btn-block btn-rounded py-2 mb-4 font-weight-bold">
                <i class="fas fa-list mr-1"></i> Volver al Catálogo
            </a>

            <a asp-page="./Delete" asp-route-id="@Model.Equipment.Id" class="btn btn-link btn-block text-danger small font-weight-bold mt-2">
                <i class="fas fa-trash-alt mr-1"></i> Eliminar Definición del Sistema
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .v-middle {
            vertical-align: middle !important;
        }

        .italic {
            font-style: italic;
        }

        .opacity-7 {
            opacity: 0.7;
        }

        .opacity-5 {
            opacity: 0.5;
        }

        .border-dashed {
            border-style: dashed !important;
        }

        .alert-soft-info {
            background-color: #e1f5fe;
            color: #01579b;
            border-left: 5px solid #03a9f4;
        }
    </style>
}
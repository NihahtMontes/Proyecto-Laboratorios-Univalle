@page
@model Proyecto_Laboratorios_Univalle.Pages.Equipment.DetailsModel

@{
    ViewData["Title"] = "Expediente del Equipo";
}

<div class="row">
    <!-- Columna Principal: Expediente Técnico -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark">Expediente Técnico: @Model.Equipment.Name</h4>
                        <h6 class="card-subtitle text-muted">Información detallada sobre el activo y su ciclo de vida operativo.</h6>
                    </div>
                    <div class="ml-auto">
                        @{
                            var statusBadge = Model.Equipment.CurrentStatus switch {
                                Proyecto_Laboratorios_Univalle.Models.Enums.EquipmentStatus.Operational => "badge-success",
                                Proyecto_Laboratorios_Univalle.Models.Enums.EquipmentStatus.UnderMaintenance => "badge-warning",
                                Proyecto_Laboratorios_Univalle.Models.Enums.EquipmentStatus.OutOfService => "badge-danger",
                                _ => "badge-secondary"
                            };
                        }
                        <span class="badge badge-pill @statusBadge px-4 py-2" style="font-size: 0.9rem;">
                            <i class="fas fa-check-circle mr-1"></i> @Model.Equipment.CurrentStatus
                        </span>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-6 border-right">
                        <h5 class="font-weight-bold text-info mb-3">
                            <i class="fas fa-microscope mr-2"></i> Especificaciones del Activo
                        </h5>
                        <table class="table table-sm table-borderless bg-light rounded p-3">
                            <tbody>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 pt-3" style="width: 40%;">N° Inventario</th>
                                    <td class="font-weight-bold pt-3 text-info">@Model.Equipment.InventoryNumber</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3">Marca / Modelo</th>
                                    <td class="font-weight-bold text-dark">@(Model.Equipment.Brand ?? "N/A") - @(Model.Equipment.Model ?? "N/A")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3">Número de Serie</th>
                                    <td class="text-dark">@(Model.Equipment.SerialNumber ?? "S/N")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 pb-3">Categoría</th>
                                    <td class="pb-3 text-dark">@Model.Equipment.EquipmentType.Name</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="col-md-6">
                        <h5 class="font-weight-bold text-info mb-3">
                            <i class="fas fa-map-marker-alt mr-2"></i> Ubicación Asignada
                        </h5>
                        <div class="p-3 bg-light rounded">
                            <div class="mb-3">
                                <label class="text-muted small uppercase d-block mb-0">Laboratorio / Sede</label>
                                <span class="font-weight-bold text-dark">@Model.Equipment.Laboratory.Name</span>
                                <div class="small text-muted">@Model.Equipment.Laboratory?.Faculty?.Name</div>
                            </div>
                            <div>
                                <label class="text-muted small uppercase d-block mb-0">Ubicación Administrativa</label>
                                <span class="text-dark">@Model.Equipment.City.Name, @Model.Equipment.Country.Name</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Historial de Disponibilidad -->
                <div class="mt-5">
                    <h5 class="font-weight-bold text-dark mb-3">
                        <i class="fas fa-history mr-2 text-warning"></i> Historial de Estados Recientes
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-hover v-middle border rounded">
                            <thead class="bg-light">
                                <tr class="small uppercase font-weight-bold text-muted">
                                    <th>Estatus Técnico</th>
                                    <th>Fecha Inicio</th>
                                    <th>Fecha Fin</th>
                                    <th>Duración</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Equipment.StateHistory?.Any() == true)
                                {
                                    @foreach (var history in Model.Equipment.StateHistory.OrderByDescending(h => h.StartDate).Take(5))
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge @(history.EndDate == null ? "badge-success" : "badge-light text-muted") px-3">
                                                    @history.Status
                                                </span>
                                            </td>
                                            <td class="small">@history.StartDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="small">@(history.EndDate?.ToString("dd/MM/yyyy HH:mm") ?? "En curso")</td>
                                            <td class="small">@(history.DurationDays.HasValue ? $"{history.DurationDays} d." : "-")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted italic p-4 small">No se registra historial de cambios.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Equipment.Observations))
                {
                    <div class="alert alert-info border-0 mt-4 bg-light-info text-info small">
                        <label class="font-weight-bold uppercase mb-1 d-block">Observaciones de Referencia</label>
                        <i class="fas fa-info-circle mr-2"></i> @Model.Equipment.Observations
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Columna Lateral: Lifecycle y Control -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4 bg-info text-white">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold"><i class="fas fa-chart-line mr-2"></i> Ciclo de Vida Útil</h5>
                <hr class="border-white opacity-2" />
                
                <div class="row">
                    <div class="col-6">
                        <small class="text-white-50 d-block uppercase font-weight-bold" style="font-size: 0.65rem;">Antigüedad</small>
                        <span class="font-weight-bold h5 mb-0">@(Model.Equipment.AgeYears?.ToString() ?? "0") años</span>
                    </div>
                    <div class="col-6 border-left border-white opacity-5">
                        <small class="text-white-50 d-block uppercase font-weight-bold" style="font-size: 0.65rem;">Vida Estimada</small>
                        <span class="font-weight-bold h5 mb-0">@(Model.Equipment.UsefulLifeYears?.ToString() ?? "0") años</span>
                    </div>
                </div>

                <div class="mt-4">
                    @{
                        var percent = 0;
                        if (Model.Equipment.UsefulLifeYears.HasValue && Model.Equipment.UsefulLifeYears > 0) {
                            percent = (int)(100 - ((double)(Model.Equipment.AgeYears ?? 0) / Model.Equipment.UsefulLifeYears * 100));
                            percent = Math.Max(0, Math.Min(100, percent));
                        }
                        var progressColor = percent < 20 ? "bg-danger" : (percent < 50 ? "bg-warning" : "bg-success");
                    }
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-white-50 uppercase font-weight-bold" style="font-size: 0.65rem;">Salud del Activo</small>
                        <span class="small font-weight-bold">@percent%</span>
                    </div>
                    <div class="progress" style="height: 5px; background: rgba(255,255,255,0.2);">
                        <div class="progress-bar @progressColor" role="progressbar" style="width: @percent%;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4"><i class="fas fa-user-shield mr-2 text-warning"></i> Trazabilidad</h5>
                <hr />
                <div class="small mt-3">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0">Registrado por</label>
                        <span class="font-weight-bold text-dark d-block">@(Model.Equipment.CreatedBy?.FullName ?? "Sistema")</span>
                        <span class="text-muted">@Model.Equipment.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    @if (Model.Equipment.LastModifiedDate.HasValue)
                    {
                        <div class="mb-0">
                            <label class="text-muted d-block small uppercase mb-0">Última Edición</label>
                            <span class="font-weight-bold text-dark d-block">@(Model.Equipment.ModifiedBy?.FullName ?? "-")</span>
                            <span class="text-muted">@Model.Equipment.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Botones de Acción -->
        <div class="form-actions mt-4">
            <a asp-page="./Edit" asp-route-id="@Model.Equipment.Id" class="btn btn-warning btn-block btn-rounded text-white shadow-sm font-weight-bold py-2 mb-2">
                <i class="fas fa-edit mr-1"></i> Editar Ficha Técnica
            </a>
            <a asp-page="./Index" class="btn btn-outline-secondary btn-block btn-rounded py-2 mb-4">
                <i class="fas fa-list mr-1"></i> Volver al Inventario
            </a>
            
            <a asp-page="./Delete" asp-route-id="@Model.Equipment.Id" class="btn btn-link btn-block text-danger small font-weight-bold">
                <i class="fas fa-trash-alt mr-1"></i> Solicitar baja definitiva del activo
            </a>
        </div>
    </div>
</div>

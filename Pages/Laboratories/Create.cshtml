@page
@model Proyecto_Laboratorios_Univalle.Pages.Laboratories.CreateModel

@{
    ViewData["Title"] = "Registrar Laboratorio";
}

<div class="row justify-content-center">
    <div class="col-lg-12 col-xl-11">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark">Nuevo Espacio de Laboratorio</h4>
                        <h6 class="card-subtitle text-muted">Defina la infraestructura técnica y ubicación académica.</h6>
                    </div>
                    <div class="ml-auto">
                        <i class="fas fa-flask fa-2x text-info opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row">
                        <!-- Columna 1: Identificación -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-id-card mr-2"></i> Identificación y Facultad
                            </h5>
                            
                            <div class="form-group mb-4">
                                <label asp-for="Input.FacultyId" class="control-label font-weight-bold small uppercase text-muted">
                                    Facultad Académica <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Input.FacultyId" class="form-control custom-select" asp-items="ViewBag.FacultyId"
                                        required data-validation-required-message="Debe seleccionar una facultad">
                                    <option value="">-- Seleccione una Facultad --</option>
                                </select>
                                <span asp-validation-for="Input.FacultyId" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-5">
                                    <div class="form-group mb-4 border-left border-warning pl-3 bg-light p-2">
                                        <label asp-for="Input.Code" class="control-label font-weight-bold small text-warning uppercase">
                                            Sigla / Código <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="Input.Code" class="form-control border-warning shadow-none" placeholder="Ej: LAB-INF-01" 
                                               required data-validation-required-message="Obligatorio" maxlength="20" />
                                        <span asp-validation-for="Input.Code" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="form-group mb-4">
                                        <label asp-for="Input.Name" class="control-label font-weight-bold small uppercase text-muted">
                                            Nombre del Laboratorio <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="Input.Name" class="form-control" placeholder="Ej: Lab. de Software" 
                                               required data-validation-required-message="Nombre obligatorio"
                                               pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ\d\s\.-]+$" />
                                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Type" class="control-label font-weight-bold small uppercase text-muted">
                                    Tipo / Especialidad
                                </label>
                                <input asp-for="Input.Type" class="form-control" placeholder="Ej: Investigación, Docencia, Cómputo..." />
                            </div>
                        </div>

                        <!-- Columna 2: Ubicación Técnica -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-map-marker-alt mr-2"></i> Ubicación y Capacidad
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label asp-for="Input.Building" class="control-label font-weight-bold small uppercase text-muted">
                                            Edificio / Bloque
                                        </label>
                                        <input asp-for="Input.Building" class="form-control" placeholder="Ej: Bloque B" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label asp-for="Input.Floor" class="control-label font-weight-bold small uppercase text-muted">
                                            Piso / Nivel
                                        </label>
                                        <input asp-for="Input.Floor" class="form-control" placeholder="Ej: 2do Piso" />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Description" class="control-label font-weight-bold small uppercase text-muted">
                                    Descripción del Ambiente
                                </label>
                                <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Detallas adicionales sobre el acceso, capacidad o equipamiento general..."></textarea>
                            </div>

                            <div class="alert alert-light-info border-0 small p-3 text-info">
                                <i class="fas fa-info-circle mr-1"></i> Al registrar el laboratorio, este quedará disponible para la asignación de inventario y creación de usuarios vinculados.
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-info btn-rounded px-5 shadow-sm font-weight-bold">
                            <i class="fas fa-flask mr-1"></i> Registrar Laboratorio
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary btn-rounded ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Función para mostrar mensajes de error temporales
            function showTemporaryError($el, message) {
                var $group = $el.closest('.form-group');
                var $help = $group.find('.help-block');
                if ($help.length === 0) {
                    $group.append('<div class="help-block text-danger small font-weight-bold mt-1"></div>');
                    $help = $group.find('.help-block');
                }
                $help.text(message).fadeIn();
                $group.addClass('error');
                
                setTimeout(function() {
                    $help.fadeOut(function() { $(this).text(''); });
                    $group.removeClass('error');
                }, 2000);
            }

            // Patrón: solo letras, números, espacios, guiones, puntos y paréntesis
            var textPattern = /^[a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-\.\(\)]*$/;
            
            function setupBlocking($selector, pattern, errorMessage) {
                $($selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-\.\(\)]/g, ''));
                        showTemporaryError($field, errorMessage);
                    }
                });
            }

            // Aplicar validación agresiva
            setupBlocking('#Input_Name', textPattern, "Carácter no permitido (especial)");
            setupBlocking('#Input_Code', textPattern, "Código: Solo letras, números y guiones");
            setupBlocking('#Input_Type', textPattern, "Tipo: Solo caracteres alfanuméricos");
            setupBlocking('#Input_Building', textPattern, "Edificio: Solo caracteres alfanuméricos");
            setupBlocking('#Input_Floor', textPattern, "Piso: Solo caracteres alfanuméricos");
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

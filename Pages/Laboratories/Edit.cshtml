@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Laboratories.EditModel
@using Proyecto_Laboratorios_Univalle.Models.Enums



<div class="row">
    <!-- Main Column: Infrastructure Management -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Gestión de Infraestructura</h4>
                        <h6 class="card-subtitle text-muted">Asegúrese de que la ubicación, el código y el estado operativo sean precisos según el registro físico.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-tools fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" asp-for="Input.Id" /> 

                    <div class="row">
                        <!-- Identification and Adscription -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-university mr-2"></i> Adscripción Académica</h5>
                            
                            <div class="form-group mb-4">
                                <label asp-for="Input.FacultyId" class="control-label font-weight-bold small uppercase text-muted">Facultad Responsable <span class="text-danger">*</span></label>
                                <select asp-for="Input.FacultyId" class="form-control custom-select" asp-items="ViewBag.FacultyId" required>
                                </select>
                                <span asp-validation-for="Input.FacultyId" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-4 border-left border-info pl-3 bg-light p-3 rounded shadow-none">
                                <label asp-for="Input.Code" class="control-label font-weight-bold small uppercase text-info mb-2 d-block">Código Identificador <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white"><i class="fas fa-hashtag text-muted"></i></span>
                                    </div>
                                    <input asp-for="Input.Code" class="form-control border-info shadow-none font-weight-bold" required maxlength="20" />
                                </div>
                                <span asp-validation-for="Input.Code" class="text-danger small font-weight-bold d-block mt-1"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Name" class="control-label font-weight-bold small uppercase text-muted">Denominación Oficial <span class="text-danger">*</span></label>
                                <input asp-for="Input.Name" class="form-control" required placeholder="Nombre descriptivo del laboratorio" />
                                <span asp-validation-for="Input.Name" class="text-danger small font-weight-bold"></span>
                            </div>
                        </div>

                        <!-- Localization and Profile -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-map-marker-alt mr-2"></i> Localización Física</h5>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label asp-for="Input.Building" class="control-label font-weight-bold small uppercase text-muted">Edificio / Bloque</label>
                                        <input asp-for="Input.Building" class="form-control" placeholder="Ej. Bloque Industrial" />
                                        <span asp-validation-for="Input.Building" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label asp-for="Input.Floor" class="control-label font-weight-bold small uppercase text-muted">Nivel / Piso</label>
                                        <input asp-for="Input.Floor" class="form-control" placeholder="Ej. Planta Baja" />
                                        <span asp-validation-for="Input.Floor" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Type" class="control-label font-weight-bold small uppercase text-muted">Especialidad Técnica</label>
                                <input asp-for="Input.Type" class="form-control" placeholder="Ej. Automatización / Biomedicina" />
                                <span asp-validation-for="Input.Type" class="text-danger small"></span>
                            </div>
                            
                            <div class="form-group mb-0">
                                <label asp-for="Input.Description" class="control-label font-weight-bold small uppercase text-muted">Notas de Ambiente</label>
                                <textarea asp-for="Input.Description" class="form-control" rows="2" placeholder="Información relevante sobre el acceso o manejo..."></textarea>
                                <span asp-validation-for="Input.Description" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4 bg-light p-3 rounded border-left border-warning mt-4 shadow-none">
                        <label asp-for="Input.Status" class="text-warning small uppercase font-weight-bold mb-2 d-block">Estatus Operativo <span class="text-danger">*</span></label>
                        <select asp-for="Input.Status" class="form-control border-warning font-weight-bold custom-select" 
                                asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<GeneralStatus>()"
                                required>
                        </select>
                        <small class="text-muted italic mt-2 d-block small"><i class="fas fa-info-circle mr-1"></i> Desactivar el laboratorio restringirá el registro de nuevos servicios de mantenimiento en este espacio físico.</small>
                    </div>

                    <hr />

                    <div class="form-actions mt-4 text-right">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Sidebar: Status and Control -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-info-circle mr-2 text-info"></i> Estado de Infraestructura</h5>
                <hr class="border-secondary" />
                
                <div class="text-center py-3">
                    <div class="btn btn-circle btn-lg btn-info mb-3 shadow">
                        <i class="fas fa-flask fa-lg"></i>
                    </div>
                    <h5 class="font-weight-bold text-white mb-1">@Model.Input.Name</h5>
                    <span class="badge badge-pill badge-warning px-3 small font-weight-bold">@(Model.Input.Status)</span>
                </div>

                <div class="mt-4 border-top border-secondary pt-3 small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted uppercase font-weight-bold" style="font-size: 0.6rem;">Código Sistema:</span>
                        <span class="font-weight-bold text-info">@Model.Input.Code</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted uppercase font-weight-bold" style="font-size: 0.6rem;">ID Único:</span>
                        <span class="text-white">#@Model.Input.Id</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase"><i class="fas fa-history mr-2 text-warning"></i> Control de Auditoría</h5>
                <hr />
                <div class="small mt-3">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0 font-weight-bold">Alta de Registro</label>
                        <span class="font-weight-bold text-dark d-block">@Model.ExistingLaboratory?.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                        <div class="text-muted small">Por: @(Model.ExistingLaboratory?.CreatedBy?.FullName ?? "Sistema")</div>
                    </div>
                    @if (Model.ExistingLaboratory?.LastModifiedDate.HasValue == true)
                    {
                        <div class="mb-0 border-top pt-2">
                            <label class="text-muted d-block small uppercase mb-0 font-weight-bold">Última Gestión</label>
                            <span class="font-weight-bold text-dark d-block">@(Model.ExistingLaboratory.ModifiedBy?.FullName ?? "-")</span>
                            <span class="text-muted small">@Model.ExistingLaboratory.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="alert alert-light border shadow-none small text-muted mt-4 italic border-left border-info border-3">
            <i class="fas fa-info-circle mr-1 text-info"></i> <strong>Nota:</strong> Los laboratorios son la unidad técnica base para la organización georeferenciada del inventario institucional.
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Advanced text pattern for Spanish alfanumeric fields
            var textPattern = /^[a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-\.\(\)]*$/;
            
            function setupBlocking(selector, pattern) {
                $(selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-\.\(\)]/g, ''));
                    }
                });
            }

            // Apply aggressive validation
            setupBlocking('#Input_Name', textPattern);
            setupBlocking('#Input_Code', textPattern);
            setupBlocking('#Input_Type', textPattern);
            setupBlocking('#Input_Building', textPattern);
            setupBlocking('#Input_Floor', textPattern);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 4px !important; }
    </style>
}

@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Laboratories.DetailsModel
@using Proyecto_Laboratorios_Univalle.Models.Enums



<div class="row">
    <!-- Main Column: Technical Record -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Hoja Técnica del Laboratorio</h4>
                        <h6 class="card-subtitle text-muted">Detalles de infraestructura, ubicación institucional y alcance operativo de: @Model.Laboratory.Name</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-flask fa-2x text-info opacity-5"></i>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-6 border-right">
                        <h5 class="font-weight-bold text-info mb-3">
                            <i class="fas fa-id-card-alt mr-2"></i> Identidad Operativa
                        </h5>
                        <table class="table table-sm table-borderless bg-light rounded p-2">
                            <tbody>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 font-weight-bold" style="width: 40%;">Código Interno:</th>
                                    <td class="font-weight-bold text-dark h5 mb-0">@Model.Laboratory.Code</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 font-weight-bold">Especialidad:</th>
                                    <td class="text-dark font-weight-bold">@(Model.Laboratory.Type ?? "General / Multidisciplinar")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 font-weight-bold">Adscripción:</th>
                                    <td class="text-dark font-weight-bold small uppercase">@(Model.Laboratory.Faculty?.Name ?? "Área General")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="col-md-6">
                        <h5 class="font-weight-bold text-info mb-3">
                            <i class="fas fa-map-marker-alt mr-2"></i> Localización Física
                        </h5>
                        <table class="table table-sm table-borderless bg-light rounded p-2">
                            <tbody>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 font-weight-bold" style="width: 40%;">Edificio/Bloque:</th>
                                    <td class="font-weight-bold text-dark">@(Model.Laboratory.Building ?? "No especificado")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 font-weight-bold">Nivel / Piso:</th>
                                    <td class="text-dark font-weight-bold">@(Model.Laboratory.Floor ?? "No especificado")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted small uppercase pl-3 font-weight-bold">Estatus Ficha:</th>
                                    <td class="font-weight-bold small">
                                        <span class="text-@(Model.Laboratory.Status == GeneralStatus.Activo ? "success" : "danger") font-weight-bold">@(Model.Laboratory.Status)</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4">
                    <h6 class="font-weight-bold text-dark small uppercase mb-2"><i class="fas fa-align-left mr-2 text-muted"></i> Descripción del Espacio</h6>
                    <p class="text-muted bg-light p-3 rounded italic border-left border-info border-3 mb-0">
                        @(Model.Laboratory.Description ?? "No se ha registrado una descripción detallada para este ambiente físico en la base de datos institucional.")
                    </p>
                </div>
                
                <div class="alert alert-light border-0 mt-4 p-3 shadow-none small text-info italic border-left border-info border-3">
                    <i class="fas fa-shield-alt mr-2"></i> <strong>Aviso:</strong> Este ambiente actúa como contenedor jerárquico para la gestión de activos, programas de mantenimiento prentivo y auditorías de inventario del departamento responsable.
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar: Audit and Control -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4 bg-dark text-white">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-shield-alt mr-2 text-info"></i> Seguridad de Infraestructura</h5>
                <hr class="border-secondary" />
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted uppercase font-weight-bold" style="font-size: 0.65rem;">Disponibilidad Sistema:</small>
                    <span class="badge badge-pill badge-@(Model.Laboratory.Status == GeneralStatus.Activo ? "success" : "danger") px-3 font-weight-bold">
                        @Model.Laboratory.Status
                    </span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase"><i class="fas fa-history mr-2 text-warning"></i> Auditoría de Gestión</h5>
                <hr />
                <div class="small mt-3">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0 font-weight-bold">Alta de Registro</label>
                        <span class="font-weight-bold text-dark d-block">@Model.Laboratory.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                        <div class="text-muted small">Por: @(Model.Laboratory.CreatedBy?.FullName ?? "Admin Principal")</div>
                    </div>
                    @if (Model.Laboratory.LastModifiedDate.HasValue)
                    {
                        <div class="mb-0 border-top pt-2">
                            <label class="text-muted d-block small uppercase mb-0 font-weight-bold">Última Gestión</label>
                            <span class="font-weight-bold text-dark d-block">@(Model.Laboratory.ModifiedBy?.FullName ?? "-")</span>
                            <span class="text-muted small">@Model.Laboratory.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="form-actions mt-4">
            <a asp-page="./Edit" asp-route-id="@Model.Laboratory.Id" class="btn btn-warning btn-block btn-rounded text-white shadow-sm font-weight-bold py-2 mb-2">
                <i class="fas fa-edit mr-1"></i> Modificar Ficha
            </a>
            <a asp-page="./Index" class="btn btn-outline-secondary btn-block btn-rounded py-2 mb-4 font-weight-bold">
                <i class="fas fa-list mr-1"></i> Volver al Listado
            </a>
            
            <a asp-page="./Delete" asp-route-id="@Model.Laboratory.Id" class="btn btn-link btn-block text-danger small font-weight-bold mt-2">
                <i class="fas fa-trash-alt mr-1"></i> Dar de Baja Infraestructura
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 4px !important; }
    </style>
}

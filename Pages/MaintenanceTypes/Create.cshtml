@page
@model Proyecto_Laboratorios_Univalle.Pages.MaintenanceTypes.CreateModel



<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Nuevo Tipo de Mantenimiento</h4>
                        <h6 class="card-subtitle text-muted">Defina una nueva categor챠a para organizar los servicios t챕cnicos y preventivos.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-tools fa-2x text-primary opacity-5"></i>
                    </div>
                </div>

                <form method="post" class="mt-4" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="Input.Name" class="font-weight-bold text-muted small uppercase mb-1">Nombre de la Categor챠a <span class="text-danger">*</span></label>
                        <input asp-for="Input.Name" class="form-control form-control-lg border-primary shadow-none" placeholder="Ej: Preventivo, Correctivo, Calibraci처n..." required />
                        <span asp-validation-for="Input.Name" class="text-danger small font-weight-bold"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Description" class="font-weight-bold text-muted small uppercase mb-1">Descripci처n del Servicio</label>
                        <textarea asp-for="Input.Description" class="form-control shadow-none" rows="4" placeholder="Describa brevemente el alcance de este tipo de mantenimiento..."></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-light border-0 small p-3 italic text-primary shadow-none">
                        <i class="fas fa-info-circle mr-1"></i> Una correcta categorizaci처n permite generar reportes t챕cnicos precisos y planificar mejor el ciclo de vida del inventario.
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-primary btn-rounded px-5 shadow-sm font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Crear Categor챠a
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Advanced text pattern for Spanish alfanumeric fields
            var alphanumericPattern = /^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣챰횗\s\-\.\(\)]*$/;
            
            function setupBlocking(selector, pattern) {
                $(selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-Z0-9찼챕챠처첬횁횋횒횙횣챰횗\s\-\.\(\)]/g, ''));
                    }
                });
            }

            // Apply aggressive validation
            setupBlocking('#Input_Name', alphanumericPattern);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
    </style>
}

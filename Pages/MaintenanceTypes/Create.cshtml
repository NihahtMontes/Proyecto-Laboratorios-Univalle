@page
@model Proyecto_Laboratorios_Univalle.Pages.MaintenanceTypes.CreateModel

@{
    ViewData["Title"] = "Nuevo Tipo de Mantenimiento";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <!-- Header Estándar -->
                <div class="d-md-flex align-items-center mb-4">
                    <div>
                        <h2 class="mt-3 ml-3 text-dark">Nuevo Tipo</h2>
                        <h6 class="card-subtitle ml-3 text-muted">Defina una nueva categoría para organizar los servicios técnicos.</h6>
                    </div>
                    <div class="ml-auto mt-3">
                        <a href="/Maintenances/Index#tipos" class="btn btn-outline-secondary btn-rounded">
                            <i class="fas fa-arrow-left mr-1"></i> Volver
                        </a>
                    </div>
                </div>

                <form method="post" class="mt-4 px-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="Input.Name" class="font-weight-bold text-muted small uppercase mb-1">Nombre de la Categoría</label>
                        <input asp-for="Input.Name" class="form-control rounded-pill shadow-sm" placeholder="Ej: Preventivo, Correctivo, Calibración..." required />
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Description" class="font-weight-bold text-muted small uppercase mb-1">Descripción del Tipo</label>
                        <textarea asp-for="Input.Description" class="form-control rounded-lg shadow-sm" rows="4" placeholder="Describa brevemente qué incluye este tipo de mantenimiento..."></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    </div>

                    <div class="text-right pt-3">
                        <a href="/Maintenances/Index#tipos" class="btn btn-secondary btn-rounded px-4 mr-2">Cancelar</a>
                        <button type="submit" class="btn btn-primary btn-rounded px-5 shadow">
                            <i class="fas fa-save mr-2"></i> Crear Tipo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

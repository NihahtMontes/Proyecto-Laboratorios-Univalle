@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.MaintenanceTypes.EditModel



<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Actualizar Categoría Técnica</h4>
                        <h6 class="card-subtitle text-muted">Ajuste la definición y el alcance de la categoría de mantenimiento.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-edit fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" class="mt-4" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" asp-for="MaintenanceType.Id" />
                    
                    <div class="form-group mb-4">
                        <label asp-for="MaintenanceType.Name" class="font-weight-bold text-muted small uppercase mb-1 text-dark">Nombre de la Categoría <span class="text-danger">*</span></label>
                        <input asp-for="MaintenanceType.Name" class="form-control form-control-lg border-warning shadow-none" required />
                        <span asp-validation-for="MaintenanceType.Name" class="text-danger small font-weight-bold"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="MaintenanceType.Description" class="font-weight-bold text-muted small uppercase mb-1 text-dark">Descripción del Servicio</label>
                        <textarea asp-for="MaintenanceType.Description" class="form-control shadow-none" rows="4"></textarea>
                        <span asp-validation-for="MaintenanceType.Description" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-light border-0 small p-3 italic text-warning shadow-none border-left border-warning border-3">
                        <i class="fas fa-exclamation-circle mr-1"></i> Tenga en cuenta que los cambios en el nombre se reflejarán en todos los registros históricos de mantenimiento asociados a esta categoría.
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Advanced text pattern for Spanish alfanumeric fields
            var textPattern = /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-\.\(\)]*$/;
            
            function setupBlocking($selector, pattern) {
                $($selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-\.\(\)]/g, ''));
                    }
                });
            }

            // Apply aggressive validation
            setupBlocking('#MaintenanceType_Name', textPattern);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 4px !important; }
    </style>
}

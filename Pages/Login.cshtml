@page
@model Proyecto_Laboratorios_Univalle.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Ingreso al Sistema | Proyecto Laboratorios";
}

<!DOCTYPE html>
<html lang="es" dir="ltr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Acceso al sistema de gestión de laboratorios Univalle.">

    <title>@ViewData["Title"]</title>

    <!-- CSS y Favicon -->
    <link rel="icon" type="image/png" sizes="16x16" href="~/assets/images/favicon.png">
    <link href="~/dist/css/style.min.css" rel="stylesheet">

    <style>
        /* 1. Ensure background covers the whole screen */
        .auth-wrapper {
            background-image: url('~/assets/images/background/login-register.jpg');
            background-repeat: no-repeat;
            background-position: center center;
            background-size: cover;
            min-height: 100vh;
            position: relative;
            width: 100%;
        }

        /* 2. Style for right sidebar login box */
        .auth-box.on-sidebar {
            position: absolute !important;
            right: 0 !important;
            top: 0 !important;
            height: 100vh !important;
            max-width: 450px !important;
            width: 100% !important;
            background: #ffffff !important;
            display: flex;
            align-items: center;
            padding: 40px;
            box-shadow: -5px 0 20px rgba(0,0,0,0.1);
            margin: 0 !important;
        }
    </style>
</head>

<body>
    <div class="main-wrapper">
        <!-- Preloader -->
        <div class="preloader">
            <div class="lds-ripple"><div class="lds-pos"></div><div class="lds-pos"></div></div>
        </div>

        <!-- Main Container -->
        <div class="auth-wrapper">
            <div class="auth-box on-sidebar">

                <!-- Login Form -->
                <div id="loginform" style="width: 100%;">
                    <div class="logo text-center">
                        <span class="db"><img src="~/assets/images/logo-icon.png" alt="logo" /></span>
                        <h4 class="font-weight-bold text-dark mt-3 uppercase" style="letter-spacing: 2px;">Laboratorios</h4>
                        <h5 class="text-muted m-b-20">Portal de Gestión Administrativa</h5>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <form class="form-horizontal m-t-20" id="login-form" method="post">

                                <!-- Validation Summary -->
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                                <!-- Username Input -->
                                <div class="form-group mb-4">
                                    <label asp-for="Input.UserName" class="small font-weight-bold text-muted uppercase">Usuario o Correo</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-transparent border-right-0"><i class="ti-user"></i></span>
                                        </div>
                                        <input asp-for="Input.UserName" class="form-control form-control-lg border-left-0" placeholder="Ej: jperez" required autofocus>
                                    </div>
                                    <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                                </div>

                                <!-- Password Input -->
                                <div class="form-group mb-4">
                                    <label asp-for="Input.Password" class="small font-weight-bold text-muted uppercase">Contraseña</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-transparent border-right-0"><i class="ti-lock"></i></span>
                                        </div>
                                        <input asp-for="Input.Password" type="password" class="form-control form-control-lg border-left-0" placeholder="********" required>
                                    </div>
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <!-- Remember Me Checkbox -->
                                <div class="form-group row mb-4">
                                    <div class="col-md-12">
                                        <div class="custom-control custom-checkbox">
                                            <input asp-for="Input.RememberMe" type="checkbox" class="custom-control-input" id="customCheck1">
                                            <label class="custom-control-label font-medium" for="customCheck1">Recordarme en este equipo</label>
                                        </div>
                                    </div>
                                </div>

                                <!-- Login Button -->
                                <div class="form-group text-center">
                                    <div class="col-xs-12 p-b-20">
                                        <button class="btn btn-block btn-lg btn-info btn-rounded shadow-sm font-weight-bold px-4" type="submit">
                                            INICIAR SESIÓN
                                        </button>
                                    </div>
                                </div>

                                <div class="mt-4 text-center">
                                    <small class="text-muted">© @DateTime.Now.Year Universidad del Valle - Sistema de Laboratorios</small>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="~/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>

    <script>
        $(function() {
            "use strict";
            $(".preloader").fadeOut();
        });
    </script>
</body>
</html>

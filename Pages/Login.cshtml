@page
@model Proyecto_Laboratorios_Univalle.Pages.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión - Laboratorios Univalle";
    Layout = null;
}

<!DOCTYPE html>
<html dir="ltr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>@ViewData["Title"]</title>

    <!-- CSS y Favicon -->
    <link rel="icon" type="image/png" sizes="16x16" href="~/lib/nice-admin/assets/images/favicon.png">
    <link href="~/lib/nice-admin/dist/css/style.min.css" rel="stylesheet">

    <style>
        /* 1. Aseguramos que el fondo cubra TODA la pantalla sin espacios blancos */
        .auth-wrapper {
            background-image: url('/lib/nice-admin/assets/images/background/login-register.jpg');
            background-repeat: no-repeat;
            background-position: center center;
            background-size: cover;
            min-height: 100vh;
            position: relative;
            width: 100%;
        }

        /* 2. FORZAMOS el estilo de barra lateral derecha (sidebar) */
        .auth-box.on-sidebar {
            position: absolute !important;
            right: 0 !important;
            top: 0 !important;
            height: 100vh !important; /* Altura completa */
            max-width: 450px !important;
            width: 100% !important;
            background: #ffffff !important; /* Fondo blanco sólido, no transparente */
            display: flex;
            align-items: center; /* Centrar contenido verticalmente */
            padding: 40px;
            box-shadow: -5px 0 20px rgba(0,0,0,0.1); /* Sombra para separar del fondo */
            margin: 0 !important; /* Quitar margenes que lo centran */
        }

   
    </style>
</head>

<body>
    <div class="main-wrapper">
        <!-- Preloader -->
        <div class="preloader">
            <div class="lds-ripple"><div class="lds-pos"></div><div class="lds-pos"></div></div>
        </div>

        <!-- Contenedor Principal -->
        <div class="auth-wrapper">
            <div class="auth-box on-sidebar">

                <!-- Único Formulario: LOGIN -->
                <div id="loginform" style="width: 100%;">
                    <div class="logo text-center">
                        <span class="db"><img src="~/lib/nice-admin/assets/images/logo-icon.png" alt="logo" /></span>
                        <h5 class="font-medium m-b-20 mt-3">Portal Administrativo</h5>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <form class="form-horizontal m-t-20" id="loginform" method="post">

                                <!-- Mensajes de Error -->
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                                <!-- Input Usuario -->
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-transparent border-right-0"><i class="ti-user"></i></span>
                                    </div>
                                    <input asp-for="Input.UserName" class="form-control form-control-lg border-left-0" placeholder="Usuario o Email" required>
                                </div>

                                <!-- Input Contraseña -->
                                <div class="input-group mb-3">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-transparent border-right-0"><i class="ti-lock"></i></span>
                                    </div>
                                    <input asp-for="Input.Password" type="password" class="form-control form-control-lg border-left-0" placeholder="Contraseña" required>
                                </div>

                                <!-- Checkbox Recordarme -->
                                <div class="form-group row">
                                    <div class="col-md-12">
                                        <div class="custom-control custom-checkbox">
                                            <input asp-for="Input.RememberMe" type="checkbox" class="custom-control-input" id="customCheck1">
                                            <label class="custom-control-label" for="customCheck1">Recordarme en este equipo</label>
                                        </div>
                                    </div>
                                </div>

                                <!-- Botón Ingresar -->
                                <div class="form-group text-center">
                                    <div class="col-xs-12 p-b-20">
                                        <button class="btn btn-block btn-lg btn-info" type="submit">INGRESAR</button>
                                    </div>
                                </div>

                                

                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Scripts Básicos -->
    <script src="~/lib/nice-admin/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/nice-admin/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>

    <script>
        // Ocultar preloader al cargar
        $(".preloader").fadeOut();
    </script>
</body>
</html>
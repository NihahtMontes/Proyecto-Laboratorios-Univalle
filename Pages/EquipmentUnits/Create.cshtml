@page
@model Proyecto_Laboratorios_Univalle.Pages.EquipmentUnits.CreateModel
@using Proyecto_Laboratorios_Univalle.Models.Enums
@{
    ViewData["Title"] = "Alta de Unidad Física";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Registrar Nueva Unidad Física</h4>
                        <h6 class="card-subtitle text-muted">Defina la ubicación individual y datos específicos de esta instancia física.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-microscope fa-2x text-primary"></i>
                    </div>
                </div>

                <form method="post" class="needs-validation" novalidate id="unitForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row">
                        <!-- Left Column: Reference and Identification -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-primary mb-3"><i class="fas fa-tag mr-2"></i> Identificación del Activo</h5>
                            
                            <div class="form-group mb-4">
                                <label asp-for="Input.EquipmentId" class="control-label font-weight-bold small uppercase text-muted">Modelo de Equipo (Catálogo)</label>
                                <input type="hidden" asp-for="Input.EquipmentId" />
                                <select disabled asp-for="Input.EquipmentId" class="form-control custom-select" asp-items="ViewBag.EquipmentId">
                                </select>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.InventoryNumber" class="control-label font-weight-bold small uppercase text-muted">N° Inventario <span class="text-danger">*</span></label>
                                    <input asp-for="Input.InventoryNumber" class="form-control font-weight-bold" placeholder="Ej: UV-001" required />
                                    <span asp-validation-for="Input.InventoryNumber" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.SerialNumber" class="control-label font-weight-bold small uppercase text-muted">Número de Serie</label>
                                    <input asp-for="Input.SerialNumber" class="form-control" placeholder="S/N del fabricante" />
                                    <span asp-validation-for="Input.SerialNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.CareerId" class="control-label font-weight-bold small uppercase text-muted">Carrera / Programa <span class="text-danger">*</span></label>
                                <select asp-for="Input.CareerId" class="form-control select2" asp-items="ViewBag.CareerId" required>
                                    <option value="">-- Seleccione Carrera --</option>
                                </select>
                                <span asp-validation-for="Input.CareerId" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.AcquisitionDate" class="control-label font-weight-bold small uppercase text-muted">Fecha Adquisición</label>
                                    <input asp-for="Input.AcquisitionDate" class="form-control" type="date" />
                                    <span asp-validation-for="Input.AcquisitionDate" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.ManufacturingDate" class="control-label font-weight-bold small uppercase text-muted">Fecha Fabricación</label>
                                    <input asp-for="Input.ManufacturingDate" class="form-control" type="date" />
                                    <span asp-validation-for="Input.ManufacturingDate" class="text-danger small"></span>
                                </div>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Input.AcquisitionValue" class="control-label font-weight-bold small uppercase text-muted">Precio de Adquisición (Bs.)</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text">Bs.</span>
                                    </div>
                                    <input asp-for="Input.AcquisitionValue" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Input.AcquisitionValue" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Right Column: Specific Location and Condition -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-primary mb-3"><i class="fas fa-map-marker-alt mr-2"></i> Ubicación Destino</h5>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Input.FacultyId" class="control-label font-weight-bold small uppercase text-muted">Facultad <span class="text-danger">*</span></label>
                                <select asp-for="Input.FacultyId" class="form-control select2" id="facultySelect" asp-items="ViewBag.FacultyId" required>
                                    <option value="">-- Seleccionar Facultad --</option>
                                </select>
                                <span asp-validation-for="Input.FacultyId" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.LaboratoryId" class="control-label font-weight-bold small uppercase text-muted">Laboratorio Destino <span class="text-danger">*</span></label>
                                <select asp-for="Input.LaboratoryId" class="form-control select2" id="laboratorySelect" 
                                        asp-items="ViewBag.LaboratoryId"
                                        disabled="@(Model.Input.FacultyId == null)" required>
                                    @if (Model.Input.FacultyId == null)
                                    {
                                        <option value="">-- Primero seleccione facultad --</option>
                                    }
                                    else
                                    {
                                        <option value="">-- Seleccionar Laboratorio --</option>
                                    }
                                </select>
                                <span asp-validation-for="Input.LaboratoryId" class="text-danger small"></span>
                            </div>

                            <h5 class="font-weight-bold text-primary mt-4 mb-3"><i class="fas fa-heartbeat mr-2"></i> Estado y Condición</h5>
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label asp-for="Input.CurrentStatus" class="control-label font-weight-bold small uppercase text-muted">Estado Operativo</label>
                                    <select asp-for="Input.CurrentStatus" class="form-control custom-select" asp-items="Html.GetEnumSelectList<EquipmentStatus>()"></select>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label asp-for="Input.PhysicalCondition" class="control-label font-weight-bold small uppercase text-muted">Condición Física</label>
                                    <select asp-for="Input.PhysicalCondition" class="form-control custom-select" asp-items="Html.GetEnumSelectList<PhysicalCondition>()"></select>
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.Notes" class="control-label font-weight-bold small uppercase text-muted">Observaciones Específicas</label>
                                <textarea asp-for="Input.Notes" class="form-control" rows="3" placeholder="Detalle accesorios, estado físico o requerimientos para esta unidad..."></textarea>
                                <span asp-validation-for="Input.Notes" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions mt-4 border-top pt-4 text-right">
                        <button type="submit" class="btn btn-primary px-5 py-2 font-weight-bold shadow-sm btn-rounded font-18">
                            <i class="fas fa-save mr-2"></i> Registrar Unidad Física
                        </button>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-2 ml-2 font-weight-bold btn-rounded">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/assets/libs/select2/dist/css/select2.min.css" rel="stylesheet">
    <style>
        .select2-container--default .select2-selection--single { height: 38px; border: 1px solid #ced4da; }
        .select2-container--default .select2-selection--single .select2-selection__rendered { line-height: 38px; }
        .select2-container--default .select2-selection--single .select2-selection__arrow { height: 36px; }
    </style>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/assets/libs/select2/dist/js/select2.full.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2').select2({ width: '100%' });

            // Cascading
            $('#facultySelect').on('change', function() {
                let id = $(this).val();
                let $lab = $('#laboratorySelect');
                
                $lab.empty().append('<option value="">-- Cargando... --</option>').prop('disabled', true);
                
                if (!id) {
                    $lab.html('<option value="">-- Primero seleccione facultad --</option>');
                    return;
                }

                $.get('/EquipmentUnits/Create?handler=LaboratoriesByFaculty', { facultyId: id }, function(data) {
                    let opts = '<option value="">-- Seleccionar Laboratorio --</option>';
                    $.each(data, function(i, item) { opts += `<option value="${item.id}">${item.name}</option>`; });
                    $lab.html(opts).prop('disabled', false).trigger('change');
                });
            });
        });
    </script>
}

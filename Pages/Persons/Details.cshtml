@page
@model Proyecto_Laboratorios_Univalle.Pages.Persons.DetailsModel
@using Proyecto_Laboratorios_Univalle.Models.Enums

<div class="row">
    <!-- Main Column: Identity File -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Expediente de Personal</h4>
                        <h6 class="card-subtitle text-muted">Información administrativa y profesional de @Model.Person.FullName</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-id-badge fa-2x text-info opacity-5"></i>
                    </div>
                </div>

                <!-- Navigation Tabs -->
                <ul class="nav nav-tabs customtab mb-4" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-toggle="tab" href="#general" role="tab">
                            <span class="hidden-sm-up"><i class="fas fa-home"></i></span>
                            <span class="hidden-xs-down font-weight-bold">Información General</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#maintenances" role="tab">
                            <span class="hidden-sm-up"><i class="fas fa-tools"></i></span>
                            <span class="hidden-xs-down font-weight-bold">Mantenimientos Realizados</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#loans" role="tab">
                            <span class="hidden-sm-up"><i class="fas fa-hand-holding"></i></span>
                            <span class="hidden-xs-down font-weight-bold">Historial de Préstamos</span>
                        </a>
                    </li>
                </ul>

                <!-- Tab panes -->
                <div class="tab-content">
                    <!-- General Tab -->
                    <div class="tab-pane active" id="general" role="tabpanel">
                        <div class="row">
                            <div class="col-md-5 border-right text-center">
                                <div class="btn btn-circle btn-lg btn-light-info text-info mb-3 shadow-none" style="width: 80px; height: 80px; line-height: 70px;">
                                    <i class="fas @(Model.Person is Intern ? "fa-university" : "fa-truck-loading") fa-3x"></i>
                                </div>
                                <h3 class="font-weight-bold text-dark mb-1">@Model.Person.FullName</h3>
                                <div class="mb-3">
                                    <span class="badge badge-pill badge-info px-3">
                                        @(Model.Person is Intern ? "Laboratorio Interno" : (Model.Person is Extern ? "Proveedor Externo" : "Persona Base"))
                                    </span>
                                </div>
                                
                                <div class="mt-2 bg-light p-3 rounded border shadow-none italic border-left border-info border-3 text-left">
                                    @if (Model.Person is Extern e)
                                    {
                                        <label class="text-muted small uppercase font-weight-bold d-block mb-1">Tipo de Externo</label>
                                        <h6 class="font-weight-bold text-dark mb-0">@(e.IsEntity ? "Entidad / Empresa" : "Técnico Independiente")</h6>
                                        
                                        <label class="text-muted small uppercase font-weight-bold d-block mt-3 mb-1">Dirección Registrada</label>
                                        <h6 class="text-dark mb-0">@e.Address</h6>
                                    }
                                    else if (Model.Person is Intern i)
                                    {
                                        <label class="text-muted small uppercase font-weight-bold d-block mb-1">Rol Organizacional</label>
                                        <h6 class="font-weight-bold text-dark mb-0">Uso Interno Univalle</h6>
                                    }
                                </div>
                            </div>

                            <div class="col-md-7">
                                <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-address-book mr-2"></i> Canales de Comunicación</h5>
                                
                                <div class="mb-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <span class="btn btn-circle btn-sm btn-light-info text-info mr-3 font-weight-bold"><i class="fas fa-envelope"></i></span>
                                        <div>
                                            <small class="text-muted d-block uppercase font-weight-bold" style="font-size: 0.65rem;">Correo Electrónico</small>
                                            <span class="font-weight-bold text-dark">@(Model.Person.Email ?? "No registrado")</span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <span class="btn btn-circle btn-sm btn-light-info text-info mr-3 font-weight-bold"><i class="fas fa-phone-alt"></i></span>
                                        <div>
                                            <small class="text-muted d-block uppercase font-weight-bold" style="font-size: 0.65rem;">Teléfono / Celular</small>
                                            <span class="font-weight-bold text-dark">@(Model.Person.PhoneNumber ?? "No registrado")</span>
                                        </div>
                                    </div>
                                </div>

                                <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-info-circle mr-2"></i> Estado de la Ficha</h5>
                                <div class="table-responsive shadow-none">
                                    <table class="table table-sm table-borderless bg-light rounded p-2">
                                        <tbody>
                                            <tr>
                                                <th class="text-muted small uppercase pl-3 font-weight-bold" style="width: 35%;">Estado General:</th>
                                                <td>
                                                    <span class="badge @(Model.Person.Status == GeneralStatus.Activo ? "badge-success" : "badge-danger") px-2 font-weight-bold">
                                                        @Model.Person.Status
                                                    </span>
                                                </td>
                                            </tr>
                                            @if (Model.Person is Intern intern)
                                            {
                                                <tr>
                                                    <th class="text-muted small uppercase pl-3 font-weight-bold">Estado Interno:</th>
                                                    <td>
                                                        <span class="badge border border-info text-info px-2 font-weight-bold">@intern.InternStatus</span>
                                                    </td>
                                                </tr>
                                            }
                                            @if (Model.Person is Extern ex)
                                            {
                                                <tr>
                                                    <th class="text-muted small uppercase pl-3 font-weight-bold">Estado Externo:</th>
                                                    <td>
                                                        <span class="badge border border-warning text-warning px-2 font-weight-bold">@ex.ExternStatus</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Maintenances Tab -->
                    <div class="tab-pane" id="maintenances" role="tabpanel">
                        <div class="p-3">
                            <h5 class="font-weight-bold text-dark mb-3"><i class="fas fa-tools mr-2 text-info"></i> Últimos Mantenimientos Ejecutados</h5>
                            @if (Model.Maintenances.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover table-sm small">
                                        <thead>
                                            <tr class="text-muted uppercase small font-weight-bold">
                                                <th>Fecha</th>
                                                <th>Equipo / Activo</th>
                                                <th>Tipo</th>
                                                <th>Estado</th>
                                                <th class="text-right">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var m in Model.Maintenances)
                                            {
                                                <tr>
                                                    <td>@(m.StartDate?.ToString("dd/MM/yyyy") ?? m.CreatedDate.ToString("dd/MM/yyyy"))</td>
                                                    <td>
                                                        <div class="font-weight-bold text-dark">@m.EquipmentUnit.Equipment.Name</div>
                                                        <div class="text-muted" style="font-size: 0.7rem;">Inv: @m.EquipmentUnit.InventoryNumber</div>
                                                    </td>
                                                    <td>@m.MaintenanceType.Name</td>
                                                    <td>
                                                        <span class="badge badge-pill badge-light-info text-info px-2">@m.Status</span>
                                                    </td>
                                                    <td class="text-right">
                                                        <a asp-page="/Maintenances/Details" asp-route-id="@m.Id" class="btn btn-sm btn-light-info"><i class="fas fa-eye"></i></a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 bg-light rounded">
                                    <i class="fas fa-info-circle fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">No se registran intervenciones técnicas para esta persona.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Loans Tab -->
                    <div class="tab-pane" id="loans" role="tabpanel">
                        <div class="p-3">
                            <h5 class="font-weight-bold text-dark mb-3"><i class="fas fa-hand-holding mr-2 text-info"></i> Historial de Préstamos y Asignaciones</h5>
                            @if (Model.Loans.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover table-sm small">
                                        <thead>
                                            <tr class="text-muted uppercase small font-weight-bold">
                                                <th>Fecha Préstamo</th>
                                                <th>Activo</th>
                                                <th>Devolución</th>
                                                <th>Estado</th>
                                                <th class="text-right">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var l in Model.Loans)
                                            {
                                                <tr>
                                                    <td>@l.LoanDate.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        <div class="font-weight-bold text-dark">@l.EquipmentUnit.Equipment.Name</div>
                                                        <div class="text-muted" style="font-size: 0.7rem;">Inv: @l.EquipmentUnit.InventoryNumber</div>
                                                    </td>
                                                    <td>@(l.ActualReturnDate?.ToString("dd/MM/yyyy") ?? l.EstimatedReturnDate.ToString("dd/MM/yyyy"))</td>
                                                    <td>
                                                        <span class="badge badge-pill @(l.Status == LoanStatus.Active ? "badge-info" : "badge-success") px-2">@l.Status</span>
                                                    </td>
                                                    <td class="text-right">
                                                        <a asp-page="/Loans/Details" asp-route-id="@l.Id" class="btn btn-sm btn-light-info"><i class="fas fa-eye"></i></a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4 bg-light rounded">
                                    <i class="fas fa-info-circle fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">No hay historial de préstamos para esta persona.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar: Audit and Actions -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4 bg-dark text-white">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-history mr-2 text-info"></i> Trazabilidad de Perfil</h5>
                <hr class="border-secondary" />
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <small class="text-muted uppercase font-weight-bold" style="font-size: 0.65rem;">Estado Operativo:</small>
                    <span class="badge badge-pill badge-@(Model.Person.Status == GeneralStatus.Activo ? "success" : "danger") px-3 font-weight-bold">@Model.Person.Status</span>
                </div>

                <div class="small mt-4">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0">Fecha de Alta</label>
                        <span class="font-weight-bold text-white d-block">@Model.Person.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                        <div class="text-muted small italic">Por: @(Model.Person.CreatedBy?.FullName ?? "Sistema")</div>
                    </div>

                    @if (Model.Person.LastModifiedDate.HasValue)
                    {
                        <div class="mb-0 border-top border-secondary pt-2">
                            <label class="text-muted d-block small uppercase mb-0">Última Gestión</label>
                            <span class="text-white font-weight-bold d-block">@(Model.Person.ModifiedBy?.FullName ?? "-")</span>
                            <span class="text-muted small italic">@Model.Person.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a asp-page="./Edit" asp-route-id="@Model.Person.Id" class="btn btn-warning btn-block btn-rounded text-white shadow-sm font-weight-bold py-2 mb-2">
                <i class="fas fa-edit mr-1"></i> Editar Perfil
            </a>
            <a asp-page="Index" class="btn btn-outline-secondary btn-block btn-rounded py-2 font-weight-bold mb-4">
                <i class="fas fa-list mr-1"></i> Volver al Directorio
            </a>
            
            <a asp-page="./Delete" asp-route-id="@Model.Person.Id" class="btn btn-link btn-block text-danger small font-weight-bold mt-2">
                <i class="fas fa-trash-alt mr-1"></i> Desvincular Persona del Catálogo
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 3px !important; }
    </style>
}

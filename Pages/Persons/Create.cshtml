@page
@model Proyecto_Laboratorios_Univalle.Pages.Persons.CreateModel

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Registrar Nueva Identidad</h4>
                        <h6 class="card-subtitle text-muted">Apertura de ficha en el catálogo de capital humano y colaboradores externos.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-id-card fa-2x text-info opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate id="personForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>

                    <!-- Type Selection Tabs -->
                    <ul class="nav nav-pills nav-fill mb-4" id="pills-tab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active font-weight-bold" id="pills-internal-tab" data-toggle="pill" href="#pills-internal" role="tab" aria-controls="pills-internal" aria-selected="true" onclick="setType(true)">
                                <i class="fas fa-university mr-2"></i> Laboratorio Interno
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link font-weight-bold" id="pills-external-tab" data-toggle="pill" href="#pills-external" role="tab" aria-controls="pills-external" aria-selected="false" onclick="setType(false)">
                                <i class="fas fa-truck-loading mr-2"></i> Proveedor Externo
                            </a>
                        </li>
                    </ul>
                    
                    <!-- Hidden input to bind type -->
                    <input type="hidden" asp-for="Input.IsInternal" id="isInternalInput" value="true" />

                    <div class="row">
                        <!-- Standard Identification -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-id-card mr-2"></i> Identificación General
                            </h5>
                            
                            <div class="form-group mb-4">
                                <label asp-for="Input.Name" class="control-label font-weight-bold small uppercase text-muted">Nombre / Razón Social <span class="text-danger">*</span></label>
                                <input asp-for="Input.Name" class="form-control" placeholder="Ej: Laboratorio Univalle / Empresa S.A." required />
                                <span asp-validation-for="Input.Name" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div id="externSpecifics" style="display:none;">
                                <div class="form-group mb-4">
                                    <div class="custom-control custom-checkbox mr-sm-2">
                                        <input type="checkbox" asp-for="Input.IsEntity" class="custom-control-input" id="isEntityCheck">
                                        <label class="custom-control-label font-weight-bold text-dark" for="isEntityCheck">¿Es una Entidad / Empresa?</label>
                                    </div>
                                    <small class="text-muted">Si no marca esto, se tratará como técnico independiente.</small>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="Input.Address" class="control-label font-weight-bold small uppercase text-muted">Dirección <span class="text-danger">*</span></label>
                                    <textarea asp-for="Input.Address" class="form-control" rows="2" placeholder="Ej: Av. Villarroel #123"></textarea>
                                    <span asp-validation-for="Input.Address" class="text-danger small font-weight-bold"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Contact Data -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-address-book mr-2"></i> Canales de Contacto
                            </h5>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Email" class="control-label font-weight-bold small uppercase text-muted">Correo Electrónico</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white border-right-0"><i class="fas fa-envelope text-muted"></i></span>
                                    </div>
                                    <input asp-for="Input.Email" type="email" class="form-control border-left-0" placeholder="ejemplo@proveedor.com" />
                                </div>
                                <span asp-validation-for="Input.Email" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.PhoneNumber" class="control-label font-weight-bold small uppercase text-muted">Número de Teléfono</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white border-right-0"><i class="fas fa-phone-alt text-muted"></i></span>
                                    </div>
                                    <input asp-for="Input.PhoneNumber" class="form-control border-left-0" placeholder="+591 ..." />
                                </div>
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small font-weight-bold"></span>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-light border-0 small p-3 mt-2 text-info d-flex align-items-center rounded shadow-none border-left border-info border-3">
                        <i class="fas fa-info-circle mr-3 fa-2x"></i>
                        <span>Este registro crea una ficha base de @(Model.Input.IsInternal ? "compañero" : "colaborador"). El sistema asignará un identificador único automáticamente.</span>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-info btn-rounded px-5 shadow-sm font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Confirmar Registro
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();

            // Spanish alphabetic pattern
            var namePattern = /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]*$/;

            function restrictInput($selector, pattern) {
                $($selector).on('input', function() {
                    var val = $(this).val();
                    if (!pattern.test(val)) {
                        $(this).val(val.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g, ''));
                    }
                });
            }

            restrictInput('#Input_Name', namePattern);
            
            // Internal/External Logic
            window.setType = function(isInternal) {
                $('#isInternalInput').val(isInternal);
                if (isInternal) {
                    $('#externSpecifics').hide();
                    $('#Input_Address').prop('required', false).val('');
                } else {
                    $('#externSpecifics').show();
                    $('#Input_Address').prop('required', true);
                }
            };
            
            // Initialize based on current model value
            var initialIsInternal = $('#isInternalInput').val() === 'True' || $('#isInternalInput').val() === 'true';
            if (!initialIsInternal) {
                $('#pills-external-tab').tab('show');
                setType(false);
            }
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 3px !important; }
    </style>
}

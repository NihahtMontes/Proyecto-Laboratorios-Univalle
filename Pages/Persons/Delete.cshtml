@page
@model Proyecto_Laboratorios_Univalle.Pages.Persons.DeleteModel

<div class="row justify-content-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5 text-center">
                <!-- Warning icon -->
                <div class="mb-4 text-danger">
                    <i class="fas fa-exclamation-triangle display-4"></i>
                </div>

                <!-- Title -->
                <h3 class="card-title text-dark font-weight-bold">¿Dar de Baja Identidad?</h3>
                <p class="text-muted mb-4">
                    Estás a punto de desvincular a <strong class="text-dark">@Model.Person.FullName</strong> del catálogo activo.
                    <br><span class="small italic">Esta acción ocultará el registro pero mantendrá la trazabilidad histórica.</span>
                </p>

                <!-- Key Data -->
                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100 border-left border-danger border-3 shadow-none rounded">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase font-weight-bold">Cédula:</span>
                        <strong class="text-dark">@Model.Person.IdentityCard</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase font-weight-bold">Perfil:</span>
                        <span class="badge badge-pill badge-primary px-3">@Model.Person.Category</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small uppercase font-weight-bold">Organización:</span>
                        <span class="text-dark small font-weight-bold">@(Model.Person.Company ?? "Univalle")</span>
                    </div>
                </div>

                <!-- Buttons -->
                <form method="post">
                    <input type="hidden" asp-for="Person.Id" />
                    
                    <div class="d-flex flex-column flex-sm-row justify-content-center">
                        <a asp-page="./Details" asp-route-id="@Model.Person.Id" class="btn btn-outline-secondary btn-rounded px-4 mb-2 mb-sm-0 mr-sm-2 font-weight-bold py-2">
                             Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger btn-rounded px-4 shadow-sm font-weight-bold py-2">
                            <i class="fas fa-user-slash mr-1"></i> Confirmar Baja
                        </button>
                    </div>
                </form>
                
                <div class="mt-4">
                    <a asp-page="./Index" class="btn btn-link text-muted small uppercase font-weight-bold">Volver al Directorio</a>
                </div>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small italic">
            <i class="fas fa-info-circle mr-1 text-info"></i> El registro permanecerá en la base de datos con estado <strong>Eliminado</strong> para fines de auditoría.
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-3 { border-left-width: 3px !important; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .italic { font-style: italic; }
    </style>
}

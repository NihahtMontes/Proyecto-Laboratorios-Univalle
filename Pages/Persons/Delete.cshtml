@page
@model Proyecto_Laboratorios_Univalle.Pages.Persons.DeleteModel

@{
    ViewData["Title"] = "Confirmar Eliminación";
}

<div class="row justify-content-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-6 col-lg-5">
        <div class="card text-center shadow-sm">
            <div class="card-body p-5">
                <!-- Ícono de advertencia -->
                <div class="mb-4 text-danger">
                    <i class="ti-user display-3 opacity-3" style="position: absolute; left: 50%; transform: translateX(-50%); top: 10px;"></i>
                    <i class="fas fa-exclamation-triangle display-4" style="position: relative; z-index: 1;"></i>
                </div>

                <!-- Título -->
                <h3 class="card-title text-dark font-weight-bold">¿Eliminar Perfil de Personal?</h3>
                <p class="text-muted mb-4">
                    Estás a punto de eliminar a <strong class="text-dark">@Model.Person.FirstName @Model.Person.LastName</strong> del directorio central.
                    <br>Esta acción es crítica si la persona tiene un usuario vinculado.
                </p>

                <!-- Datos clave -->
                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100 border-left border-danger border-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase">Cédula:</span>
                        <strong class="text-dark">@Model.Person.IdentityCard</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase">Perfil:</span>
                        <span class="text-dark font-weight-bold small">@Model.Person.Category</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small uppercase">Empresa:</span>
                        <span class="text-dark small">@(Model.Person.Company ?? "Univalle")</span>
                    </div>
                </div>

                <!-- Botones -->
                <form method="post">
                    <input type="hidden" asp-for="Person.Id" />
                    
                    <a asp-page="./Details" asp-route-id="@Model.Person.Id" class="btn btn-outline-secondary btn-rounded px-4 mr-2">
                         Ver Detalles
                    </a>
                    <button type="submit" class="btn btn-danger btn-rounded px-4 shadow-sm">
                        <i class="fas fa-trash-alt mr-1"></i> Confirmar Eliminación
                    </button>
                </form>
                
                <div class="mt-4">
                    <a asp-page="./Index" class="btn btn-link text-muted small">Volver al Directorio</a>
                </div>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            <i class="fas fa-info-circle mr-1"></i> La eliminación podría fallar si la persona está vinculada a solicitudes de mantenimiento activas.
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-3 { border-left-width: 3px !important; }
    </style>
}

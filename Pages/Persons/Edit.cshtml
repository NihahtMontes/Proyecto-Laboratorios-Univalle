@page
@model Proyecto_Laboratorios_Univalle.Pages.Persons.EditModel
@using Proyecto_Laboratorios_Univalle.Models.Enums

<div class="row">
    <!-- Main Column: Profile Form -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Actualizar Ficha de Personal</h4>
                        <h6 class="card-subtitle text-muted">Gestión de la identidad base: @Model.Person.FullName</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-user-edit fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate id="personForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" asp-for="Input.Id" />
                    <input type="hidden" asp-for="Input.IsInternal" id="isInternalInput" />

                    <div class="row">
                        <!-- Identification and Profile -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-address-card mr-2"></i> Identificación</h5>
                            
                            <div class="form-group mb-4">
                                <label asp-for="Input.Name" class="control-label font-weight-bold small uppercase text-muted">Nombre / Razón Social <span class="text-danger">*</span></label>
                                <input asp-for="Input.Name" class="form-control" required />
                                <span asp-validation-for="Input.Name" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Status" class="control-label font-weight-bold small uppercase text-muted">Estado de Ficha (Sistema)</label>
                                <select asp-for="Input.Status" class="form-control custom-select" 
                                        asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<GeneralStatus>()">
                                </select>
                            </div>

                            @if (!Model.Input.IsInternal)
                            {
                                <div class="form-group mb-4">
                                    <div class="custom-control custom-checkbox mr-sm-2">
                                        <input type="checkbox" asp-for="Input.IsEntity" class="custom-control-input" id="isEntityCheck">
                                        <label class="custom-control-label font-weight-bold text-dark" for="isEntityCheck">¿Es una Entidad / Empresa?</label>
                                    </div>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="Input.Address" class="control-label font-weight-bold small uppercase text-muted">Dirección <span class="text-danger">*</span></label>
                                    <textarea asp-for="Input.Address" class="form-control" rows="2" required></textarea>
                                    <span asp-validation-for="Input.Address" class="text-danger small font-weight-bold"></span>
                                </div>
                            }
                        </div>

                        <!-- Contact and Status -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3"><i class="fas fa-id-badge mr-2"></i> Canales y Estados Específicos</h5>

                            <div class="form-group mb-4">
                                <label asp-for="Input.Email" class="control-label font-weight-bold small uppercase text-muted">Correo Electrónico</label>
                                <input asp-for="Input.Email" type="email" class="form-control shadow-none" />
                                <span asp-validation-for="Input.Email" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Input.PhoneNumber" class="control-label font-weight-bold small uppercase text-muted">Número de Contacto</label>
                                <input asp-for="Input.PhoneNumber" class="form-control shadow-none" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small font-weight-bold"></span>
                            </div>

                            @if (Model.Input.IsInternal)
                            {
                                <div class="form-group mb-4">
                                    <label asp-for="Input.InternStatus" class="control-label font-weight-bold small uppercase text-info">Estado del Laboratorio Interno</label>
                                    <select asp-for="Input.InternStatus" class="form-control custom-select" 
                                            asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<GeneralStatus>()">
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div class="form-group mb-4">
                                    <label asp-for="Input.ExternStatus" class="control-label font-weight-bold small uppercase text-warning">Estado del Proveedor Externo</label>
                                    <select asp-for="Input.ExternStatus" class="form-control custom-select" 
                                            asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<GeneralStatus>()">
                                    </select>
                                </div>
                            }
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Actualizar Información
                        </button>
                        <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Sidebar: Audit and Summary -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-info-circle mr-2 text-info"></i> Resumen de Perfil</h5>
                <hr class="border-secondary" />
                <div class="text-center py-3">
                    <div class="btn btn-circle btn-lg @(Model.Input.IsInternal ? "btn-info" : "btn-warning") mb-3 shadow" style="width: 70px; height: 80px; line-height: 70px;">
                        <i class="fas @(Model.Input.IsInternal ? "fa-university" : "fa-truck-loading") fa-2x"></i>
                    </div>
                    <h5 class="font-weight-bold mb-1 text-white">@Model.Person.FullName</h5>
                    <div class="mb-3">
                        <span class="badge badge-pill badge-light px-3 uppercase small">
                            @(Model.Input.IsInternal ? "Laboratorio" : "Externo")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase"><i class="fas fa-history mr-2 text-warning"></i> Control de Ficha</h5>
                <hr />
                <div class="small">
                    <div class="mb-3 border-left border-info pl-2 ml-1">
                        <label class="text-muted d-block small uppercase mb-0">Identificador</label>
                        <span class="font-weight-bold text-dark">ID #@Model.Person.Id</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();

            // Spanish alphabetic pattern
            var namePattern = /^[a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s.\-]*$/;

            function restrictInput($selector, pattern) {
                $($selector).on('input', function() {
                    var val = $(this).val();
                    if (!pattern.test(val)) {
                        $(this).val(val.replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s.\-]/g, ''));
                    }
                });
            }

            restrictInput('#Input_Name', namePattern);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
        .border-3 { border-left-width: 3px !important; }
    </style>
}

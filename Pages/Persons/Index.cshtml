@page
@model Proyecto_Laboratorios_Univalle.Pages.Persons.IndexModel

@{
    ViewData["Title"] = "Gestión de Personas";
}

<div class="page-breadcrumb">
    <div class="row">
        <div class="col-5 align-self-center">
            <h4 class="page-title">Gestión de Personas</h4>
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-page="/Index">Inicio</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Personas</li>
                    </ol>
                </nav>
            </div>
        </div>
        <div class="col-7 align-self-center">
            <div class="d-flex no-block justify-content-end align-items-center">
                <a asp-page="Create" class="btn btn-info"><i class="mdi mdi-plus"></i> Crear Nueva Persona</a>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Listado de Personas</h4>
                    <h6 class="card-subtitle">Administración de docentes, personal y externos.</h6>
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered" id="personsTable">
                            <thead>
                                <tr>
                                    <th>Nombre Completo</th>
                                    <th>Tipo</th>
                                    <th>Cargo / Empresa</th>
                                    <th>Email</th>
                                    <th>Teléfono</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Person)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.FirstName @item.LastName</strong>
                                        </td>
                                        <td>
                                            <span class="badge badge-info">@item.Type</span>
                                        </td>
                                        <td>
                                            @item.JobTitle <br />
                                            <small class="text-muted">@item.Company</small>
                                        </td>
                                        <td>@item.Email</td>
                                        <td>@item.PhoneNumber</td>
                                        <td>
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    Acciones
                                                </button>
                                                <div class="dropdown-menu">
                                                    <a class="dropdown-item" asp-page="./Edit" asp-route-id="@item.Id"><i class="ti-pencil"></i> Editar</a>
                                                    <a class="dropdown-item" asp-page="./Details" asp-route-id="@item.Id"><i class="ti-info-alt"></i> Detalles</a>
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item text-danger" asp-page="./Delete" asp-route-id="@item.Id"><i class="ti-trash"></i> Eliminar</a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/assets/libs/datatables.net-bs4/css/dataTables.bootstrap4.css" rel="stylesheet">
}

@section Scripts {
    <script src="~/assets/extra-libs/DataTables/datatables.min.js"></script>
    <script>
        $('#personsTable').DataTable({
            "language": {
                "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Spanish.json"
            }
        });
    </script>
}

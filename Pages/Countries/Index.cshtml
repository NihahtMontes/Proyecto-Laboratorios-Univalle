@page
@model Proyecto_Laboratorios_Univalle.Pages.Countries.IndexModel

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex no-block align-items-center mb-4">
                    <h4 class="card-title">Listado de Países</h4>
                    <div class="ml-auto">
                        <a asp-page="Create" class="btn btn-info btn-rounded">
                            <i class="fas fa-plus mr-1"></i> Nuevo País
                        </a>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover v-middle">
                        <thead class="thead-light">
                            <tr>
                                <th>País</th>
                                <th>Estado</th>
                                <th>Registrado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Countries)
                            {
                                <tr>
                                    <td>
                                        <h5 class="m-b-0 font-medium">@item.Name</h5>
                                    </td>
                                    <td>
                                        <span class="badge @(item.Status == Proyecto_Laboratorios_Univalle.Models.Enums.GeneralStatus.Activo ? "badge-success" : "badge-danger")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">@item.CreatedDate.ToString("dd/MM/yyyy")</small><br />
                                        <small class="text-info">@item.CreatedBy?.Initials</small>
                                    </td>
                                    <td>
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Detalles">
                                            <i class="fas fa-info-circle"></i>
                                        </a>

                                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>


@section Styles {
    <link href="~/lib/nice-admin/assets/libs/sweetalert2/dist/sweetalert2.min.css" rel="stylesheet">
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/lib/nice-admin/assets/libs/sweetalert2/dist/sweetalert2.all.min.js"></script>
    <script>
        // ✅ Mensaje de éxito
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                swal({
                    title: "¡Logrado!",
                    text: @Html.JsTempData("SuccessMessage"),
                    type: "success",
                    confirmButtonColor: "#2962ff",
                    confirmButtonText: "OK",
                    timer: 4000
                });
                </text>
        }

        // ✅ Mensaje de error
        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                swal({
                    title: "Error",
                    text: @Html.JsTempData("ErrorMessage"),
                    type: "error",
                    confirmButtonColor: "#f62d51",
                    confirmButtonText: "OK"
                });
                </text>
        }
    </script>
}
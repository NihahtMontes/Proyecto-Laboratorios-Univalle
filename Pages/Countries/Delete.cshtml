@page
@model Proyecto_Laboratorios_Univalle.Pages.Countries.DeleteModel

@{
    ViewData["Title"] = "Confirmar Eliminación";
}

<div class="row justify-content-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-5">
        <!-- Tarjeta Limpia y Centrada -->
        <div class="card text-center shadow-sm">
            <div class="card-body p-5">
                
                <!-- 1. Ícono de Advertencia (Estilo SweetAlert) -->
                <div class="mb-4 text-warning">
                    <i class="ti-alert display-3"></i> 
                </div>

                <!-- 2. Título de Impacto -->
                <h3 class="card-title text-dark font-weight-bold">¿Estás seguro?</h3>
                <p class="text-muted mb-4">
                    Estás a punto de deshabilitar el país <strong class="text-dark">@Model.Country.Name</strong> del sistema.
                    <br>¡No podrás revertir esta acción fácilmente!
                </p>

                <!-- 3. Datos Clave (Cajita gris suave) -->
                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100">
                    <div class="d-flex justify-content-between">
                        <span><i class="fas fa-flag mr-2 text-muted"></i> País:</span>
                        <strong class="text-dark">@Model.Country.Name</strong>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span><i class="fas fa-info-circle mr-2 text-muted"></i> Estado actual:</span>
                        <span class="badge badge-warning">@Model.Country.Status</span>
                    </div>
                </div>

                <!-- 4. Botones de Acción (Redondos) -->
                <form method="post">
                    <input type="hidden" asp-for="Country.Id" />
                    
                    <a asp-page="/Cities/Index" class="btn btn-outline-secondary btn-rounded px-4 mr-2">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-danger btn-rounded px-4">
                        <i class="fas fa-trash-alt mr-1"></i> Sí, eliminarlo
                    </button>
                </form>

            </div>
        </div>
        
        <!-- Pie de página discreto -->
        <div class="text-center mt-3 text-muted small">
            Registrado el @Model.Country.CreatedDate.ToString("dd/MM/yyyy") por @(Model.Country.CreatedBy?.Initials ?? "Sist.")
        </div>
    </div>
</div>

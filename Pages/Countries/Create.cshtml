@page
@using System.Net
@model Proyecto_Laboratorios_Univalle.Pages.Countries.CreateModel

@{
    ViewData["Title"] = "Create";
}

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Registrar País</h4>
                <h6 class="card-subtitle mb-4">Ingrese el nombre del nuevo país para el sistema</h6>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Name" class="control-label font-weight-bold">Nombre del País <span class="text-danger">*</span></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="Ej: Bolivia" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>

                    <hr />

                    <div class="form-actions mt-4 text-right">
                        <button type="submit" class="btn btn-info btn-rounded px-4">
                            <i class="fas fa-save mr-1"></i> Guardar
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary btn-rounded ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

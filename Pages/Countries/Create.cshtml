@page
@model Proyecto_Laboratorios_Univalle.Pages.Countries.CreateModel

@{
    ViewData["Title"] = "Nuevo País";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title">Registrar País</h4>
                        <h6 class="card-subtitle">Ingrese los datos para el nuevo registro</h6>
                    </div>
                    <div class="ml-auto">
                        <i class="fas fa-plus-circle fa-2x text-info opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Name" class="control-label font-weight-bold">Nombre del País <span class="text-danger">*</span></label>
                        <div class="controls">
                            <input asp-for="Input.Name" class="form-control" placeholder="Ej: Bolivia" 
                                   required 
                                   data-validation-required-message="El nombre del país es obligatorio para el registro"
                                   minlength="2"
                                   data-validation-minlength-message="El nombre debe tener al menos 2 caracteres"
                                   pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s-]+$"
                                   data-validation-pattern-message="No se permiten caracteres especiales (solo letras, espacios y guiones)" />
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-light small p-2 mb-4">
                        <i class="fas fa-info-circle mr-1"></i> El registro se creará con estado <strong>Activo</strong> por defecto.
                    </div>

                    <hr />

                    <div class="form-actions mt-4 text-right">
                        <button type="submit" class="btn btn-info btn-rounded px-4 shadow-sm">
                            <i class="fas fa-save mr-1"></i> Guardar Registro
                        </button>
                        <a asp-page="/Cities/Index" class="btn btn-outline-secondary btn-rounded ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            // 💡 Inicialización de la validación personalizada de NiceAdmin
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

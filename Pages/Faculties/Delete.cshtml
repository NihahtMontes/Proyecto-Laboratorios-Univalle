@page
@model Proyecto_Laboratorios_Univalle.Pages.Faculties.DeleteModel

@{
    ViewData["Title"] = "Baja de Unidad Académica";
}

<div class="row justify-content-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-6 col-lg-5">
        <div class="card text-center shadow-sm">
            <div class="card-body p-5">
                <!-- Ícono de advertencia -->
                <div class="mb-4 text-danger">
                    <i class="ti-trash display-3 opacity-2" style="position: absolute; left: 50%; transform: translateX(-50%); top: 40px;"></i>
                    <i class="fas fa-exclamation-triangle display-4" style="position: relative; z-index: 1;"></i>
                </div>

                <!-- Título -->
                <h3 class="card-title text-dark font-weight-bold">¿Retirar Unidad Académica?</h3>
                <p class="text-muted mb-4">
                    Estás a punto de deshabilitar la facultad <strong class="text-dark">@Model.Faculty.Name</strong>.
                    <br>Esta acción impedirá que se vinculen nuevos laboratorios a esta unidad.
                </p>

                <!-- Datos clave -->
                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100 border-left border-danger border-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small uppercase">Sigla Oficial:</span>
                        <strong class="text-dark">@(Model.Faculty.Code ?? "No definida")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small uppercase">Estatus Actual:</span>
                        <span class="badge badge-pill badge-warning px-3 font-weight-bold">@Model.Faculty.Status</span>
                    </div>
                </div>

                <!-- Botones -->
                <form method="post">
                    <input type="hidden" asp-for="Faculty.Id" />
                    
                    <a asp-page="./Details" asp-route-id="@Model.Faculty.Id" class="btn btn-outline-secondary btn-rounded px-4 mr-2">
                         Ver Detalles
                    </a>
                    <button type="submit" class="btn btn-danger btn-rounded px-4 shadow-sm font-weight-bold">
                        <i class="fas fa-trash-alt mr-1"></i> Confirmar Baja
                    </button>
                </form>
                
                <div class="mt-4">
                    <a asp-page="/Laboratories/Index" class="btn btn-link text-muted small">Volver al Directorio</a>
                </div>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small italic">
            <i class="fas fa-info-circle mr-1"></i> El sistema realizará una baja administrativa preservando la integridad de los laboratorios ya registrados.
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-3 { border-left-width: 3px !important; }
    </style>
}

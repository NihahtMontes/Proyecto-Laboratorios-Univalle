@page
@model Proyecto_Laboratorios_Univalle.Pages.Faculties.EditModel

@{
    ViewData["Title"] = "Editar Facultad";
}

<div class="row">
    <!-- Columna Principal: Gestión Académica -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark">Gestión de Unidad Académica</h4>
                        <h6 class="card-subtitle text-muted">Asegúrese de que el nombre y la sigla oficial coincidan con el estatuto.</h6>
                    </div>
                    <div class="ml-auto">
                        <i class="fas fa-university fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" asp-for="Faculty.Id" />

                    <div class="row">
                        <!-- Identidad -->
                        <div class="col-md-7 border-right">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-id-card mr-2"></i> Identidad Institucional
                            </h5>
                            
                            <div class="form-group mb-4">
                                <label asp-for="Faculty.Name" class="control-label font-weight-bold small uppercase text-muted">Nombre de la Facultad <span class="text-danger">*</span></label>
                                <input asp-for="Faculty.Name" class="form-control" required />
                                <span asp-validation-for="Faculty.Name" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label asp-for="Faculty.Description" class="control-label font-weight-bold small uppercase text-muted">Misión Académica / Descripción</label>
                                <textarea asp-for="Faculty.Description" class="form-control" rows="4" placeholder="Breve descripción del alcance de la facultad..."></textarea>
                            </div>
                        </div>

                        <!-- Referencia -->
                        <div class="col-md-5">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-tag mr-2"></i> Referencia
                            </h5>
                            <div class="form-group mb-4 border-left border-warning pl-3 bg-light p-2">
                                <label asp-for="Faculty.Code" class="control-label font-weight-bold small text-warning uppercase">Sigla Oficial (Acronimo)</label>
                                <input asp-for="Faculty.Code" class="form-control border-warning shadow-none font-weight-bold" maxlength="10" />
                                <span asp-validation-for="Faculty.Code" class="text-danger small"></span>
                            </div>

                            <div class="alert alert-light-info border-0 small p-3 mt-4 text-info italic shadow-none">
                                <i class="fas fa-info-circle mr-1"></i> La sigla se utilizará en la generación de reportes y códigos de laboratorio.
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4 bg-light p-3 rounded border-left border-warning mt-3">
                        <label asp-for="Faculty.Status" class="text-warning small uppercase font-weight-bold">Estado Administrativo <span class="text-danger">*</span></label>
                        <select asp-for="Faculty.Status" class="form-control border-warning font-weight-bold custom-select" 
                                asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<Proyecto_Laboratorios_Univalle.Models.Enums.GeneralStatus>()"
                                required></select>
                        <small class="text-muted italic mt-1 d-block">Indique si la facultad está habilitada para agrupar nuevos centros o laboratorios.</small>
                    </div>

                    <hr />

                    <div class="form-actions mt-4 text-right">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold">
                            <i class="fas fa-save mr-1"></i> Actualizar Ficha
                        </button>
                        <a asp-page="/Laboratories/Index" class="btn btn-outline-secondary btn-rounded ml-2">
                             Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Columna Lateral: Estado y Auditoría -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4"><i class="fas fa-info-circle mr-2 text-info"></i> Estado de la Unidad</h5>
                <hr class="border-secondary" />
                
                <div class="text-center py-3">
                    <div class="btn btn-circle btn-lg btn-info mb-3">
                        <i class="fas fa-university fa-lg"></i>
                    </div>
                    <h5 class="font-weight-bold text-white mb-1">@Model.Faculty.Name</h5>
                    <span class="badge badge-pill badge-warning px-3 small font-weight-bold">@(Model.Faculty.Status)</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase"><i class="fas fa-history mr-2 text-warning"></i> Auditoría Operativa</h5>
                <hr />
                <div class="small">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0">Alta de Registro</label>
                        <span class="font-weight-bold text-dark d-block">@Model.Faculty.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="text-muted">Por: @(Model.Faculty.CreatedBy?.FullName ?? "Sistema")</span>
                    </div>
                    @if (Model.Faculty.LastModifiedDate.HasValue == true)
                    {
                        <div class="mb-0 border-top pt-2">
                            <label class="text-muted d-block small uppercase mb-0">Última Gestión</label>
                            <span class="font-weight-bold text-dark d-block">@Model.Faculty.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="text-muted">Por: @(Model.Faculty.ModifiedBy?.FullName ?? "-")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Función para mostrar mensajes de error temporales
            function showTemporaryError($el, message) {
                var $group = $el.closest('.form-group');
                var $help = $group.find('.help-block');
                if ($help.length === 0) {
                    $group.append('<div class="help-block text-danger small font-weight-bold mt-1"></div>');
                    $help = $group.find('.help-block');
                }
                $help.text(message).fadeIn();
                $group.addClass('error');
                
                setTimeout(function() {
                    $help.fadeOut(function() { $(this).text(''); });
                    $group.removeClass('error');
                }, 2000);
            }

            // Patrón: solo letras, números, espacios, guiones, puntos y paréntesis
            var textPattern = /^[a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-\.\(\)]*$/;
            
            function setupBlocking($selector, pattern, errorMessage) {
                $($selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-\.\(\)]/g, ''));
                        showTemporaryError($field, errorMessage);
                    }
                });
            }

            // Aplicar validación agresiva
            setupBlocking('#Input_Name', textPattern, "Carácter no permitido (especial)");
            setupBlocking('#Input_Code', textPattern, "Código: Solo letras, números y guiones");
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

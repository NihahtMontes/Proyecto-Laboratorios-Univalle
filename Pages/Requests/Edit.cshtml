@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Requests.EditModel
@using Proyecto_Laboratorios_Univalle.Models.Enums

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark">Gestión de Solicitud: #@Model.Input.Id</h4>
                        <h6 class="card-subtitle text-muted">Evaluación técnica y actualización del flujo de mantenimiento.</h6>
                    </div>
                    <div class="ml-auto">
                        <i class="fas fa-edit fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small"></div>
                    <input type="hidden" asp-for="Input.Id" />
                    <input type="hidden" asp-for="Input.Type" />

                    <div class="row mb-4">
                        <div class="col-12">
                            <label class="small text-muted font-weight-bold uppercase mb-1">Equipamiento Afectado</label>
                            <div class="p-3 bg-light rounded border-left border-info font-weight-bold text-dark d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="fas fa-tools mr-2 text-info"></i> @Model.Request.Equipment?.Name 
                                    <span class="text-muted font-weight-normal small ml-1">(@(Model.Request.EquipmentUnit?.InventoryNumber ?? "-"))</span>
                                </span>
                                <span class="badge badge-pill badge-info px-3">@Model.Request.Equipment?.Category</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="font-weight-bold text-dark mb-3">
                        @if (Model.Input.Type == RequestType.Technical)
                        {
                            <i class="fas fa-align-left mr-2 text-info"></i> <span>Detalles Técnicos</span>
                        }
                        else
                        {
                            <i class="fas fa-shopping-cart mr-2 text-success"></i> <span>Detalles de Compra</span>
                        }
                    </h5>
                    
                    <div class="form-group mb-4">
                        <label asp-for="Input.Description" class="control-label font-weight-bold small uppercase text-muted">Contenido de la Solicitud / Justificación <span class="text-danger">*</span></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Descripción técnica del problema..."></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    </div>

                    @if (Model.Input.Type == RequestType.Technical)
                    {
                        <div class="form-group mb-4">
                            <label asp-for="Input.EstimatedRepairTime" class="control-label font-weight-bold small uppercase text-muted">Tiempo Estimado de Reparación</label>
                            <input asp-for="Input.EstimatedRepairTime" class="form-control" placeholder="Ej: 2 horas, 1 día..." />
                            <span asp-validation-for="Input.EstimatedRepairTime" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <div class="form-group mb-4">
                            <label asp-for="Input.InvestmentCode" class="control-label font-weight-bold small uppercase text-success">Código de Inversión (Activos)</label>
                            <input asp-for="Input.InvestmentCode" class="form-control border-success" placeholder="Ej: INV-2024-001" />
                            <span asp-validation-for="Input.InvestmentCode" class="text-danger small"></span>
                        </div>
                    }

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Input.Priority" class="control-label font-weight-bold small uppercase text-muted">Nivel de Prioridad <span class="text-danger">*</span></label>
                                <select asp-for="Input.Priority" class="form-control custom-select" asp-items="Html.GetEnumSelectList<RequestPriority>()"></select>
                                <span asp-validation-for="Input.Priority" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                             <div class="form-group">
                                <label asp-for="Input.Observations" class="control-label font-weight-bold small uppercase text-muted">Observaciones Adicionales</label>
                                <textarea asp-for="Input.Observations" class="form-control" rows="1" placeholder="Notas de campo..."></textarea>
                            </div>
                        </div>
                    </div>

                     @if (Model.Input.Type == RequestType.Purchasing)
                    {
                        <div id="cost-table-section" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="control-label font-weight-bold small uppercase text-muted mb-0"><i class="fas fa-list-ol mr-1"></i> Ítems del Presupuesto</label>
                                <button type="button" class="btn btn-sm btn-success btn-rounded shadow-sm" onclick="addItem()">
                                    <i class="fas fa-plus mr-1"></i> Agregar Ítem
                                </button>
                            </div>
                            
                            <div class="table-responsive border rounded bg-white shadow-sm" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0" id="itemsTable">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width: 40%">Descripción/Concepto</th>
                                            <th style="width: 15%">Cantidad</th>
                                            <th style="width: 20%">Precio Unit.</th>
                                            <th style="width: 15%">Unidad</th>
                                            <th style="width: 10%"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="itemsBody">
                                        </tbody>
                                    <tfoot class="bg-light font-weight-bold">
                                        <tr>
                                            <td colspan="2" class="text-right">Total Estimado:</td>
                                            <td colspan="3" class="text-success" id="totalAmount">0.00</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            <span asp-validation-for="Input.Items" class="text-danger small"></span>
                        </div>
                    }

                    @if (User.IsInRole("Administrator") || User.IsInRole("SuperAdmin"))
                    {
                        <div class="card border-info bg-light-info mt-4 shadow-none">
                            <div class="card-body p-3">
                                <h5 class="card-title text-info font-weight-bold mb-3 small uppercase"><i class="fas fa-shield-alt mr-2"></i> Panel de Decisión Administrativa</h5>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-group mb-0">
                                            <label asp-for="Input.Status" class="control-label font-weight-bold small uppercase text-info">Estado de Resolución</label>
                                            <select asp-for="Input.Status" class="form-control custom-select border-info" asp-items="Html.GetEnumSelectList<RequestStatus>()"></select>
                                        </div>
                                    </div>
                                    <div id="rejectionSection" class="col-md-12 mt-3" style="@(Model.Input.Status == RequestStatus.Rejected ? "" : "display:none;")">
                                        <div class="form-group mb-0">
                                            <label asp-for="Input.RejectionReason" class="control-label font-weight-bold small text-danger uppercase">Motivo Relevante de Rechazo</label>
                                            <textarea asp-for="Input.RejectionReason" class="form-control border-danger" rows="2" placeholder="Explique brevemente por qué no procede la solicitud..."></textarea>
                                            <span asp-validation-for="Input.RejectionReason" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold">
                            <i class="fas fa-save mr-1"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4 bg-dark text-white">
            <div class="card-body">
                <h5 class="card-title text-white"><i class="fas fa-info-circle mr-2 text-info"></i> Estado de Trámite</h5>
                <hr class="border-secondary" />
                <div class="small">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-1">Identificador Único</label>
                        <span class="font-weight-bold text-info">#REQ-@(Model.Input.Id.ToString("D5"))</span>
                    </div>
                    <div>
                        <label class="text-muted d-block small uppercase mb-1">Estatus Actual</label>
                        <span class="badge badge-pill badge-@(Model.Request.Status == RequestStatus.Approved ? "success" : (Model.Request.Status == RequestStatus.Pending ? "warning" : "danger")) px-3">
                            @Model.Request.Status
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase"><i class="fas fa-history mr-2 text-warning"></i> Bitácora de Auditoría</h5>
                <hr />
                <div class="small">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0">Origen de Solicitud</label>
                        <span class="font-weight-bold text-dark d-block">@Model.Request.CreatedBy?.FullName</span>
                        <span class="text-muted small">@Model.Request.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>

                    @if (Model.Request.LastModifiedDate.HasValue)
                    {
                        <div class="mb-0 border-top pt-2">
                            <label class="text-muted d-block small uppercase mb-0">Última Gestión</label>
                            <span class="font-weight-bold text-dark d-block">@(Model.Request.ModifiedBy?.FullName ?? "-")</span>
                            <span class="text-muted small">@Model.Request.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        let itemCount = 0;

        function addItem(concept = '', quantity = 1, price = 0, unit = 'Unidad', category = 'SparePart') {
            const index = itemCount++;
            const row = `
                <tr id="row_${index}">
                    <td>
                        <input name="Input.Items[${index}].Concept" class="form-control form-control-sm" placeholder="Ej: Repuesto Valvula..." value="${concept}" required />
                    </td>
                    <td>
                        <input name="Input.Items[${index}].Quantity" type="number" step="0.01" class="form-control form-control-sm qty-input" value="${quantity}" onchange="calcTotal()" required />
                    </td>
                    <td>
                        <input name="Input.Items[${index}].UnitPrice" type="number" step="0.01" class="form-control form-control-sm price-input" value="${price}" onchange="calcTotal()" required />
                    </td>
                    <td>
                        <input name="Input.Items[${index}].UnitOfMeasure" class="form-control form-control-sm" value="${unit}" />
                        <input type="hidden" name="Input.Items[${index}].Category" value="${category}" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger btn-circle" onclick="removeRow(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                    </td>
                </tr>
            `;
            $('#itemsBody').append(row);
            calcTotal();
        }

        function removeRow(index) {
            $(`#row_${index}`).remove();
            calcTotal();
        }

        function calcTotal() {
            let total = 0;
            $('#itemsBody tr').each(function() {
                const qty = parseFloat($(this).find('.qty-input').val()) || 0;
                const price = $(this).find('.price-input').val().replace(',', '.'); 
                const pVal = parseFloat(price) || 0;
                total += qty * pVal;
            });
            $('#totalAmount').text(total.toFixed(2));
        }

        $(function() {
            @if (Model.Input.Type == RequestType.Purchasing && Model.Input.Items != null)
            {
                foreach (var item in Model.Input.Items)
                {
                    <text>
                        addItem("@Html.Raw(item.Concept)", @item.Quantity, @item.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture), "@item.UnitOfMeasure", "@item.Category");
                    </text>
                }
            }
            
            $('#Input_Status').on('change', function() {
                if ($(this).val() == '@((int)RequestStatus.Rejected)') {
                    $('#rejectionSection').slideDown();
                    $('#Input_RejectionReason').focus();
                } else {
                    $('#rejectionSection').slideUp();
                }
            });
        });
    </script>
}

@section Styles {
    <style>
        .bg-light-success { background-color: rgba(40, 167, 69, 0.05); }
        .bg-light-danger { background-color: rgba(220, 53, 69, 0.05); }
        .bg-light-info { background-color: rgba(0, 192, 239, 0.05); }
        .bg-light-warning { background-color: rgba(255, 193, 7, 0.05); }
        .border-left-3 { border-left-width: 4px !important; }
        .italic { font-style: italic; }
        .opacity-5 { opacity: 0.15; }
        .audit-log label { letter-spacing: 0.5px; }
    </style>
}
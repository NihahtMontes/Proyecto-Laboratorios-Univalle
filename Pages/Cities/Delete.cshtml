@page
@model Proyecto_Laboratorios_Univalle.Pages.Cities.DeleteModel
@{
    ViewData["Title"] = "Confirmar Eliminación";
}

<div class="row justify-content-center" style="min-height: 50vh; align-items: center;">
    <div class="col-md-5">
        <div class="card text-center shadow-sm">
            <div class="card-body p-5">
                <div class="mb-4 text-warning">
                    <i class="ti-alert display-3"></i>
                </div>

                <h3 class="card-title text-dark font-weight-bold">¿Estás seguro?</h3>
                <p class="text-muted mb-4">
                    Estás a punto de eliminar la ciudad <strong class="text-dark">@Model.City.Name</strong> del registro.
                    <br>¡No podrás deshacer esta acción!
                </p>

                <div class="bg-light p-3 rounded mb-4 text-left d-inline-block w-100">
                    <div class="d-flex justify-content-between">
                        <span><i class="fas fa-globe-americas mr-2 text-muted"></i> País:</span>
                        <!-- ✅ Si Country es null, muestra vacío en lugar de error -->
                        <strong class="text-dark">@(Model.City.Country?.Name ?? "N/A")</strong>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span><i class="fas fa-map-marked-alt mr-2 text-muted"></i> Región:</span>
                        <span class="text-dark">@Html.DisplayFor(model => model.City.Region)</span>
                    </div>
                </div>

                <form method="post" id="deleteForm">
                    <input type="hidden" asp-for="City.Id" />
                    <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded px-4 mr-2">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-danger btn-rounded px-4">
                        <i class="fas fa-trash-alt mr-1"></i> Sí, eliminarla
                    </button>
                </form>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            Registro creado por @(Model.City.CreatedBy?.FullName ?? "Sistema") el @Model.City.CreatedDate.ToString("d")
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/nice-admin/assets/libs/sweetalert2/dist/sweetalert2.min.css" rel="stylesheet">
}

@section Scripts {
    <script src="~/lib/nice-admin/assets/libs/sweetalert2/dist/sweetalert2.all.min.js"></script>
}
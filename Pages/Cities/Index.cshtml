@page
@model Proyecto_Laboratorios_Univalle.Pages.Cities.IndexModel

@{
    ViewData["Title"] = "Ciudades";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-md-flex align-items-center mb-4">
                    <div>
                        <h4 class="card-title">Gestión de Ciudades</h4>
                        <h6 class="card-subtitle">Listado de ciudades registradas en el sistema</h6>
                    </div>
                    <div class="ml-auto">
                        <a asp-page="Create" class="btn btn-info btn-sm">
                            <i class="fas fa-plus"></i> Crear Nueva Ciudad
                        </a>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-bordered no-wrap">
                        <thead class="bg-light">
                            <tr>
                                <th>País</th>
                                <th>Nombre</th>
                                <th>Región</th>
                                <th>Estado</th>
                                <th>Auditoría</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Cities)
                            {
                                <tr>
                                    <td>@item.Country?.Name</td>
                                    <td><strong>@item.Name</strong></td>
                                    <td>@item.Region</td>
                                    <td>
                                        <span class="badge badge-@(item.Status == Proyecto_Laboratorios_Univalle.Models.Enums.GeneralStatus.Activo ? "success" : "danger")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <i class="mdi mdi-calendar"></i> @item.CreatedDate.ToString("dd/MM/yyyy")<br />
                                            <i class="mdi mdi-account"></i> @item.CreatedBy?.Initials
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Detalles">
                                                <i class="fas fa-info-circle"></i>
                                            </a>
                                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/lib/nice-admin/assets/libs/sweetalert2/dist/sweetalert2.min.css" rel="stylesheet">
}

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/lib/nice-admin/assets/libs/sweetalert2/dist/sweetalert2.all.min.js"></script>

    <script>
        // ✅ Mensaje de éxito (sintaxis v7)
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                swal({
                    title: "¡Logrado!",
                    text: "@TempData["SuccessMessage"]",
                    type: "success",
                    confirmButtonColor: "#2962ff",
                    confirmButtonText: "OK",
                    timer: 4000
                });
                </text>
        }

        // ✅ Mensaje de error (sintaxis v7)
        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                swal({
                    title: "Error",
                    text: "@TempData["ErrorMessage"]",
                    type: "error",
                    confirmButtonColor: "#f62d51",
                    confirmButtonText: "OK"
                });
                </text>
        }
    </script>
}
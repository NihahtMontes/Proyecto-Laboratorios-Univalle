@page
@model Proyecto_Laboratorios_Univalle.Pages.Cities.CreateModel

@{
    ViewData["Title"] = "Nueva Ciudad";
}

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Registrar Ciudad</h4>
                <h6 class="card-subtitle mb-4">Ingrese los datos para la nueva ciudad</h6>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.CountryId" class="control-label font-weight-bold">País <span class="text-danger">*</span></label>
                        <select asp-for="Input.CountryId" class="form-control custom-select" asp-items="ViewBag.CountryId">
                            <option value="">-- Seleccione un País --</option>
                        </select>
                        <span asp-validation-for="Input.CountryId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.Name" class="control-label font-weight-bold">Nombre de la Ciudad <span class="text-danger">*</span></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="Ej: Cochabamba" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Region" class="control-label font-weight-bold">Región / Departamento</label>
                        <input asp-for="Input.Region" class="form-control" placeholder="Ej: Cercado" />
                        <span asp-validation-for="Input.Region" class="text-danger"></span>
                    </div>

                    <hr />

                    <div class="form-actions mt-4 text-right">
                        <button type="submit" class="btn btn-info btn-rounded px-4">
                            <i class="fas fa-save mr-1"></i> Guardar
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary btn-rounded ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

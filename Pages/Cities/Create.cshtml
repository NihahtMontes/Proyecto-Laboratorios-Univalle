@page
@model Proyecto_Laboratorios_Univalle.Pages.Cities.CreateModel

@{
    ViewData["Title"] = "Alta de Ciudad";
}

<div class="row justify-content-center">
    <div class="col-lg-11 col-xl-10">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex no-block align-items-center mb-4">
                    <div>
                        <h4 class="card-title text-dark">Registrar Nueva Localidad</h4>
                        <h6 class="card-subtitle text-muted">Defina las sedes y puntos de presencia institucional con precisión geográfica.</h6>
                    </div>
                    <div class="ml-auto">
                        <i class="fas fa-map-marked-alt fa-2x text-info opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0" role="alert"></div>

                    <div class="row">
                        <!-- Columna 1: Identificación Geográfica -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-globe mr-2"></i> Adscripción Territorial
                            </h5>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Input.CountryId" class="control-label font-weight-bold small uppercase text-muted">
                                    País de Ubicación <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Input.CountryId" class="form-control custom-select" asp-items="ViewBag.CountryId" required>
                                    <option value="">-- Seleccione el País --</option>
                                </select>
                                <span asp-validation-for="Input.CountryId" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Input.Name" class="control-label font-weight-bold small uppercase text-muted">
                                    Nombre de la Ciudad <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Input.Name" class="form-control" placeholder="Ej: La Paz, Santa Cruz..." 
                                       required 
                                       data-validation-required-message="El nombre de la ciudad es obligatorio"
                                       pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]+$"
                                       data-validation-pattern-message="Solo letras, espacios y guiones" />
                                <span asp-validation-for="Input.Name" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Columna 2: División Administrativa -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-layer-group mr-2"></i> División Administrativa
                            </h5>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Input.Region" class="control-label font-weight-bold small uppercase text-muted">
                                    Región / Provincia / Departamento
                                </label>
                                <input asp-for="Input.Region" class="form-control" placeholder="Ej: La Paz, Cochabamba..." 
                                       pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]*$"
                                       data-validation-pattern-message="Solo letras, espacios y guiones" />
                                <span asp-validation-for="Input.Region" class="text-danger small"></span>
                            </div>

                            <div class="alert alert-light border-left border-info border-3 small p-3 mt-4">
                                <strong class="text-info"><i class="fas fa-info-circle mr-1"></i> Nota Técnica</strong><br>
                                <span class="text-muted">
                                    El registro preciso de ciudades permite segmentar el inventario y los servicios técnicos por proximidad regional.
                                </span>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-info btn-rounded px-5 shadow-sm font-weight-bold">
                            <i class="fas fa-save mr-1"></i> Registrar Ciudad
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary btn-rounded ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-3 { border-left-width: 3px !important; }
    </style>
}

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Función para mostrar mensajes de error temporales
            function showTemporaryError($el, message) {
                var $group = $el.closest('.form-group');
                var $help = $group.find('.help-block');
                if ($help.length === 0) {
                    $group.append('<div class="help-block text-danger small font-weight-bold mt-1"></div>');
                    $help = $group.find('.help-block');
                }
                $help.text(message).fadeIn();
                $group.addClass('error');
                
                setTimeout(function() {
                    $help.fadeOut(function() { $(this).text(''); });
                    $group.removeClass('error');
                }, 2000);
            }

            // Patrón: solo letras, espacios y guiones
            var textPattern = /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]*$/;
            
            function setupBlocking($selector, pattern, errorMessage) {
                $($selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]/g, ''));
                        showTemporaryError($field, errorMessage);
                    }
                });
            }

            // Aplicar validación agresiva
            setupBlocking('#Input_Name', textPattern, "Carácter no permitido (solo letras y guiones)");
            setupBlocking('#Input_Region', textPattern, "Región: Solo letras, espacios y guiones");
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

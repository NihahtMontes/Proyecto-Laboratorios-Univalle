@page
@model Proyecto_Laboratorios_Univalle.Pages.Cities.EditModel

@{
    ViewData["Title"] = "Editar Ciudad";
}

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Modificar Ciudad</h4>
                <h6 class="card-subtitle mb-4">Actualice la información de la ciudad seleccionada</h6>
                
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="City.Id" />
                    
                    <div class="form-group mb-3">
                        <label asp-for="City.CountryId" class="control-label font-weight-bold">País <span class="text-danger">*</span></label>
                        <select asp-for="City.CountryId" class="form-control" asp-items="ViewBag.CountryId">
                            <option value="">-- Seleccione un País --</option>
                        </select>
                        <span asp-validation-for="City.CountryId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="City.Name" class="control-label font-weight-bold">Nombre de la Ciudad <span class="text-danger">*</span></label>
                        <input asp-for="City.Name" class="form-control" />
                        <span asp-validation-for="City.Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="City.Region" class="control-label font-weight-bold">Región / Departamento</label>
                        <input asp-for="City.Region" class="form-control" />
                        <span asp-validation-for="City.Region" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="City.Status" class="control-label font-weight-bold">Estado</label>
                        <select asp-for="City.Status" class="form-control" asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<Proyecto_Laboratorios_Univalle.Models.Enums.GeneralStatus>()"></select>
                        <span asp-validation-for="City.Status" class="text-danger"></span>
                    </div>

                    <hr />

                    <div class="form-actions mt-4 text-right">
                        <button type="submit" class="btn btn-warning px-4 text-white">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary ml-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@page "{id:int}"
@model Proyecto_Laboratorios_Univalle.Pages.Cities.EditModel
@using Proyecto_Laboratorios_Univalle.Models.Enums



<div class="row">
    <!-- Main Column: Edit Form -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex no-block align-items-center mb-4 pb-3 border-bottom">
                    <div>
                        <h4 class="card-title text-dark font-weight-bold">Editar Localidad</h4>
                        <h6 class="card-subtitle text-muted">Actualice la configuración territorial y el estado operativo de la sede.</h6>
                    </div>
                    <div class="ml-auto mt-2 mt-md-0">
                        <i class="fas fa-edit fa-2x text-warning opacity-5"></i>
                    </div>
                </div>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 small" role="alert"></div>
                    <input type="hidden" asp-for="City.Id" />

                    <div class="row">
                        <!-- Section 1: Location -->
                        <div class="col-md-6 border-right">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-map-marker-alt mr-2"></i> Ubicación
                            </h5>
                            
                            <div class="form-group mb-3">
                                <label asp-for="City.CountryId" class="control-label font-weight-bold small uppercase text-muted">
                                    País <span class="text-danger">*</span>
                                </label>
                                <select asp-for="City.CountryId" class="form-control custom-select" asp-items="ViewBag.CountryId" required></select>
                                <span asp-validation-for="City.CountryId" class="text-danger small font-weight-bold"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="City.Name" class="control-label font-weight-bold small uppercase text-muted">
                                    Nombre de la Ciudad <span class="text-danger">*</span>
                                </label>
                                <input asp-for="City.Name" class="form-control" placeholder="Ej: Cali, Cochabamba" required />
                                <span asp-validation-for="City.Name" class="text-danger small font-weight-bold"></span>
                            </div>
                        </div>

                        <!-- Section 2: Configuration -->
                        <div class="col-md-6">
                            <h5 class="font-weight-bold text-info mb-3">
                                <i class="fas fa-cog mr-2"></i> Configuración
                            </h5>
                            
                            <div class="form-group mb-3">
                                <label asp-for="City.Region" class="control-label font-weight-bold small uppercase text-muted">
                                    Región / Departamento
                                </label>
                                <input asp-for="City.Region" class="form-control" placeholder="Ej: Valle, Cercado" />
                            </div>

                            <div class="form-group mb-3 border-left border-warning pl-3 bg-light p-2 shadow-none rounded">
                                <label asp-for="City.Status" class="control-label font-weight-bold small text-warning uppercase">
                                    Estado del Registro <span class="text-danger">*</span>
                                </label>
                                <select asp-for="City.Status" class="form-control custom-select border-warning font-weight-bold" 
                                        asp-items="@Proyecto_Laboratorios_Univalle.Helpers.EnumHelper.GetStatusSelectList<GeneralStatus>()"
                                        required>
                                </select>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-actions text-right mt-4">
                        <button type="submit" class="btn btn-warning btn-rounded px-5 shadow-sm text-white font-weight-bold py-2">
                            <i class="fas fa-save mr-1"></i> Actualizar Registro
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary btn-rounded ml-2 py-2 px-4 font-weight-bold">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Sidebar: Audit -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-body">
                <h5 class="card-title text-white font-weight-bold small uppercase mb-4">
                    <i class="fas fa-info-circle mr-2 text-info"></i> Información de Control
                </h5>
                <hr class="border-secondary" />
                <div class="text-center py-3">
                    <div class="btn btn-circle btn-lg btn-info mb-3">
                        <i class="fas fa-city fa-lg"></i>
                    </div>
                    <h5 class="font-weight-bold text-white mb-1">@Model.City.Name</h5>
                    <span class="badge badge-pill badge-warning px-3 small font-weight-bold">@(Model.City.Status)</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="card-title text-dark font-weight-bold mb-4 small uppercase">
                    <i class="fas fa-history mr-2 text-warning"></i> Auditoría Operativa
                </h5>
                <hr />
                <div class="small">
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase mb-0">Alta de Registro</label>
                        <span class="font-weight-bold text-dark d-block">@Model.City.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                        <div class="text-muted small">Por: @(Model.City.CreatedBy?.FullName ?? "Sistema")</div>
                    </div>

                    @if (Model.City.LastModifiedDate.HasValue)
                    {
                        <div class="mb-0 border-top pt-2">
                            <label class="text-muted d-block small uppercase mb-0">Última Gestión</label>
                            <span class="font-weight-bold text-dark d-block">@(Model.City.ModifiedBy?.FullName ?? "-")</span>
                            <span class="text-muted small">@Model.City.LastModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/nice-admin/assets/extra-libs/jqbootstrapvalidation/validation.js"></script>
    <script>
        $(function () {
            "use strict";
            $("input,select,textarea").not("[type=submit]").jqBootstrapValidation();
            
            // Advanced text pattern for Spanish alfanumeric fields
            var textPattern = /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]*$/;
            
            function setupBlocking($selector, pattern) {
                $($selector).on('input', function() {
                    var $field = $(this);
                    var val = $field.val();
                    if (!pattern.test(val)) {
                        $field.val(val.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]/g, ''));
                    }
                });
            }

            // Apply aggressive validation
            setupBlocking('#City_Name', textPattern);
            setupBlocking('#City_Region', textPattern);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <style>
        .help-block ul { list-style: none; padding-left: 0; }
        .italic { font-style: italic; }
        .uppercase { text-transform: uppercase; letter-spacing: 1px; }
    </style>
}

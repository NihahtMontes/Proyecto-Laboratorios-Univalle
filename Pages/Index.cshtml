</div>

<!-- MODAL WIZARD: Asistente de Inicio de Gestión -->
<div class="modal fade" id="wizardModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content border-0 rounded-2xl shadow-xl overflow-hidden tailwind-scope">
      <div class="bg-slate-900 text-white px-6 py-4 flex items-center gap-3">
        <i class="fas fa-calendar-alt text-blue-400 text-xl"></i>
        <h2 class="text-lg font-bold m-0 text-white">Asistente de Inicio de Gestión</h2>
      </div>
      
      <div class="p-6">
        <!-- Step 1 -->
        <div id="wizardStep1" class="space-y-5">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1">Año de Gestión</label>
              <input type="number" value="2025" id="wizardYear" class="w-full h-10 px-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 font-medium" />
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1">Semestre</label>
              <div class="flex gap-2 p-1 bg-slate-100 rounded-lg">
                <button type="button" onclick="setSemester('I')" id="btnSemI" class="flex-1 py-2 text-sm font-semibold rounded-md transition-colors bg-white text-slate-800 shadow-sm border border-gray-200 focus:outline-none">
                  I — Jun/Jul
                </button>
                <button type="button" onclick="setSemester('II')" id="btnSemII" class="flex-1 py-2 text-sm font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 focus:outline-none border border-transparent">
                  II — Dic/Ene
                </button>
              </div>
            </div>
          </div>

          <div class="p-3 bg-slate-50 border border-slate-100 rounded-lg text-center">
            <span class="text-xs text-slate-500 block mb-1">Vista Previa</span>
            <span class="text-sm font-bold text-[#3B82F6]" id="wizardPreview">
              Gestión 2025-I | Jun – Jul 2025
            </span>
          </div>

          <div class="flex items-start gap-3 p-3 bg-[#FFC107]/10 border border-[#FFC107]/30 rounded-lg text-yellow-800">
            <i class="fas fa-exclamation-triangle text-[#FFC107] text-lg mt-0.5"></i>
            <p class="text-xs font-medium leading-relaxed m-0">
              <strong class="block mb-0.5">Atención:</strong>
              Al activar esta nueva gestión, todos los mantenimientos de la gestión actual serán archivados automáticamente y se iniciará un periodo en blanco.
            </p>
          </div>

          <div class="flex justify-end pt-2">
            <button type="button" onclick="nextStep()" class="inline-flex items-center justify-center rounded-lg font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none bg-[#28A745] text-white hover:bg-green-700 active:bg-green-800 border border-transparent shadow-sm h-10 px-4 text-sm w-full sm:w-auto gap-2">
              Siguiente <i class="fas fa-arrow-right text-[10px]"></i>
            </button>
          </div>
        </div>

        <!-- Step 2 -->
        <div id="wizardStep2" class="space-y-6 hidden">
          <div class="text-center space-y-2">
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
              <i class="fas fa-check text-2xl"></i>
            </div>
            <h3 class="text-lg font-bold text-slate-900 m-0">Confirmar Activación</h3>
            <p class="text-sm text-slate-500 m-0 mt-1">Revise los datos antes de proceder.</p>
          </div>

          <div class="bg-slate-50 rounded-xl shadow-sm border border-gray-100 overflow-hidden p-4 flex flex-col items-center justify-center text-center">
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Se activará</span>
            <span class="text-xl font-black text-slate-800" id="wizardTargetTitle">Gestión 2025-I</span>
            <span class="text-sm text-slate-500 mt-1" id="wizardTargetDesc">Junio – Julio 2025</span>
          </div>

          <div class="flex gap-3 pt-2">
            <button type="button" onclick="$('#wizardModal').modal('hide')" class="inline-flex items-center justify-center rounded-lg font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 bg-white border border-gray-300 text-slate-700 hover:bg-gray-50 active:bg-gray-100 h-10 px-4 text-sm flex-1">
              Cancelar
            </button>
            <button type="button" onclick="finishWizard()" class="inline-flex items-center justify-center rounded-lg font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 bg-[#28A745] text-white hover:bg-green-700 active:bg-green-800 border border-transparent shadow-sm h-10 px-4 text-sm flex-1">
              Activar Gestión
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <!-- Chart.js for rendering the graphical data from Tailwind component -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let currentSem = 'I';

        // Custom JS to handle dropdown and modal behavior to mimic React state
        function toggleManagement() {
            var dd = document.getElementById('mgmntDropdown');
            if (dd.classList.contains('hidden')) {
                dd.classList.remove('hidden');
                setTimeout(() => { dd.style.opacity = '1'; dd.style.transform = 'translateY(0)'; }, 10);
            } else {
                dd.style.opacity = '0'; dd.style.transform = 'translateY(5px)';
                setTimeout(() => dd.classList.add('hidden'), 150);
            }
        }

        // Close dropdown when clicking outside
        window.addEventListener('click', function(e) {
            if (!document.getElementById('managementSystemDropdown').contains(e.target)) {
                var dd = document.getElementById('mgmntDropdown');
                if (!dd.classList.contains('hidden')) {
                    dd.style.opacity = '0'; dd.style.transform = 'translateY(5px)';
                    setTimeout(() => dd.classList.add('hidden'), 150);
                }
            }
        });

        function openWizardModal() {
            toggleManagement(); // close dropdown
            document.getElementById('wizardStep1').classList.remove('hidden');
            document.getElementById('wizardStep2').classList.add('hidden');
            $('#wizardModal').modal('show');
        }

        function setSemester(sem) {
            currentSem = sem;
            var year = document.getElementById('wizardYear').value;
            
            if (sem === 'I') {
                document.getElementById('btnSemI').className = "flex-1 py-2 text-sm font-semibold rounded-md transition-colors bg-white text-slate-800 shadow-sm border border-gray-200 focus:outline-none";
                document.getElementById('btnSemII').className = "flex-1 py-2 text-sm font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 focus:outline-none border border-transparent";
                document.getElementById('wizardPreview').innerText = `Gestión ${year}-I | Jun – Jul ${year}`;
            } else {
                document.getElementById('btnSemII').className = "flex-1 py-2 text-sm font-semibold rounded-md transition-colors bg-white text-slate-800 shadow-sm border border-gray-200 focus:outline-none";
                document.getElementById('btnSemI').className = "flex-1 py-2 text-sm font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 focus:outline-none border border-transparent";
                document.getElementById('wizardPreview').innerText = `Gestión ${year}-II | Dic – Ene ${year}`;
            }
        }

        document.getElementById('wizardYear').addEventListener('input', function() {
            setSemester(currentSem);
        });

        function nextStep() {
            var year = document.getElementById('wizardYear').value;
            document.getElementById('wizardStep1').classList.add('hidden');
            document.getElementById('wizardStep2').classList.remove('hidden');
            
            document.getElementById('wizardTargetTitle').innerText = `Gestión ${year}-${currentSem}`;
            document.getElementById('wizardTargetDesc').innerText = currentSem === 'I' ? `Junio – Julio ${year}` : `Diciembre – Enero ${year}`;
        }

        function finishWizard() {
            $('#wizardModal').modal('hide');
            // Trigger SweetAlert defined in Layout using TempData-like mechanism natively
            if(window.Swal) {
                Swal.fire('Gestión Activada', 'La nueva gestión se ha iniciado exitosamente.', 'success');
            }
        }

        // Initialize Charts with Chart.js mimicking Recharts
        document.addEventListener('DOMContentLoaded', function() {
            // Global Progress Pie
            const ctxGlobal = document.getElementById('globalProgressChart').getContext('2d');
            new Chart(ctxGlobal, {
                type: 'doughnut',
                data: {
                    labels: ['Ejecutado', 'Planeado'],
                    datasets: [{
                        data: [45, 55],
                        backgroundColor: ['#28A745', '#E2E8F0'],
                        borderWidth: 0,
                        cutout: '75%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(c) { return c.parsed + '%'; } } } }
                }
            });

            // Type Progress Bar
            const ctxType = document.getElementById('typeProgressChart').getContext('2d');
            new Chart(ctxType, {
                type: 'bar',
                data: {
                    labels: ['Mecánicos', 'Eléctricos', 'Ópticos', 'Térmicos'],
                    datasets: [{
                        data: [80, 50, 90, 30],
                        backgroundColor: ['#3B82F6', '#F59E0B', '#8B5CF6', '#EC4899'],
                        borderRadius: 4,
                        barThickness: 16
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { display: false },
                        y: { grid: { display: false }, border: { display: false }, ticks: { color: '#64748b', font: { size: 12 } } }
                    },
                    plugins: { legend: { display: false } }
                }
            });

            // Subgroups Progress Bar
            const ctxSub = document.getElementById('subgroupsProgressChart').getContext('2d');
            new Chart(ctxSub, {
                type: 'bar',
                data: {
                    labels: ['Laboratorios H', 'Biotecnología', 'Civil y Suelos'],
                    datasets: [{
                        data: [65, 40, 85],
                        backgroundColor: ['#10B981', '#F43F5E', '#3B82F6'],
                        borderRadius: 4,
                        barThickness: 16
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { display: false },
                        y: { grid: { display: false }, border: { display: false }, ticks: { color: '#64748b', font: { size: 12 } } }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        });
    </script>
}

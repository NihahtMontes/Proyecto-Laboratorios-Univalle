@page
@model IndexModel
@using Proyecto_Laboratorios_Univalle.Models.Enums
@{
    var now = DateTime.UtcNow;
    string greeting = now.Hour < 12 ? "Buenos días" : now.Hour < 18 ? "Buenas tardes" : "Buenas noches";
}

@section Styles {
    <!-- Tailwind Generated Scoped CSS -->
    <link rel="stylesheet" href="~/css/tailwind-dashboard.css" asp-append-version="true" />
    
    <!-- Evitar conflictos con Bootstrap -->
    <style>
        .tailwind-scope {
            /* Resetting some Bootstrap conflicts if needed inside the dashboard scope */
            text-align: left;
        }
        .tailwind-scope a:hover {
            text-decoration: none;
        }
    </style>
}

<div class="tailwind-scope p-6 max-w-[1600px] mx-auto space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight flex items-center">
        Planificación Global
        <!-- Management System Component -->
        <div class="relative inline-block ml-4" id="managementSystemDropdown">
          <button
            onclick="toggleManagement()"
            class="flex items-center gap-2 bg-white border border-gray-200 shadow-sm rounded-lg px-3 py-1.5 hover:bg-gray-50 transition-colors focus:outline-none"
          >
            <span class="text-sm font-semibold text-slate-800">Gestión 2025-I</span>
            <span class="text-xs text-slate-500">| Junio – Julio 2025</span>
            <i class="fas fa-chevron-down text-slate-400 text-xs"></i>
          </button>

          <!-- Dropdown -->
          <div id="mgmntDropdown" class="absolute top-full left-0 mt-2 w-72 bg-white rounded-xl shadow-lg border border-gray-200 py-2 z-50 hidden" style="opacity: 0; transform: translateY(5px); transition: all 0.15s ease-in-out;">
            <div class="px-4 py-2 text-xs font-bold text-slate-400 uppercase tracking-wider">
              Gestiones Disponibles
            </div>
            
            <button class="w-full text-left px-4 py-2.5 bg-[#28A745]/5 hover:bg-[#28A745]/10 flex items-center justify-between group transition-colors">
              <div>
                <div class="text-sm font-bold text-[#28A745]">Gestión 2025-I</div>
                <div class="text-xs text-slate-500">Junio – Julio 2025</div>
              </div>
              <i class="fas fa-check text-[#28A745]"></i>
            </button>
            
            <button class="w-full text-left px-4 py-2.5 hover:bg-slate-50 flex items-center justify-between group transition-colors opacity-70">
              <div>
                <div class="text-sm font-semibold text-slate-600">Gestión 2024-II</div>
                <div class="text-xs text-slate-500">Diciembre – Enero 2024</div>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-slate-100 text-slate-700 border border-slate-200">Archivada</span>
            </button>

            <div class="my-1 border-t border-gray-100"></div>
            
            <button onclick="openWizardModal()" class="w-full text-left px-4 py-2 hover:bg-slate-50 flex items-center gap-2 text-sm font-semibold text-[#3B82F6] transition-colors">
              <i class="fas fa-plus"></i> Nueva Gestión Semestral
            </button>
          </div>
        </div>
      </h1>
      <p class="text-slate-500 text-sm mt-1">Avance de Mantenimientos por Laboratorio y Equipos</p>
    </div>
    
    <div class="flex gap-3">
      <button class="inline-flex items-center justify-center rounded-lg font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none bg-[#DC3545] text-white hover:bg-red-700 active:bg-red-800 border border-transparent shadow-sm h-10 px-4 text-sm gap-2 shrink-0">
        <i class="fas fa-exclamation-circle text-xs"></i>
        <span class="hidden sm:inline">Falla Rápida</span>
      </button>
      <a href="/Wizard" class="inline-flex">
        <button class="inline-flex items-center justify-center rounded-lg font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none bg-[#28A745] text-white hover:bg-green-700 active:bg-green-800 border border-transparent shadow-sm h-10 px-5 text-sm gap-2 shrink-0 !bg-slate-900 !hover:bg-slate-800">
          <i class="fas fa-play text-xs"></i>
          <span>Iniciar Ronda (Wizard)</span>
        </button>
      </a>
    </div>
  </div>

  <!-- L22: Top Widgets -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Chart: Avance Global -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-5 flex flex-col items-center justify-center relative">
      <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-2 self-start w-full text-left">Avance Global</h3>
      <div class="h-40 w-full relative content-center flex items-center justify-center">
        <!-- Recharts Placeholder -> Chart.js canvas -->
        <div style="height: 140px; width: 140px;" class="relative">
            <canvas id="globalProgressChart"></canvas>
            <div class="absolute inset-0 flex items-center justify-center flex-col pointer-events-none">
              <span class="text-2xl font-bold text-slate-800">45%</span>
              <span class="text-[10px] text-slate-400 font-medium uppercase mt-1">Completado</span>
            </div>
        </div>
      </div>
    </div>

    <!-- Chart: Por Tipo de Equipo -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-5">
      <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Por Tipo de Equipo</h3>
      <div class="h-40 w-full relative">
        <canvas id="typeProgressChart"></canvas>
      </div>
    </div>

    <!-- Chart: Avance de Subgrupos -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-5">
      <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Avance de Subgrupos</h3>
      <div class="h-40 w-full relative">
        <canvas id="subgroupsProgressChart"></canvas>
      </div>
    </div>
  </div>

  <!-- LabProgress Component -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Bars -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-5 lg:col-span-2">
      <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-5">Avance por Laboratorio</h3>
      <div class="space-y-4">
          
        <div class="flex items-center gap-4">
          <span class="w-20 text-sm font-semibold text-slate-700">Civil</span>
          <div class="flex-1 h-3 bg-slate-100 rounded-full overflow-hidden flex">

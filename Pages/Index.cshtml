              </td>
              <td class="px-6 py-4 border-0">
                <button class="font-semibold text-[#3B82F6] hover:underline cursor-pointer text-left focus:outline-none bg-transparent border-0 p-0 m-0 shadow-none">Torno CNC Haas</button>
                <p class="text-xs text-slate-400 mt-0.5 mb-0">INV-11203</p>
              </td>
              <td class="px-6 py-4 border-0">
                <span class="text-slate-600 truncate max-w-[200px] inline-block">Mantenimiento husillo principal</span>

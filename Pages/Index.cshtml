@page
@model IndexModel
@using Proyecto_Laboratorios_Univalle.Models.Enums
@{
    var now = DateTime.UtcNow;
    string greeting = now.Hour < 12 ? "Buenos días" : now.Hour < 18 ? "Buenas tardes" : "Buenas noches";
}

<div class="container-fluid">
    
    <!-- 🌟 HERO SECTION: BIENVENIDA MÁS PROFESIONAL -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-white shadow-sm border-0 rounded-lg overflow-hidden dashboard-hero">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="hero-icon mr-4 d-none d-md-flex">
                        <i class="fas fa-chart-line fa-3x text-primary opacity-2"></i>
                    </div>
                    <div>
                        <h2 class="font-weight-bold text-dark mb-1">@greeting, @User.Identity?.Name</h2>
                        <p class="text-muted mb-0">
                            <span class="badge badge-soft-primary px-3 mr-2">
                                <i class="far fa-calendar-alt mr-1"></i> @now.ToString("dd 'de' MMMM, yyyy")
                            </span>
                            Resumen operativo del Sistema de Gestión de Laboratorios.
                        </p>
                    </div>
                    <div class="ml-auto d-none d-lg-block">
                        <div class="text-right">
                            <h4 class="mb-0 font-weight-bold text-primary">@Model.OperationalPercent%</h4>
                            <small class="text-muted uppercase font-weight-bold" style="letter-spacing: 1px;">Operatividad Total</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ⚡ QUICK ACTIONS: ACCESOS RÁPIDOS ELEGANTES -->
    <div class="row mb-4">
        <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
            <a asp-page="/Equipment/Create" class="action-card card h-100 shadow-sm border-0 text-decoration-none">
                <div class="card-body text-center p-4">
                    <div class="action-icon bg-info-soft text-info mb-3 mx-auto">
                        <i class="fas fa-plus"></i>
                    </div>
                    <h6 class="font-weight-bold text-dark mb-1">Nuevo Equipo</h6>
                    <p class="small text-muted mb-0">Registrar activo técnico</p>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
            <a asp-page="/Requests/Create" class="action-card card h-100 shadow-sm border-0 text-decoration-none">
                <div class="card-body text-center p-4">
                    <div class="action-icon bg-warning-soft text-warning mb-3 mx-auto">
                        <i class="fas fa-file-signature"></i>
                    </div>
                    <h6 class="font-weight-bold text-dark mb-1">Nueva Solicitud</h6>
                    <p class="small text-muted mb-0">Reportar falla o daño</p>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6 mb-3 mb-sm-0">
            <a asp-page="/Maintenances/Create" class="action-card card h-100 shadow-sm border-0 text-decoration-none">
                <div class="card-body text-center p-4">
                    <div class="action-icon bg-success-soft text-success mb-3 mx-auto">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <h6 class="font-weight-bold text-dark mb-1">Mantenimiento</h6>
                    <p class="small text-muted mb-0">Programar intervención</p>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-page="/Verifications/Create" class="action-card card h-100 shadow-sm border-0 text-decoration-none">
                <div class="card-body text-center p-4">
                    <div class="action-icon bg-primary-soft text-primary mb-3 mx-auto">
                        <i class="fas fa-check-double"></i>
                    </div>
                    <h6 class="font-weight-bold text-dark mb-1">Inspección</h6>
                    <p class="small text-muted mb-0">Verificar estado técnico</p>
                </div>
            </a>
        </div>
    </div>

    <!-- 📊 INDICADORES PRINCIPALES (KPIs) -->
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm card-stats h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon bg-info text-white mr-3">
                            <i class="fas fa-boxes"></i>
                        </div>
                        <div>
                            <h3 class="font-weight-bold text-dark mb-0">@Model.TotalEquipment</h3>
                            <small class="text-muted font-weight-bold uppercase">Total Activos</small>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span>Estado Operativo</span>
                            <span class="text-success font-weight-bold">@Model.OperationalPercent%</span>
                        </div>
                        <div class="progress" style="height: 5px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @Model.OperationalPercent%"></div>
                        </div>
                    </div>
                    <hr class="my-3 opacity-1">
                    <div class="text-center">
                        <a asp-page="/Equipment/Index" class="btn btn-link btn-sm text-info font-weight-bold">Ver Inventario <i class="fas fa-arrow-right ml-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm card-stats h-100 border-left-warning">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon bg-warning text-white mr-3">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <h3 class="font-weight-bold text-dark mb-0">@Model.PendingRequests</h3>
                            <small class="text-muted font-weight-bold uppercase">Req. Pendientes</small>
                        </div>
                    </div>
                    <div class="mt-4">
                        <span class="badge badge-soft-warning px-3 py-2 btn-rounded w-100">
                            Acción Requerida
                        </span>
                    </div>
                    <hr class="my-3 opacity-1">
                    <div class="text-center">
                        <a asp-page="/Requests/Index" class="btn btn-link btn-sm text-warning font-weight-bold">Gestionar Buzón <i class="fas fa-arrow-right ml-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
            <div class="card border-0 shadow-sm card-stats h-100 border-left-success">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon bg-success text-white mr-3">
                            <i class="fas fa-cogs"></i>
                        </div>
                        <div>
                            <h3 class="font-weight-bold text-dark mb-0">@Model.OngoingMaintenances</h3>
                            <small class="text-muted font-weight-bold uppercase">En Progreso</small>
                        </div>
                    </div>
                    <div class="mt-4">
                        <span class="badge badge-soft-success px-3 py-2 btn-rounded w-100">
                            Servicios Activos
                        </span>
                    </div>
                    <hr class="my-3 opacity-1">
                    <div class="text-center">
                        <a asp-page="/Maintenances/Index" class="btn btn-link btn-sm text-success font-weight-bold">Ver Historial <i class="fas fa-arrow-right ml-1"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm card-stats h-100 border-left-primary">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon bg-primary text-white mr-3">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div>
                            <h3 class="font-weight-bold text-dark mb-0">@Model.RecentVerificationsCount</h3>
                            <small class="text-muted font-weight-bold uppercase">Verif. Semanal</small>
                        </div>
                    </div>
                    <div class="mt-4">
                        <span class="badge badge-soft-primary px-3 py-2 btn-rounded w-100">
                            Inspecciones OK
                        </span>
                    </div>
                    <hr class="my-3 opacity-1">
                    <div class="text-center">
                        <a asp-page="/Verifications/Index" class="btn btn-link btn-sm text-primary font-weight-bold">Bitácora Técnica <i class="fas fa-arrow-right ml-1"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 📂 MAIN CONTENT AREA -->
    <div class="row">
        <!-- SOLICITUDES RECIENTES -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                    <h5 class="card-title font-weight-bold mb-0 text-dark">Actividad Reciente del Buzón</h5>
                    <div class="ml-auto">
                        <span class="badge badge-light text-muted">Últimos 6 registros</span>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-borderless v-middle">
                        <thead class="bg-light-soft text-muted small uppercase">
                            <tr>
                                <th class="px-4">Equipo / ID</th>
                                <th>Solicitante</th>
                                <th>Prioridad</th>
                                <th class="text-center">Estado</th>
                                <th class="text-right px-4">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.LatestRequests.Any())
                            {
                                <tr><td colspan="5" class="text-center py-5 text-muted">No hay solicitudes recientes registradas.</td></tr>
                            }
                            @foreach (var request in Model.LatestRequests)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="font-weight-bold text-dark">@(request.EquipmentUnit?.Equipment?.Name ?? request.Equipment?.Name)</div>
                                        <div class="small text-muted">@(request.EquipmentUnit?.InventoryNumber ?? "-")</div>
                                    </td>
                                    <td>
                                        <div class="small text-dark font-weight-bold">@request.RequestedBy?.FullName</div>
                                        <div class="small text-muted">@request.RequestedBy?.IdentityCard</div>
                                    </td>
                                    <td>
                                        @{
                                            var pClass = request.Priority == RequestPriority.High ? "badge-soft-danger text-danger" : 
                                                       request.Priority == RequestPriority.Medium ? "badge-soft-warning text-warning" : "badge-soft-info text-info";
                                        }
                                        <span class="badge @pClass px-3 py-1 rounded-pill small">@request.Priority</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge badge-dot bg-warning mr-1"></span> @request.Status
                                    </td>
                                    <td class="text-right px-4">
                                        <a href="/Requests/Details/@request.Id" class="btn btn-sm btn-soft-secondary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ALERTAS Y CONTINGENCIAS -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="card-title font-weight-bold mb-0 text-dark">Alertas de Contingencia</h5>
                </div>
                <div class="card-body pt-0">
                    <div class="contingency-list">
                        @if (!Model.CriticalEquipment.Any())
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-check-double text-success fa-3x mb-3 opacity-2"></i>
                                <h6 class="text-dark">Sistemas Estables</h6>
                                <p class="text-muted small">No hay equipos críticos fuera de servicio en este momento.</p>
                            </div>
                        }
                        @foreach (var eq in Model.CriticalEquipment)
                        {
                            <div class="contingency-item p-3 mb-3 border rounded-lg bg-light-soft border-danger-soft">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="stats-icon bg-danger-soft text-danger mr-2" style="width: 30px; height: 30px; font-size: 14px;">
                                        <i class="fas fa-exclamation-triangle"></i>
                                    </div>
                                    <h6 class="font-weight-bold text-dark mb-0">@eq.Equipment?.Name</h6>
                                </div>
                                <div class="small text-muted mb-2">
                                    <i class="fas fa-map-marker-alt mr-1"></i> Lab: @(eq.Laboratory?.Name ?? "S/L") | Inv: @eq.InventoryNumber
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge badge-danger px-2 py-1">CRÍTICO</span>
                                    <a href="/Equipment/Details/@eq.Id" class="small font-weight-bold text-primary">Ver detalle</a>
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.CriticalEquipment.Any())
                    {
                        <div class="alert alert-soft-danger py-2 px-3 small mt-3">
                            <i class="fas fa-info-circle mr-2"></i> @Model.CriticalEquipment.Count equipos requieren atención urgente.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --soft-bg-info: #e1f5fe;
            --soft-bg-success: #e8f5e9;
            --soft-bg-warning: #fff3e0;
            --soft-bg-danger: #ffebee;
            --soft-bg-primary: #e8eaf6;
        }

        .dashboard-hero { border-left: 5px solid #2962ff !important; }
        .hero-icon { width: 80px; height: 80px; background: var(--soft-bg-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        
        .card-stats { transition: transform 0.3s ease; border-bottom: 3px solid transparent !important; }
        .card-stats:hover { transform: translateY(-5px); }
        .stats-icon { width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; }

        .action-card { transition: all 0.3s ease; }
        .action-card:hover { transform: scale(1.03); background: #f8f9fa; }
        .action-icon { width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22px; }

        /* Soft utility classes */
        .bg-info-soft { background-color: var(--soft-bg-info); }
        .bg-warning-soft { background-color: var(--soft-bg-warning); }
        .bg-success-soft { background-color: var(--soft-bg-success); }
        .bg-primary-soft { background-color: var(--soft-bg-primary); }
        .bg-light-soft { background-color: #f8f9fa; }
        
        .badge-soft-primary { background-color: #e8eaf6; color: #3f51b5; }
        .badge-soft-warning { background-color: #fff3e0; color: #ef6c00; }
        .badge-soft-info { background-color: #e1f5fe; color: #0288d1; }
        .badge-soft-success { background-color: #e8f5e9; color: #2e7d32; }

        .btn-soft-secondary { background-color: #f5f5f5; color: #424242; border: none; }
        .btn-soft-secondary:hover { background-color: #eeeeee; }

        .alert-soft-danger { background-color: #ffebee; color: #c62828; border: none; }
        .border-danger-soft { border-color: #ffcdd2 !important; }
        .bg-danger-soft { background-color: #ffebee; }

        .v-middle td { vertical-align: middle !important; }
        .uppercase { text-transform: uppercase; letter-spacing: 0.8px; font-size: 11px; }
        .opacity-1 { opacity: 0.1; }
        .opacity-2 { opacity: 0.2; }

        .badge-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; vertical-align: middle; }
    </style>
}

@section Scripts {
    <script>
        $(function () {
             $('[data-toggle="tooltip"]').tooltip();
        });
    </script>
}

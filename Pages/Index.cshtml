          </div>
          <div class="w-12 text-right text-sm font-bold text-slate-800">60%</div>
          <div class="w-20 text-right text-xs text-slate-500">9/15 eq.</div>
        </div>
        
        <div class="flex items-center gap-4">
          <span class="w-20 text-sm font-semibold text-slate-700">Química</span>
          <div class="flex-1 h-3 bg-slate-100 rounded-full overflow-hidden flex">
            <div class="h-full bg-[#DC3545] transition-all duration-500" style="width: 40%"></div>
          </div>
          <div class="w-12 text-right text-sm font-bold text-slate-800">40%</div>
          <div class="w-20 text-right text-xs text-slate-500">6/15 eq.</div>
        </div>
        
        <div class="flex items-center gap-4">
          <span class="w-20 text-sm font-semibold text-slate-700">Electrónica</span>
          <div class="flex-1 h-3 bg-slate-100 rounded-full overflow-hidden flex">
            <div class="h-full bg-[#DC3545] transition-all duration-500" style="width: 20%"></div>
          </div>
          <div class="w-12 text-right text-sm font-bold text-slate-800">20%</div>
          <div class="w-20 text-right text-xs text-slate-500">3/15 eq.</div>
        </div>

      </div>
    </div>

    <!-- Alerts -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-0 flex flex-col">
      <div class="px-4 py-3 bg-[#DC3545]/10 border-b border-[#DC3545]/20 flex items-center gap-2">
        <i class="fas fa-exclamation-circle text-[#DC3545]"></i>
        <h3 class="text-xs font-bold text-red-800 uppercase tracking-wider">Vencidos</h3>
      </div>
      <div class="p-4 space-y-3 bg-white">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-semibold text-slate-800">Horno PINZUAR</p>
            <p class="text-xs text-slate-500">Civil</p>
          </div>
          <span class="text-[10px] font-bold text-[#DC3545] bg-[#DC3545]/10 px-2 py-0.5 rounded-full mt-1">Hace 5 días</span>
        </div>
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-semibold text-slate-800">Balanza OHAUS</p>
            <p class="text-xs text-slate-500">H-1</p>
          </div>
          <span class="text-[10px] font-bold text-[#DC3545] bg-[#DC3545]/10 px-2 py-0.5 rounded-full mt-1">Hace 2 días</span>
        </div>
      </div>

      <div class="px-4 py-3 bg-[#FFC107]/10 border-y border-[#FFC107]/20 flex items-center gap-2 mt-auto">
        <i class="fas fa-clock text-[#FFC107]"></i>
        <h3 class="text-xs font-bold text-yellow-800 uppercase tracking-wider">Próximos a Vencer</h3>
      </div>
      <div class="p-4 space-y-3 bg-white">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-semibold text-slate-800">Fermentador INOX</p>
            <p class="text-xs text-slate-500">H-1</p>
          </div>
          <span class="text-[10px] font-bold text-yellow-800 bg-[#FFC107]/20 px-2 py-0.5 rounded-full mt-1">En 3 días</span>
        </div>
        <div class="flex justify-between items-start">
          <div>
            <p class="text-sm font-semibold text-slate-800">Campana WILDA</p>
            <p class="text-xs text-slate-500">H-1</p>
          </div>
          <span class="text-[10px] font-bold text-yellow-800 bg-[#FFC107]/20 px-2 py-0.5 rounded-full mt-1">En 6 días</span>
        </div>
      </div>
    </div>
  </div>

  <!-- L48: Main Gantt / Table Area -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col overflow-visible">
    <div class="px-6 py-4 border-b border-gray-100 flex flex-col gap-4 bg-white rounded-t-xl">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-bold text-slate-800">Cronograma de Intervenciones</h2>
        <div class="flex gap-2">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full font-semibold bg-slate-100 text-slate-700 border border-slate-200 text-[10px]">Semana 12 - 16</span>
        </div>
      </div>
      
      <!-- Filters Bar -->
      <div class="flex flex-wrap items-center gap-3 pt-2">
        <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mr-2">
          <i class="fas fa-filter text-xs"></i> Filtros:
        </div>
        
        <div class="relative group">
          <button class="flex items-center gap-2 bg-[#F8F9FA] hover:bg-slate-100 border border-gray-200 px-3 py-1.5 rounded-lg text-sm font-semibold text-slate-700 transition-colors">
            Laboratorio <i class="fas fa-chevron-down text-slate-400 text-[10px]"></i>
          </button>
        </div>
        
        <div class="relative group">
          <button class="flex items-center gap-2 bg-[#F8F9FA] hover:bg-slate-100 border border-gray-200 px-3 py-1.5 rounded-lg text-sm font-semibold text-slate-700 transition-colors">
            Categoría <i class="fas fa-chevron-down text-slate-400 text-[10px]"></i>
          </button>
        </div>
        
        <div class="relative group">
          <button class="flex items-center gap-2 bg-[#F8F9FA] hover:bg-slate-100 border border-gray-200 px-3 py-1.5 rounded-lg text-sm font-semibold text-slate-700 transition-colors">
            Técnico <i class="fas fa-chevron-down text-slate-400 text-[10px]"></i>
          </button>
        </div>

        <div class="h-6 w-px bg-gray-200 mx-1"></div>

        <div class="flex bg-[#F8F9FA] rounded-lg p-0.5 border border-gray-200">
            <button class="px-3 py-1 text-xs font-semibold rounded-md transition-colors bg-white shadow-sm text-slate-800">Todos</button>
            <button class="px-3 py-1 text-xs font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 hover:bg-slate-100">Planeado</button>
            <button class="px-3 py-1 text-xs font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 hover:bg-slate-100">En Progreso</button>
            <button class="px-3 py-1 text-xs font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 hover:bg-slate-100">Ejecutado</button>
            <button class="px-3 py-1 text-xs font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700 hover:bg-slate-100">Externo</button>
        </div>
      </div>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm whitespace-nowrap m-0 border-0">
        <thead class="bg-[#F8F9FA] text-slate-500 uppercase font-semibold text-xs tracking-wider border-b-2 border-gray-200">
          <tr>
            <th class="px-6 py-4 font-semibold border-0">Laboratorio</th>
            <th class="px-6 py-4 font-semibold border-0">Equipo / Inv.</th>
            <th class="px-6 py-4 font-semibold border-0">Falla Reportada</th>
            <th class="px-6 py-4 font-semibold border-0">Servicio</th>
            <th class="px-6 py-4 font-semibold border-0">S12</th>
            <th class="px-6 py-4 font-semibold border-0">S13</th>
            <th class="px-6 py-4 font-semibold border-0">S14</th>
            <th class="px-6 py-4 font-semibold border-0 text-center w-12"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
            
            <!-- Item 1: Ejecutado -->
            <tr class="hover:bg-slate-50/50 transition-colors group">
              <td class="px-6 py-4 border-0">
                <span class="font-medium text-slate-700">Civil y Suelos</span>
              </td>
              <td class="px-6 py-4 border-0">
                <button class="font-semibold text-[#3B82F6] hover:underline cursor-pointer text-left focus:outline-none bg-transparent border-0 p-0 m-0 shadow-none">Prensa Hidráulica 200T</button>
                <p class="text-xs text-slate-400 mt-0.5 mb-0">INV-11201</p>
              </td>
              <td class="px-6 py-4 border-0">
                <span class="text-slate-600 truncate max-w-[200px] inline-block">Fuga de aceite en cilindro</span>
              </td>
              <td class="px-6 py-4 border-0">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800 border border-blue-200">Interno</span>
              </td>
              <td class="px-6 py-4 border-0">
                <div class="h-6 bg-[#28A745]/20 border border-[#28A745]/40 rounded w-full relative group-hover:bg-[#28A745]/30 transition-colors"><span class="absolute inset-0 flex items-center justify-center text-[10px] text-[#28A745] font-bold">OK</span></div>
              </td>
              <td class="px-6 py-4 border-0"></td>
              <td class="px-6 py-4 border-0"></td>
              <td class="px-6 py-4 text-center border-0">
                <button class="text-slate-400 hover:text-slate-700 focus:outline-none bg-transparent border-0"><i class="fas fa-ellipsis-v"></i></button>
              </td>
            </tr>

            <!-- Item 2: Planeado -->
            <tr class="hover:bg-slate-50/50 transition-colors group">
              <td class="px-6 py-4 border-0">
                <span class="font-medium text-slate-700">Biotecnología</span>
              </td>
              <td class="px-6 py-4 border-0">
                <button class="font-semibold text-[#3B82F6] hover:underline cursor-pointer text-left focus:outline-none bg-transparent border-0 p-0 m-0 shadow-none">Espectrofotómetro UV/VIS</button>
                <p class="text-xs text-slate-400 mt-0.5 mb-0">INV-11202</p>
              </td>
              <td class="px-6 py-4 border-0">
                <span class="text-slate-600 truncate max-w-[200px] inline-block">Calibración Lámpara D2</span>
              </td>
              <td class="px-6 py-4 border-0">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200">Externo</span>
              </td>
              <td class="px-6 py-4 border-0"></td>
              <td class="px-6 py-4 border-0">
                <div class="h-6 bg-[#FFC107]/20 border border-[#FFC107]/40 rounded w-full relative"><span class="absolute inset-0 flex items-center justify-center text-[10px] text-yellow-800 font-bold">Prev.</span></div>
              </td>
              <td class="px-6 py-4 border-0">
                <div class="h-6 bg-slate-100 border border-slate-200 rounded w-full opacity-50"></div>
              </td>
              <td class="px-6 py-4 text-center border-0">
                <button class="text-slate-400 hover:text-slate-700 focus:outline-none bg-transparent border-0"><i class="fas fa-ellipsis-v"></i></button>
              </td>
            </tr>

            <!-- Item 3: Ejecutado -->
